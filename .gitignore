# Dependencies
node_modules/

# Build output
dist/

# IDE
.vscode/
.idea/
CLAUDE.md
.claude
GEMINI.md
.gemini/

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local
.env.deploy

# Logs
*.log
npm-debug.log*

# Astro
.astro/

# Tooling privado de migración y QA (no forma parte del producto final).
# Incluye: download-binaries, rewrite-urls, audit-links, migrate-*, check-itrc-changes.
# Si en el futuro se necesitan scripts para el webmaster, agregarlos a
# package.json scripts o crear docs/ops/ dedicado (tracked).
scripts/
# cms-strapi/scripts/ es infraestructura del CMS (autogen de schemas,
# migración masiva, generación de fetchers). Sí debe trackearse.
!cms-strapi/scripts/
!cms-strapi/scripts/**

# Salidas de los scripts anteriores
reports/

# Docs de trabajo locales (planificación, tracker, análisis de gaps).
# Fuente única de contexto para reanudar conversaciones. No suben al remoto.
.local-docs/

# Binarios migrados desde itrc.gov.co al filesystem local.
# Ver .local-docs/ESTRATEGIA.md para el plan de hosting final.
# Backup cubierto por OneDrive. No se publican en el remoto de pruebas.
# Ignorar todo lo que esté directamente bajo public/documentos/
# pero permitir excepciones específicas (CIPREP) más abajo.
public/documentos/*
# Excepción: documentos CIPREP sí se commitean (volumen pequeño, recursos
# del Congreso publicados en la landing /ciprep)
!public/documentos/ciprep/
!public/documentos/ciprep/**
# Excepción: fichas de relatoría que la oficina jurídica entregue para publicar
# (catálogo de 152+ fichas migrado desde Joomla legacy roto; los PDFs llegan
# por goteo). Volumen estimado pequeño porque cada ficha es ~200-300 KB.
!public/documentos/relatorias/
!public/documentos/relatorias/**
# Excepción: material infantil (cuento + libro infantil ITRC) publicado en
# /observatorio/eje-de-educacion/itrc-para-ninos. 2 PDFs (~45 MB).
!public/documentos/ninos/
!public/documentos/ninos/**
.env.cms
