# Plantilla de configuración del stack CMS (Strapi + Postgres).
# Copiar a .env.cms (gitignored) y completar con valores reales.
# docker-compose.yml lee automáticamente del archivo .env del directorio
# actual; opcionalmente: docker compose --env-file .env.cms ... .

# ---- Postgres ----
CMS_DB_NAME=strapi
CMS_DB_USER=strapi
CMS_DB_PASSWORD=cambiar-en-local-y-en-server

# ---- Secretos de Strapi ----
# Generar cada uno con: openssl rand -base64 16
# APP_KEYS necesita al menos 2 valores separados por coma.
STRAPI_APP_KEYS=cambiar1,cambiar2
STRAPI_API_TOKEN_SALT=cambiar
STRAPI_ADMIN_JWT_SECRET=cambiar
STRAPI_JWT_SECRET=cambiar
STRAPI_TRANSFER_TOKEN_SALT=cambiar
STRAPI_ENCRYPTION_KEY=cambiar

# ---- GitHub dispatch (opcional, para auto-rebuild on publish) ----
# Dejar vacío para deshabilitar el dispatch.
GITHUB_REPO=cdavidbm/pitrcastro
GITHUB_DISPATCH_TOKEN=
