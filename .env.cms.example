# Plantilla de configuración del stack CMS (Strapi + Postgres).
# Copiar a .env.cms (gitignored) y completar con valores reales.
# El docker-compose.yml usa COMPOSE_ENV_FILES=.env.cms si está presente.

# ---- Postgres ----
CMS_DB_NAME=strapi
CMS_DB_USER=strapi
CMS_DB_PASSWORD=cambiar-en-local

# ---- Conexión Strapi → Postgres (estos los lee Strapi de su .env propio,
# pero los duplicamos aquí como referencia para POC) ----
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=cambiar-en-local
DATABASE_SSL=false
