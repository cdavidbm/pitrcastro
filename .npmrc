# pnpm policy de seguridad y consistencia.
# El preinstall en package.json refuerza only-allow pnpm; este archivo
# sintoniza el comportamiento del install para que sea reproducible.

# Resuelve peer deps automáticamente sin romper instalaciones.
auto-install-peers=true

# Acepta peer deps levemente desalineadas (no aborta install).
strict-peer-dependencies=false

# Force que la versión de Node coincida con engines.node de package.json.
engine-strict=true

# Por defecto los installs usan el lockfile congelado (como `pnpm ci`).
# Solo se actualiza el lockfile con `pnpm install --no-frozen-lockfile`.
prefer-frozen-lockfile=true
