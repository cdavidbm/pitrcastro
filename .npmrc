# pnpm policy de seguridad y consistencia.
# El preinstall en package.json refuerza only-allow pnpm; este archivo
# sintoniza el comportamiento del install para que sea reproducible.

# Resuelve peer deps automáticamente sin romper instalaciones.
auto-install-peers=true

# Acepta peer deps levemente desalineadas (no aborta install).
strict-peer-dependencies=false

# Force que la versión de Node coincida con engines.node de package.json.
engine-strict=true

# Por defecto los installs usan el lockfile congelado (como `pnpm ci`).
# Solo se actualiza el lockfile con `pnpm install --no-frozen-lockfile`.
prefer-frozen-lockfile=true

# Resiliencia de red para el runner self-hosted del datacenter ITRC: vimos
# instalaciones colgadas indefinidamente (CPU 0%, sockets en wait) cuando
# algún tarball del registry npm no responde. Estos timeouts garantizan
# que un fetch lento falle rápido y se reintente, en vez de bloquear el
# build entero. Inocuo en máquinas con buena red (cuando todo va bien
# nunca se acerca a estos límites).
fetch-timeout=120000
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
# Concurrencia moderada de red: el default de 16 conexiones simultáneas
# puede saturar el firewall corporativo del datacenter; con 8 se ve igual
# de rápido en redes domésticas y más estable en el runner.
network-concurrency=8
