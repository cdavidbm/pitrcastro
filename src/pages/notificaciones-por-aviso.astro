---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

import pageData from '../content/pages/atencion/notificaciones-por-aviso.json';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Atención y Servicios', href: '#' },
  { label: pageData.title }
];

const enlacesRelacionados = [
  { titulo: 'Notificaciones y Traslados', descripcion: 'Edictos, estados y traslados de actos administrativos', url: '/notificaciones-y-traslados', icon: 'fa-bell' },
  { titulo: 'Canales de Atención', descripcion: 'Directorio institucional y canales de contacto', url: '/canales-de-atencion-al-ciudadano', icon: 'fa-headset' },
  { titulo: 'Preguntas Frecuentes', descripcion: 'Respuestas a las preguntas más comunes', url: '/preguntas-frecuentes', icon: 'fa-circle-question' },
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage
    title={pageData.title}
    subtitle={pageData.description}
    icon={pageData.icon}
    breadcrumb={breadcrumb}
  />

  <section class="aviso-section">
    <div class="container">
      <div class="aviso-content">
        <div class="aviso-icon-block">
          <i class="fa-solid fa-scale-balanced" aria-hidden="true"></i>
        </div>

        <p class="aviso-texto">{pageData.textoLegal}</p>

        <blockquote class="aviso-cita">
          <i class="fa-solid fa-quote-left aviso-cita__quote" aria-hidden="true"></i>
          <p>{pageData.citaLegal}</p>
          <cite>— Artículo 69, Ley 1437 de 2011</cite>
        </blockquote>

        <div class="aviso-divider"></div>

        <div class="aviso-link-card">
          <a href="https://www.itrc.gov.co/denuncias/consulta" target="_blank" rel="noopener">
            <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
            Respuestas a P.Q.R.S anónimas o sin dirección
          </a>
        </div>
      </div>
    </div>
  </section>

  <RelatedLinks links={enlacesRelacionados} title="Atención y Servicios" />
</Base>

<style>
  .aviso-section {
    padding: var(--space-10) var(--space-6) var(--space-16);
    background: var(--theme-surface);
  }

  .aviso-section .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .aviso-content {
    text-align: center;
  }

  .aviso-icon-block {
    width: 72px;
    height: 72px;
    margin: 0 auto var(--space-8);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--itrc-gold-rgb), 0.1);
    border-radius: var(--radius-full);
    color: var(--itrc-gold);
    font-size: var(--font-size-3xl);
  }

  .aviso-texto {
    font-size: var(--font-size-lg);
    line-height: 1.8;
    color: var(--theme-text);
    margin-bottom: var(--space-8);
    text-align: left;
  }

  .aviso-cita {
    position: relative;
    background: var(--theme-surface-alt);
    border-left: 4px solid var(--itrc-gold);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: var(--space-8) var(--space-8) var(--space-6);
    margin: 0 0 var(--space-8);
    text-align: left;
  }

  .aviso-cita__quote {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    font-size: var(--font-size-2xl);
    color: var(--itrc-gold);
    opacity: 0.3;
  }

  .aviso-cita p {
    font-size: var(--font-size-base);
    line-height: 1.8;
    color: var(--theme-text);
    font-style: italic;
    margin: 0 0 var(--space-4);
    padding-left: var(--space-6);
  }

  .aviso-cita cite {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--theme-text-muted);
    font-style: normal;
    font-weight: 600;
    padding-left: var(--space-6);
  }

  .aviso-divider {
    width: 60px;
    height: 3px;
    background: var(--itrc-gold);
    margin: var(--space-8) auto;
    border-radius: var(--radius-full);
  }

  .aviso-link-card a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    background: var(--theme-surface);
    border: 2px solid var(--itrc-gold);
    border-radius: var(--radius-full);
    color: var(--itrc-gold);
    font-weight: 700;
    font-size: var(--font-size-base);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .aviso-link-card a:hover {
    background: var(--itrc-gold);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .aviso-section {
      padding: var(--space-6) var(--space-4) var(--space-12);
    }

    .aviso-texto {
      font-size: var(--font-size-base);
    }

    .aviso-cita {
      padding: var(--space-6) var(--space-5) var(--space-4);
    }

    .aviso-cita p {
      font-size: var(--font-size-sm);
      padding-left: var(--space-4);
    }

    .aviso-link-card a {
      font-size: var(--font-size-sm);
      padding: var(--space-3) var(--space-6);
    }
  }
</style>
