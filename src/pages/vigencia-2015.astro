---
import Base from '../layouts/Base.astro';
import ListadoInformes from '../components/ListadoInformes.astro';
import { getNormativaVigenciaList } from '../utils/strapi-fetchers';

const SLUG = 'vigencia-2015';
const all = await getNormativaVigenciaList();
const pageData = all.find((x: any) => x.slug === SLUG);
if (!pageData) throw new Error(`Strapi: no se encontro slug ${SLUG} en normativa-vigencia`);
---

<Base title={pageData.title} description={pageData.description} strapiSlug={`normativa-vigencia/${SLUG}`}>
  <ListadoInformes pageData={pageData} />
</Base>
