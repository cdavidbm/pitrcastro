    { nombre: 'Septiembre', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/10/Publicacion-Septiembre-2024-web-agencia.pdf' },
    { nombre: 'Junio', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/Publicacion-Junio-2024-web-agencia-V1.pdf' },
    { nombre: 'Marzo', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/04/Publicacion-Marzo-2024-web-agencia-V2pag.pdf' },
