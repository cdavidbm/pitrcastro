---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Supervisión y Vigilancia' }];

const entidades = [
  { nombre: 'Contraloría General de la República', direccion: 'Carrera 69 No. 44-35', telefono: '(601) 518 7000', email: 'cgr@contraloria.gov.co', web: 'https://www.contraloria.gov.co/', control: 'Control fiscal' },
  { nombre: 'Procuraduría General de la Nación', direccion: 'Carrera 5 # 15-80', telefono: '(601) 587 8750', email: '', web: 'https://www.procuraduria.gov.co/', control: 'Control disciplinario' },
  { nombre: 'Fiscalía General de la Nación', direccion: 'Avenida Calle 24 No. 52-01 (Ciudad Salitre)', telefono: '(601) 791 0758', email: 'ges.documentalpqrs@fiscalia.gov.co', web: 'https://www.fiscalia.gov.co/colombia/', control: 'Control penal' },
  { nombre: 'Contaduría General de la Nación', direccion: 'Calle 26 No. 69-76, Edificio Elemento Torre 1, Piso 15', telefono: '(601) 492 6400', email: 'contactenos@contaduria.gov.co', web: 'https://www.contaduria.gov.co/', control: 'Control contable' },
  { nombre: 'Congreso de la República — Senado', direccion: 'Calle 11 # 5-60 Tercer Nivel', telefono: '(601) 382 3000', email: 'atencionciudadanacongreso@senado.gov.co', web: 'https://www.senado.gov.co/', control: 'Control político' },
  { nombre: 'Congreso de la República — Cámara', direccion: 'Carrera 7 No. 8-68 Primer Piso', telefono: '(601) 877 0720', email: '', web: 'https://www.camara.gov.co/', control: 'Control político' },
  { nombre: 'Archivo General de la Nación', direccion: 'Carrera 6 No. 6-91', telefono: '(601) 328 2888', email: 'contacto@archivogeneral.gov.co', web: 'https://www.archivogeneral.gov.co/', control: 'Control de política archivística' },
  { nombre: 'Ministerio de Hacienda y Crédito Público', direccion: 'Carrera 8 No. 6C-38', telefono: '(601) 381 1700', email: 'relacionciudadano@minhacienda.gov.co', web: 'https://www.minhacienda.gov.co/', control: 'Control presupuestal' },
  { nombre: 'Comisión Nacional del Servicio Civil', direccion: 'Carrera 16 No. 96-64, Piso 7', telefono: '(601) 325 9700', email: 'atencionalciudadano@cnsc.gov.co', web: 'https://www.cnsc.gov.co/', control: 'Control de la carrera administrativa' },
];
---
<Base title="Supervisión y Vigilancia" description="Entes y autoridades que vigilan a la Agencia ITRC">
  <HeroPage title="Supervisión y Vigilancia" subtitle="Entes y autoridades que vigilan a la Agencia ITRC" icon="fa-building-shield" breadcrumb={breadcrumb} />
  <section class="sv-section"><div class="container">
    <p class="sv-intro">La UAE Agencia ITRC como entidad sin personería jurídica, adscrita al Ministerio de Hacienda y Crédito Público, está sometida a la vigilancia y control de los siguientes entes y autoridades:</p>
    <div class="sv-grid">
      {entidades.map((e) => (
        <div class="sv-card">
          <div class="sv-card__header">
            <h3>{e.nombre}</h3>
            <span class="sv-badge">{e.control}</span>
          </div>
          <div class="sv-card__body">
            <div class="sv-dato"><i class="fa-solid fa-location-dot" aria-hidden="true"></i><span>{e.direccion}</span></div>
            <div class="sv-dato"><i class="fa-solid fa-phone" aria-hidden="true"></i><span>{e.telefono}</span></div>
            {e.email && <div class="sv-dato"><i class="fa-solid fa-envelope" aria-hidden="true"></i><a href={`mailto:${e.email}`}>{e.email}</a></div>}
            <a href={e.web} target="_blank" rel="noopener" class="sv-web"><i class="fa-solid fa-globe" aria-hidden="true"></i> Sitio web <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></a>
          </div>
        </div>
      ))}
    </div>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>
  .sv-section{padding:var(--space-8) var(--space-6) var(--space-16);background:var(--theme-surface)}.sv-section .container{max-width:1000px;margin:0 auto}
  .sv-intro{font-size:var(--font-size-base);line-height:1.8;color:var(--theme-text);margin-bottom:var(--space-8);text-align:center}
  .sv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--space-5)}
  .sv-card{border:1px solid var(--theme-border);border-radius:var(--radius-xl);overflow:hidden;transition:all var(--transition-base)}
  .sv-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px)}
  .sv-card__header{padding:var(--space-4) var(--space-5);background:var(--theme-surface-alt);border-bottom:2px solid var(--itrc-gold)}
  .sv-card__header h3{font-size:var(--font-size-sm);color:var(--theme-heading);margin:0 0 var(--space-2)}
  .sv-badge{display:inline-block;padding:2px 10px;background:rgba(var(--itrc-gold-rgb),0.12);color:var(--itrc-gold);border-radius:var(--radius-full);font-size:var(--font-size-xs);font-weight:700}
  .sv-card__body{padding:var(--space-4) var(--space-5);display:flex;flex-direction:column;gap:var(--space-2)}
  .sv-dato{display:flex;align-items:flex-start;gap:var(--space-2);font-size:var(--font-size-xs);color:var(--theme-text-secondary)}
  .sv-dato i{color:var(--itrc-gold);margin-top:2px;flex-shrink:0;font-size:var(--font-size-xs)}
  .sv-dato a{color:var(--itrc-gold);text-decoration:none}.sv-dato a:hover{text-decoration:underline}
  .sv-web{display:inline-flex;align-items:center;gap:var(--space-2);margin-top:var(--space-2);padding:var(--space-2) var(--space-3);background:var(--itrc-navy);color:var(--white);border-radius:var(--radius-md);font-size:var(--font-size-xs);font-weight:700;text-decoration:none;transition:all var(--transition-fast);align-self:flex-start}
  .sv-web:hover{background:var(--itrc-gold)}
  .back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}
  @media(max-width:768px){.sv-section{padding:var(--space-6) var(--space-4) var(--space-12)}.sv-grid{grid-template-columns:1fr}}
</style>
