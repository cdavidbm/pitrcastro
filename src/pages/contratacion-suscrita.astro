---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { getTransparenciaContratacionContratacionSuscrita } from '../utils/strapi-fetchers';
import { mediaUrl } from '../utils/strapi-media';
const pageData: any = (await getTransparenciaContratacionContratacionSuscrita()) ?? {};
const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: 'Contratación Suscrita' }
];

const totalProcesos = (pageData.convocatorias || []).reduce((acc: number, c: any) => acc + c.procesos.length, 0);
const totalContratos = (pageData.contratacionSuscrita || []).reduce((acc: number, s: any) => acc + s.contratos.length, 0);
---

<Base title={pageData.title} description={pageData.description} strapiSlug="transparencia-contratacion-contratacion-suscrita">
  <HeroPage title="Información Contractual" subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="cs-section">
    <div class="container">
      <p class="cs-intro">{pageData.intro}</p>

      <!--
        Pestañas (tabs) — solicitadas por el área de contratación para que el
        usuario navegue claramente entre lo MENSUAL (contratos suscritos) y
        los PROCESOS (selección pública). Los accesos directos a SECOP I/II
        a nivel pagina se eliminaron a proposito: llevaban al login y el
        Decreto exige vista publica. Los enlaces a SECOP dentro de cada fila
        de proceso siguen apuntando a la vista publica.
      -->
      <div class="cs-tabs" role="tablist" aria-label="Secciones de contratación">
        <button
          class="cs-tab cs-tab--active"
          role="tab"
          aria-selected="true"
          aria-controls="tab-panel-contratos"
          id="tab-btn-contratos"
          data-tab="contratos"
        >
          <i class="fa-solid fa-file-signature" aria-hidden="true"></i>
          <span>Contratación Suscrita</span>
          <span class="cs-tab__count">{totalContratos}</span>
        </button>
        <button
          class="cs-tab"
          role="tab"
          aria-selected="false"
          aria-controls="tab-panel-procesos"
          id="tab-btn-procesos"
          data-tab="procesos"
          tabindex="-1"
        >
          <i class="fa-solid fa-bullhorn" aria-hidden="true"></i>
          <span>Procesos Públicos de Selección</span>
          <span class="cs-tab__count">{totalProcesos}</span>
        </button>
      </div>

      <!-- Tab 1: Contratación Suscrita (mensual) -->
      <div
        class="cs-panel cs-panel--active"
        role="tabpanel"
        id="tab-panel-contratos"
        aria-labelledby="tab-btn-contratos"
      >
        <p class="cs-panel-intro">
          Listado mensual de contratos suscritos por la Agencia ITRC. Cada
          archivo contiene el detalle de los contratos del periodo, con sus
          accesos de vista pública individuales.
        </p>

        {pageData.contratacionSuscrita && pageData.contratacionSuscrita.map((s: any, i: number) => (
          <details class="cs-cat" open={i === 0}>
            <summary class="cs-cat__summary">
              <span class="cs-cat__titulo">{s.titulo}</span>
              <span class="cs-cat__count">{s.contratos.length}</span>
              <i class="fa-solid fa-chevron-down cs-chevron" aria-hidden="true"></i>
            </summary>
            <ul class="cs-list">
              {s.contratos.map((c: any) => (
                <li>
                  <a href={c.url} target="_blank" rel="noopener noreferrer" class="cs-doc">
                    <i class="fa-solid fa-file-excel" aria-hidden="true"></i>
                    <span>{c.periodo}</span>
                    <i class="fa-solid fa-download" aria-hidden="true"></i>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>

      <!-- Tab 2: Procesos Públicos de Selección -->
      <div
        class="cs-panel"
        role="tabpanel"
        id="tab-panel-procesos"
        aria-labelledby="tab-btn-procesos"
        hidden
      >
        <p class="cs-panel-intro">
          Procesos públicos de selección de la Agencia ITRC organizados por
          categoría. Cada fila incluye los documentos del proceso y un enlace
          de vista pública en SECOP.
        </p>

        {pageData.convocatorias && pageData.convocatorias.map((cat: any) => (
          <details class="cs-cat" open>
            <summary class="cs-cat__summary">
              <span class="cs-cat__titulo">{cat.categoria}</span>
              <span class="cs-cat__count">{cat.procesos.length}</span>
              <i class="fa-solid fa-chevron-down cs-chevron" aria-hidden="true"></i>
            </summary>
            <div class="cs-tabla-wrap">
              <table class="cs-tabla">
                <thead>
                  <tr>
                    <th>Proceso</th>
                    <th>Año</th>
                    <th>Documentos</th>
                    <th>SECOP</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.procesos.map((p: any) => (
                    <tr>
                      <td class="cs-c-proc">
                        {p.pdfUrl ? (
                          <a href={mediaUrl(p.pdfUrl)} target="_blank" rel="noopener noreferrer" class="cs-link">
                            <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
                            <strong>{p.label}</strong>
                          </a>
                        ) : (<strong>{p.label}</strong>)}
                      </td>
                      <td class="cs-c-anio">{p.anio || '—'}</td>
                      <td class="cs-c-otros">
                        {p.otros && p.otros.length > 0 ? (
                          <ul>
                            {p.otros.map((o: any) => (
                              <li>
                                <a href={o.url} target="_blank" rel="noopener noreferrer" class="cs-link cs-link--small">
                                  <i class="fa-solid fa-file" aria-hidden="true"></i>
                                  {o.label}
                                </a>
                              </li>
                            ))}
                          </ul>
                        ) : '—'}
                      </td>
                      <td class="cs-c-secop">
                        {p.secopRef && p.secopRef !== '#' ? (
                          <a
                            href={p.secopRef.startsWith('https://') ? p.secopRef : `https://community.secop.gov.co/Public/Tendering/OpportunityDetail/Index?noticeUID=${p.secopRef}&isFromPublicArea=True&isModal=False`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="cs-secop-link"
                            title={`Ver vista pública en SECOP: ${p.secopRef}`}
                          >
                            <i class="fa-solid fa-up-right-from-square" aria-hidden="true"></i>
                            Vista pública
                          </a>
                        ) : '—'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))}
      </div>

      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<script>
  // Tabs: alternar panel activo. Accesible (ARIA + flechas izquierda/derecha).
  (function () {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.cs-tab'));
    if (tabs.length === 0) return;

    const panels: Record<string, HTMLElement | null> = {
      contratos: document.getElementById('tab-panel-contratos'),
      procesos: document.getElementById('tab-panel-procesos'),
    };

    const activate = (key: string) => {
      tabs.forEach((t) => {
        const isActive = t.dataset.tab === key;
        t.classList.toggle('cs-tab--active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        t.setAttribute('tabindex', isActive ? '0' : '-1');
      });
      Object.entries(panels).forEach(([k, panel]) => {
        if (!panel) return;
        const isActive = k === key;
        panel.classList.toggle('cs-panel--active', isActive);
        if (isActive) panel.removeAttribute('hidden');
        else panel.setAttribute('hidden', '');
      });
      // Sincronizar el hash de la URL (sin saltar).
      const newHash = key === 'procesos' ? '#procesos' : '#contratos';
      if (location.hash !== newHash) history.replaceState(null, '', newHash);
    };

    tabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => activate(tab.dataset.tab!));
      tab.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
          e.preventDefault();
          const dir = e.key === 'ArrowRight' ? 1 : -1;
          const next = tabs[(idx + dir + tabs.length) % tabs.length];
          activate(next.dataset.tab!);
          next.focus();
        }
      });
    });

    // Deep-link via hash: #procesos abre el segundo tab directamente.
    if (location.hash === '#procesos') activate('procesos');
  })();
</script>

<style>
  .cs-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .cs-section .container { max-width: 1100px; margin: 0 auto; }
  .cs-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text); margin-bottom: var(--space-8); text-align: center; max-width: 800px; margin-left: auto; margin-right: auto; }

  /* === Tabs === */
  .cs-tabs {
    display: flex;
    gap: var(--space-2);
    border-bottom: 2px solid var(--theme-border);
    margin-bottom: var(--space-6);
    overflow-x: auto;
  }
  .cs-tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    font-family: inherit;
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--theme-text-muted);
    transition: all var(--transition-base);
    white-space: nowrap;
  }
  .cs-tab:hover {
    color: var(--theme-heading);
    background: var(--theme-surface-alt);
  }
  .cs-tab--active {
    color: var(--itrc-navy);
    border-bottom-color: var(--itrc-gold);
    background: transparent;
  }
  .cs-tab i { color: var(--itrc-gold); }
  .cs-tab__count {
    padding: 2px 10px;
    background: var(--theme-surface-alt);
    color: var(--theme-text-muted);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: 800;
  }
  .cs-tab--active .cs-tab__count {
    background: var(--itrc-gold);
    color: var(--itrc-navy);
  }

  .cs-panel { animation: fadeIn 0.25s ease-out; }
  .cs-panel[hidden] { display: none; }
  .cs-panel-intro {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
    margin: 0 0 var(--space-5);
    line-height: 1.6;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === Acordeones internos por categoría/vigencia (sin cambios) === */
  .cs-cat { margin-bottom: var(--space-3); border: 1px solid var(--theme-border); border-radius: var(--radius-lg); overflow: hidden; }
  .cs-cat__summary { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); cursor: pointer; list-style: none; background: var(--theme-surface-alt); }
  .cs-cat__summary::-webkit-details-marker { display: none; }
  .cs-cat__summary:hover { background: var(--theme-border-light); }
  .cs-cat__titulo { flex: 1; font-weight: 800; color: var(--theme-heading); }
  .cs-cat__count { padding: 2px 12px; background: var(--itrc-gold); color: var(--itrc-navy); border-radius: var(--radius-full); font-size: var(--font-size-xs); font-weight: 800; }
  .cs-chevron { color: var(--itrc-gold); transition: transform var(--transition-base); }
  .cs-cat[open] .cs-chevron { transform: rotate(180deg); }

  .cs-tabla-wrap { overflow-x: auto; padding: var(--space-3); }
  .cs-tabla { width: 100%; border-collapse: collapse; font-size: var(--font-size-sm); }
  .cs-tabla th { padding: var(--space-3) var(--space-3); background: var(--theme-surface-alt); text-align: left; font-weight: 700; font-size: var(--font-size-xs); text-transform: uppercase; color: var(--theme-text-muted); border-bottom: 2px solid var(--theme-border); }
  .cs-tabla td { padding: var(--space-3); border-bottom: 1px solid var(--theme-border-light); vertical-align: top; }
  .cs-tabla tbody tr:hover { background: var(--theme-surface-alt); }
  .cs-c-otros ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .cs-c-secop code { font-size: var(--font-size-xs); padding: 2px 6px; background: var(--theme-surface-alt); border-radius: var(--radius-sm); white-space: nowrap; }
  .cs-link { display: inline-flex; align-items: flex-start; gap: var(--space-2); color: var(--theme-heading); text-decoration: none; }
  .cs-link:hover { color: var(--file-pdf); }
  .cs-link i { color: var(--file-pdf); margin-top: 2px; flex-shrink: 0; }
  .cs-link--small { font-size: var(--font-size-xs); }
  .cs-link--small i { color: var(--theme-text-muted); }

  .cs-list { list-style: none; padding: var(--space-3); margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .cs-doc { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); border: 1px solid var(--theme-border-light); border-radius: var(--radius-md); text-decoration: none; transition: all var(--transition-fast); }
  .cs-doc:hover { border-color: #16a34a; background: var(--theme-surface-alt); transform: translateX(3px); }
  .cs-doc > i:first-child { color: #16a34a; }
  .cs-doc span { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .cs-doc > i:last-child { color: var(--theme-text-muted); opacity: 0.4; font-size: var(--font-size-xs); }

  .cs-secop-link { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; background: var(--itrc-navy); color: var(--white); border-radius: var(--radius-md); font-size: var(--font-size-xs); font-weight: 700; text-decoration: none; white-space: nowrap; transition: all var(--transition-fast); }
  .cs-secop-link:hover { background: var(--itrc-gold); color: var(--itrc-navy); transform: scale(1.05); }
  .cs-secop-link i { font-size: 10px; }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 768px) {
    .cs-tabla { font-size: var(--font-size-xs); }
    .cs-tabla th, .cs-tabla td { padding: var(--space-2); }
    .cs-tab { padding: var(--space-3) var(--space-4); font-size: var(--font-size-sm); }
    .cs-tab span:not(.cs-tab__count) { display: none; }
  }
</style>
