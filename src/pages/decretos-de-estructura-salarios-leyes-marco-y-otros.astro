---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import pageData from '../content/pages/transparencia/decretos-estructura.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];

const totalDecretos = pageData.secciones.reduce((acc, s) => acc + s.decretos.length, 0);
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="dec-section">
    <div class="container">
      {pageData.intro && <p class="dec-intro">{pageData.intro}</p>}

      <div class="dec-stats">
        <i class="fa-solid fa-scale-balanced" aria-hidden="true"></i>
        <span>{totalDecretos} decretos publicados en {pageData.secciones.length} categorías</span>
      </div>

      {pageData.secciones.map((s, i) => (
        <section class="dec-seccion">
          <h2 class="dec-seccion__titulo">{s.titulo}</h2>
          {s.descripcion && <p class="dec-seccion__desc">{s.descripcion}</p>}
          <ul class="dec-list">
            {s.decretos.map((dec) => (
              <li class="dec-item">
                <a href={dec.url} target="_blank" rel="noopener noreferrer" class="dec-item__link">
                  <div class="dec-item__badge">
                    <span class="dec-item__numero">{dec.numero}</span>
                    {dec.anio && <span class="dec-item__anio">{dec.anio}</span>}
                  </div>
                  <span class="dec-item__nombre">{dec.nombre}</span>
                  <i class="fa-solid fa-download dec-item__dl" aria-hidden="true"></i>
                </a>
                {dec.nota && <p class="dec-item__nota"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> {dec.nota}</p>}
              </li>
            ))}
          </ul>
        </section>
      ))}

      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .dec-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .dec-section .container { max-width: 1000px; margin: 0 auto; }

  .dec-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text-secondary); margin-bottom: var(--space-6); text-align: justify; max-width: 900px; margin-left: auto; margin-right: auto; }

  .dec-stats { display: inline-flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-5); background: var(--theme-surface-alt); border-radius: var(--radius-full); margin-bottom: var(--space-10); font-weight: 700; color: var(--itrc-gold); font-size: var(--font-size-sm); }
  .dec-stats i { color: var(--itrc-gold); }

  .dec-seccion { margin-bottom: var(--space-10); }
  .dec-seccion__titulo { font-size: var(--font-size-xl); color: var(--theme-heading); margin: 0 0 var(--space-2); padding-bottom: var(--space-3); border-bottom: 2px solid var(--itrc-gold); }
  .dec-seccion__desc { font-size: var(--font-size-sm); color: var(--theme-text-secondary); margin: 0 0 var(--space-5); font-style: italic; }

  .dec-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-3); }

  .dec-item__link { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .dec-item__link:hover { border-color: var(--file-pdf); box-shadow: var(--shadow-md); transform: translateX(4px); }

  .dec-item__badge { display: inline-flex; flex-direction: column; align-items: center; justify-content: center; min-width: 64px; padding: 6px 10px; background: linear-gradient(135deg, var(--itrc-navy), var(--itrc-gold)); color: var(--white); border-radius: var(--radius-md); flex-shrink: 0; }
  .dec-item__numero { font-size: var(--font-size-sm); font-weight: 800; line-height: 1; font-variant-numeric: tabular-nums; }
  .dec-item__anio { font-size: var(--font-size-xs); opacity: 0.85; margin-top: 2px; }

  .dec-item__nombre { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); line-height: 1.5; }
  .dec-item__link:hover .dec-item__nombre { color: var(--file-pdf); }

  .dec-item__dl { color: var(--theme-text-muted); opacity: 0.5; font-size: var(--font-size-sm); flex-shrink: 0; }
  .dec-item__link:hover .dec-item__dl { color: var(--file-pdf); opacity: 1; }

  .dec-item__nota { display: flex; align-items: flex-start; gap: var(--space-2); margin: var(--space-2) 0 0 var(--space-4); padding: var(--space-2) var(--space-3); background: rgba(255,193,7,0.10); border-left: 3px solid #ffc107; border-radius: var(--radius-sm); font-size: var(--font-size-xs); color: var(--theme-text-secondary); }
  .dec-item__nota i { color: #ffa000; flex-shrink: 0; margin-top: 2px; }

  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 640px) { .dec-item__link { flex-wrap: wrap; } .dec-item__nombre { order: 3; width: 100%; } }
</style>
