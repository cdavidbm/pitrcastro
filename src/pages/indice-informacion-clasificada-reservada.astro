---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Índice de Información Clasificada y Reservada' }];
---
<Base title="Índice de Información Clasificada y Reservada" description="Índice de información clasificada y reservada de la Agencia ITRC">
  <HeroPage title="Índice de Información Clasificada y Reservada" subtitle="Instrumentos de gestión de la información" icon="fa-lock" breadcrumb={breadcrumb} />
  <section class="simple-page"><div class="container">
    <a href="https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/11/7-1-2-Índice-de-Información-Clasificada-y-Reservada.xlsx" target="_blank" rel="noopener" class="doc-cta doc-cta--excel"><i class="fa-solid fa-file-excel" aria-hidden="true"></i><span>Información Clasificada y Reservada</span><i class="fa-solid fa-download" aria-hidden="true"></i></a>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.simple-page{padding:var(--space-12) var(--space-6) var(--space-16);background:var(--theme-surface)}.simple-page .container{max-width:700px;margin:0 auto;text-align:center}.doc-cta{display:inline-flex;align-items:center;gap:var(--space-4);padding:var(--space-5) var(--space-8);border:2px solid;border-radius:var(--radius-full);text-decoration:none;font-weight:700;font-size:var(--font-size-base);transition:all var(--transition-base)}.doc-cta:hover{color:var(--white);transform:translateY(-2px);box-shadow:var(--shadow-md)}.doc-cta--excel{border-color:var(--file-excel);color:var(--file-excel)}.doc-cta--excel:hover{background:var(--file-excel)}.back-link{margin-top:var(--space-8)}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}@media(max-width:768px){.doc-cta{font-size:var(--font-size-sm);padding:var(--space-4) var(--space-6)}}</style>
