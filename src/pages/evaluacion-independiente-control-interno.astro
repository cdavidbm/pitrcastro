---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Evaluación Independiente SCI' }];

function fileIcon(url: string) { return url.endsWith('.xlsx') ? 'fa-file-excel' : 'fa-file-pdf'; }
function fileColor(url: string) { return url.endsWith('.xlsx') ? 'excel' : 'pdf'; }

const docs = [
  { nombre: 'Evaluación Independiente SCI — Semestre II 2025', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2026/01/SCI_Sem_I_2025_Conclusiones_publicar.pdf' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2025', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2025/07/Estado-SCI-Sem1-2025.pdf' },
  { nombre: 'Evaluación Independiente SCI — Semestre II 2024', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2025/07/Estado-SCI-Sem2-2024.pdf' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2024', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/Informe-Eval-Ind-SCI-Sem-I-2024.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre II 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/01/Informe-Eval-Ind-SCI-Sem-II-2023.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/07/Informe-Eval-Ind-SCI-Sem-I-2023.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre II 2022', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/01/Informe-Eval-Ind-SCI-Sem-II-2022.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2022', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/Informe-Eval-Ind-SCI-Sem-I-2022.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre II 2021', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/01/Informe-Eval-Ind-SCI-Sem-II-2021.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2021', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/07/2021-07-27-Informe-Eval-Ind-SCI-Sem-I-2021.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre II 2020', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/01/Informe-Eval-Ind-SCI-Sem-II-2020.xlsx' },
  { nombre: 'Evaluación Independiente SCI — Semestre I 2020', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/07/Informe-Eval-Ind-SCI-Sem-I-2020.xlsx' },
];
---

<Base title="Evaluación Independiente — Sistema de Control Interno" description="Informes de evaluación independiente del Sistema de Control Interno">
  <HeroPage title="Evaluación Independiente — SCI" subtitle="Informes del Sistema de Control Interno" icon="fa-clipboard-check" breadcrumb={breadcrumb} />
  <section class="docs-section"><div class="container">
    <div class="docs-list">
      {docs.map((d) => (
        <a href={d.url} target="_blank" rel="noopener" class={`doc-item doc--${fileColor(d.url)}`}>
          <div class="doc-item__icon"><i class={`fa-solid ${fileIcon(d.url)}`} aria-hidden="true"></i></div>
          <span>{d.nombre}</span><i class="fa-solid fa-download" aria-hidden="true"></i>
        </a>
      ))}
    </div>

    <div class="related-section">
      <a href="https://www.itrc.gov.co/Itrc/informe-pormenorizado/" target="_blank" rel="noopener" class="related-link">
        <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
        <span>Informe Pormenorizado del Estado del Control Interno</span>
        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
      </a>
    </div>

    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>

<style>
  .docs-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .docs-section .container { max-width: 850px; margin: 0 auto; }
  .docs-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .doc-item { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .doc-item:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
  .doc-item__icon { width: 40px; height: 40px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); font-size: var(--font-size-lg); transition: all var(--transition-base); }
  .doc--pdf .doc-item__icon { background: rgba(220,53,69,0.08); color: var(--file-pdf); }
  .doc--pdf:hover .doc-item__icon { background: var(--file-pdf); color: var(--white); }
  .doc--excel .doc-item__icon { background: rgba(25,135,84,0.08); color: var(--file-excel); }
  .doc--excel:hover .doc-item__icon { background: var(--file-excel); color: var(--white); }
  .doc-item span { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .doc-item:hover span { color: var(--itrc-gold); }
  .doc-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .doc-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .related-section { margin-top: var(--space-8); padding-top: var(--space-6); border-top: 2px solid var(--theme-border-light); }
  .related-link { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-5) var(--space-6); border: 2px solid var(--itrc-navy); border-radius: var(--radius-xl); text-decoration: none; transition: all var(--transition-base); }
  .related-link:hover { background: var(--itrc-navy); color: var(--white); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .related-link > i:first-child { color: var(--itrc-navy); font-size: var(--font-size-xl); }
  .related-link:hover > i:first-child { color: var(--white); }
  .related-link span { flex: 1; font-size: var(--font-size-base); font-weight: 700; color: var(--itrc-navy); }
  .related-link:hover span { color: var(--white); }
  .related-link > i:last-child { color: var(--itrc-navy); opacity: 0.4; }
  .related-link:hover > i:last-child { color: var(--white); opacity: 1; }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .docs-section { padding: var(--space-6) var(--space-4) var(--space-12); } .doc-item span { font-size: var(--font-size-xs); } }
</style>
