import ListadoInformes from '../components/ListadoInformes.astro';
import { getTransparenciaProcedimientosDecisiones } from '../utils/strapi-fetchers';
const pageData: any = (await getTransparenciaProcedimientosDecisiones()) ?? {};
---

<Base title={pageData.title} description={pageData.description} strapiSlug="transparencia-procedimientos-decisiones">
  <ListadoInformes pageData={pageData} />
</Base>
