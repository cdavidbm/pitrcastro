---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Tablas de Retención Documental' }];
function fileIcon(u: string) { return u.endsWith('.xlsx') ? 'fa-file-excel' : 'fa-file-pdf'; }
function fc(u: string) { return u.endsWith('.xlsx') ? 'excel' : 'pdf'; }
const v1 = [
  { n: 'Tablas de Retención Documental', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/05/Tablas-de-Retencion-Documental.pdf' },
  { n: 'Cuadro de Clasificación Documental', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/01/Cuadro-de-Clasificacion-Documental.pdf' },
  { n: 'Banco Terminológico', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/01/Banco-Terminologico.pdf' },
  { n: 'Resolución No. 176 del 25 de junio de 2020', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/06/Resolución-176-de-2020.pdf' },
  { n: 'Certificado de Convalidación (AGN)', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/05/2-2021-3973-CERTIFICADO_CONVALIDACION_TRD-ITRC-1.pdf' },
  { n: 'Certificado de Inscripción en RUSD', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/05/CERTIFICADO_RUSD_TRD_ITRC.pdf' },
  { n: 'Tablas de Control de Acceso', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/TABLAS-DE-CONTROL-DE-ACCESO-4.xlsx' },
];
const v2 = [
  { n: 'Tablas de Retención Documental — TRD V2', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Tablas-de-Retencion-Documental-TRD-V2..pdf' },
  { n: 'Certificado de Convalidación (AGN)', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Certificado-de-Convalidacion-expedido-por-el-AGN.pdf' },
  { n: 'Certificado de Inscripción en RUSD', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Certificado-de-Inscripcion-en-el-Registro-Unico-de-Series-Documentales-RUSD.pdf' },
  { n: 'Resolución 244 de 2024 — Adopción TRD V2', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Resolucion-244-de-2024-Por-la-cual-se-adopta-la-actualizacion-de-las-tablas-de-retencion-Documental-TRD-version-2-de-la-ITRC.pdf' },
  { n: 'Cuadro de Clasificación Documental', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Cuadro-de-Clasificacion-Documental.pdf' },
  { n: 'Banco Terminológico de Series y Subseries', u: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/06/Banco-Terminologico-de-Series-y-Subseries-Documentales.pdf' },
];
---
<Base title="Tablas de Retención Documental" description="Tablas de retención documental de la Agencia ITRC">
  <HeroPage title="Tablas de Retención Documental" subtitle="Instrumentos de gestión de la información" icon="fa-table-list" breadcrumb={breadcrumb} />
  <section class="trd-section"><div class="container">
    {[{ titulo: 'Versión 2 (Vigente)', docs: v2 }, { titulo: 'Versión 1', docs: v1 }].map((sec) => (
      <div class="trd-group">
        <h2 class="trd-title"><i class="fa-solid fa-folder-open" aria-hidden="true"></i> {sec.titulo}<span class="trd-count">{sec.docs.length}</span></h2>
        <div class="trd-list">{sec.docs.map((d) => (<a href={d.u} target="_blank" rel="noopener" class={`trd-item trd--${fc(d.u)}`}><i class={`fa-solid ${fileIcon(d.u)}`} aria-hidden="true"></i><span>{d.n}</span><i class="fa-solid fa-download" aria-hidden="true"></i></a>))}</div>
      </div>
    ))}
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.trd-section{padding:var(--space-8) var(--space-6) var(--space-16);background:var(--theme-surface)}.trd-section .container{max-width:850px;margin:0 auto}.trd-group{margin-bottom:var(--space-8)}.trd-title{display:flex;align-items:center;gap:var(--space-3);font-size:var(--font-size-lg);color:var(--theme-heading);margin:0 0 var(--space-4);padding-bottom:var(--space-3);border-bottom:2px solid var(--itrc-gold)}.trd-title i{color:var(--itrc-gold)}.trd-count{padding:2px 10px;background:var(--theme-surface-alt);border-radius:var(--radius-full);font-size:var(--font-size-xs);color:var(--theme-text-muted)}.trd-list{display:flex;flex-direction:column;gap:var(--space-2)}.trd-item{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-3) var(--space-4);border:1px solid var(--theme-border-light);border-radius:var(--radius-lg);text-decoration:none;transition:all var(--transition-fast)}.trd-item:hover{box-shadow:var(--shadow-sm);transform:translateX(3px)}.trd--pdf>i:first-child{color:var(--file-pdf)}.trd--pdf:hover{border-color:rgba(220,53,69,0.3)}.trd--excel>i:first-child{color:var(--file-excel)}.trd--excel:hover{border-color:rgba(25,135,84,0.3)}.trd-item span{flex:1;font-size:var(--font-size-sm);font-weight:600;color:var(--theme-heading)}.trd-item:hover span{color:var(--itrc-gold)}.trd-item>i:last-child{color:var(--theme-text-muted);opacity:0.4;font-size:var(--font-size-xs)}.back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
