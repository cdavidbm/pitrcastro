---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import pageData from '../content/pages/transparencia/tablas-retencion.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: pageData.title }];
function fileIcon(u: string) { return u.endsWith('.xlsx') ? 'fa-file-excel' : 'fa-file-pdf'; }
function fc(u: string) { return u.endsWith('.xlsx') ? 'excel' : 'pdf'; }
---
<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle="Instrumentos de gestión de la información" icon={pageData.icon} breadcrumb={breadcrumb} />
  <section class="trd-section"><div class="container">
    {pageData.versiones.map((sec) => (
      <div class="trd-group">
        <h2 class="trd-title"><i class="fa-solid fa-folder-open" aria-hidden="true"></i> {sec.titulo}<span class="trd-count">{sec.docs.length}</span></h2>
        <div class="trd-list">{sec.docs.map((d) => (<a href={d.u} target="_blank" rel="noopener" class={`trd-item trd--${fc(d.u)}`}><i class={`fa-solid ${fileIcon(d.u)}`} aria-hidden="true"></i><span>{d.n}</span><i class="fa-solid fa-download" aria-hidden="true"></i></a>))}</div>
      </div>
    ))}
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.trd-section{padding:var(--space-8) var(--space-6) var(--space-16);background:var(--theme-surface)}.trd-section .container{max-width:850px;margin:0 auto}.trd-group{margin-bottom:var(--space-8)}.trd-title{display:flex;align-items:center;gap:var(--space-3);font-size:var(--font-size-lg);color:var(--theme-heading);margin:0 0 var(--space-4);padding-bottom:var(--space-3);border-bottom:2px solid var(--itrc-gold)}.trd-title i{color:var(--itrc-gold)}.trd-count{padding:2px 10px;background:var(--theme-surface-alt);border-radius:var(--radius-full);font-size:var(--font-size-xs);color:var(--theme-text-muted)}.trd-list{display:flex;flex-direction:column;gap:var(--space-2)}.trd-item{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-3) var(--space-4);border:1px solid var(--theme-border-light);border-radius:var(--radius-lg);text-decoration:none;transition:all var(--transition-fast)}.trd-item:hover{box-shadow:var(--shadow-sm);transform:translateX(3px)}.trd--pdf>i:first-child{color:var(--file-pdf)}.trd--pdf:hover{border-color:rgba(220,53,69,0.3)}.trd--excel>i:first-child{color:var(--file-excel)}.trd--excel:hover{border-color:rgba(25,135,84,0.3)}.trd-item span{flex:1;font-size:var(--font-size-sm);font-weight:600;color:var(--theme-heading)}.trd-item:hover span{color:var(--itrc-gold)}.trd-item>i:last-child{color:var(--theme-text-muted);opacity:0.4;font-size:var(--font-size-xs)}.back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
