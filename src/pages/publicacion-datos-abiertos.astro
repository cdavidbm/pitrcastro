---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Datos Abiertos' }];
---
<Base title="Publicación de Datos Abiertos" description="Datos abiertos de la Agencia ITRC">
  <HeroPage title="Datos Abiertos" subtitle="Datos abiertos de la Agencia ITRC" icon="fa-database" breadcrumb={breadcrumb} />
  <section class="datos-page"><div class="container">
    <p class="datos-intro">Conozca los datos abiertos que la Agencia ITRC pone a disposición de todos los ciudadanos para que puedan acceder de forma libre y abierta.</p>
    <a href="https://www.datos.gov.co/browse?q=itrc" target="_blank" rel="noopener" class="datos-cta"><i class="fa-solid fa-database" aria-hidden="true"></i> Ir a Datos Abiertos — datos.gov.co <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></a>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.datos-page{padding:var(--space-12) var(--space-6) var(--space-16);background:var(--theme-surface)}.datos-page .container{max-width:700px;margin:0 auto;text-align:center}.datos-intro{font-size:var(--font-size-lg);line-height:1.8;color:var(--theme-text);margin-bottom:var(--space-8)}.datos-cta{display:inline-flex;align-items:center;gap:var(--space-3);padding:var(--space-5) var(--space-8);background:var(--itrc-navy);color:var(--white);border-radius:var(--radius-full);text-decoration:none;font-weight:700;font-size:var(--font-size-base);transition:all var(--transition-base)}.datos-cta:hover{background:var(--itrc-gold);transform:translateY(-2px);box-shadow:var(--shadow-md)}.back-link{margin-top:var(--space-8)}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
