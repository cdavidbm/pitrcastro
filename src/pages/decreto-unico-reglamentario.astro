---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import pageData from '../content/pages/transparencia/decreto-unico.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle="Sector Hacienda y Crédito Público" icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="decreto-page">
    <div class="container">
      {pageData.documentos.map((d) => (
        <a href={d.url} target="_blank" rel="noopener" class={`doc-card doc-card--${d.tipo === 'external' ? 'ext' : 'pdf'}`}>
          <i class={`fa-solid ${d.tipo === 'external' ? 'fa-arrow-up-right-from-square' : 'fa-file-pdf'}`} aria-hidden="true"></i>
          <span>{d.nombre}</span>
          <i class={`fa-solid ${d.tipo === 'external' ? 'fa-arrow-up-right-from-square' : 'fa-download'}`} aria-hidden="true"></i>
        </a>
      ))}

      <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
    </div>
  </section>
</Base>

<style>
  .decreto-page { padding: var(--space-12) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .decreto-page .container { max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-4); align-items: center; }
  .doc-card { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-5) var(--space-8); border: 2px solid; border-radius: var(--radius-full); text-decoration: none; font-weight: 700; font-size: var(--font-size-base); transition: all var(--transition-base); width: 100%; max-width: 600px; justify-content: center; }
  .doc-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); color: var(--white); }
  .doc-card--pdf { border-color: var(--file-pdf); color: var(--file-pdf); }
  .doc-card--pdf:hover { background: var(--file-pdf); }
  .doc-card--ext { border-color: var(--itrc-navy); color: var(--itrc-navy); }
  .doc-card--ext:hover { background: var(--itrc-navy); }
  .doc-card span { flex: 1; text-align: center; }
  .doc-card > i:last-child { opacity: 0.5; font-size: var(--font-size-sm); }
  .back-link { margin-top: var(--space-6); }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .doc-card { font-size: var(--font-size-sm); padding: var(--space-4) var(--space-5); } }
</style>
