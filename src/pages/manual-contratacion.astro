---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: 'Manual de Contratación' }
];

const documentos = [
  { nombre: 'Manual de Contratación', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/12/Manual_de_Contratacion.pdf', tipo: 'pdf' },
  { nombre: 'Manual de supervisión e interventoría', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/12/Manual-de-Supervision-e-Interventoria.pdf', tipo: 'pdf' },
  { nombre: 'Resolución No. 418 — Delegación de funciones', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/05/No.418-Por-medio-de-la-cual-se-delegan-unas-funciones-y-se-dictan-otras-disposiciones.pdf', tipo: 'pdf' },
  { nombre: 'Preguntas Frecuentes — Declaración de Bienes y Rentas (Ley 2013 de 2019)', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2021/11/2021-03-25_Preguntas_frecuentes_aplicativo_ley_2013_de_2019.pdf', tipo: 'pdf' },
  { nombre: 'Instructivo elaboración estudios previos', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/Instructivo-elaboracion-Estudios-Previos-codigo-GCO-OD-004-version-12.pdf', tipo: 'pdf' },
  { nombre: 'Resolución No. 073 de 2022 — Creación del Comité Asesor de Contratación', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/08/No.073-Por-la-cual-se-crea-el-Comite-Asesor-de-Contratacion-y-se-dictan-otras-disposiciones.pdf', tipo: 'pdf' },
  { nombre: 'Resolución No. 313 de 2023 — Modificación del Comité Asesor de Contratación', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/08/No.313-Por-la-cual-se-modifica-la-integracion-del-comite-Asesor-de-contratacion-creado-con-Resolucion-073-de-28-de-febrero-de-2022.pdf', tipo: 'pdf' },
  { nombre: 'Guía para elaborar estudios de sector (CCE)', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/08/GUIA-PARA-ELABORAR-ESTUDIOS-DE-SECTOR-CCE.pdf', tipo: 'pdf' },
];
---

<Base title="Manual de Contratación" description="Procedimientos, lineamientos y políticas en materia de adquisición y compras de la Agencia ITRC">
  <HeroPage title="Manual de Contratación" subtitle="Procedimientos, lineamientos y políticas en materia de adquisición y compras" icon="fa-file-contract" breadcrumb={breadcrumb} />

  <section class="docs-section">
    <div class="container">
      <div class="docs-list">
        {documentos.map((doc) => (
          <a href={doc.url} target="_blank" rel="noopener" class="doc-item">
            <div class="doc-item__icon"><i class="fa-solid fa-file-pdf" aria-hidden="true"></i></div>
            <span>{doc.nombre}</span>
            <i class="fa-solid fa-download" aria-hidden="true"></i>
          </a>
        ))}
      </div>
      <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
    </div>
  </section>
</Base>

<style>
  .docs-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .docs-section .container { max-width: 850px; margin: 0 auto; }
  .docs-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .doc-item { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .doc-item:hover { border-color: rgba(220,53,69,0.3); box-shadow: var(--shadow-md); transform: translateX(4px); }
  .doc-item__icon { width: 40px; height: 40px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: rgba(220,53,69,0.08); border-radius: var(--radius-md); color: var(--file-pdf); font-size: var(--font-size-lg); transition: all var(--transition-base); }
  .doc-item:hover .doc-item__icon { background: var(--file-pdf); color: var(--white); }
  .doc-item span { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .doc-item:hover span { color: var(--file-pdf); }
  .doc-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .doc-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .docs-section { padding: var(--space-6) var(--space-4) var(--space-12); } .doc-item span { font-size: var(--font-size-xs); } }
</style>
