---
import Base from '../layouts/Base.astro';
import NormativaTematica from '../components/NormativaTematica.astro';
import { getNormativaDelitoList } from '../utils/strapi-fetchers';

const SLUG = 'normatividad-alteracion-o-falsificacion-de-informacion';
const all = await getNormativaDelitoList();
const pageData = all.find((x: any) => x.slug === SLUG);
if (!pageData) throw new Error(`Strapi: no se encontro slug ${SLUG} en normativa-delito`);
---

<Base title={pageData.title} description={pageData.description} strapiSlug={`normativa-delito/${SLUG}`}>
  <NormativaTematica pageData={pageData} />
</Base>
