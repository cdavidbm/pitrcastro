---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';
import pageData from '../content/pages/transparencia/otros-grupos.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: pageData.title }];
---
<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />
  <section class="grupos-page"><div class="container">
    <div class="grupos-list">{pageData.enlaces.map((e) => (
      <a href={e.tipo === 'internal' ? resolveUrl(e.url) : e.url} target={e.tipo !== 'internal' ? '_blank' : undefined} rel={e.tipo !== 'internal' ? 'noopener' : undefined} class="grupo-link">
        <i class={`fa-solid ${e.icon}`} aria-hidden="true"></i><span>{e.nombre}</span>
        <i class={`fa-solid ${e.tipo === 'internal' ? 'fa-chevron-right' : e.tipo === 'pdf' ? 'fa-download' : 'fa-arrow-up-right-from-square'}`} aria-hidden="true"></i>
      </a>
    ))}</div>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.grupos-page{padding:var(--space-10) var(--space-6) var(--space-16);background:var(--theme-surface)}.grupos-page .container{max-width:800px;margin:0 auto}.grupos-list{display:flex;flex-direction:column;gap:var(--space-3)}.grupo-link{display:flex;align-items:center;gap:var(--space-4);padding:var(--space-4) var(--space-5);border:1px solid var(--theme-border);border-radius:var(--radius-lg);text-decoration:none;transition:all var(--transition-base)}.grupo-link:hover{border-color:var(--itrc-gold);box-shadow:var(--shadow-md);transform:translateX(4px)}.grupo-link>i:first-child{color:var(--itrc-gold);font-size:var(--font-size-lg)}.grupo-link span{flex:1;font-size:var(--font-size-sm);font-weight:700;color:var(--theme-heading)}.grupo-link:hover span{color:var(--itrc-gold)}.grupo-link>i:last-child{color:var(--theme-text-muted);opacity:0.4;font-size:var(--font-size-xs)}.back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
