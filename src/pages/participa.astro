---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';

import pageData from '../content/pages/participa.json';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: pageData.title }
];

const colorMap: Record<string, string> = {
  blue: '#0943b5',
  green: '#198754',
  gold: 'var(--itrc-gold)',
  purple: '#6f42c1',
  navy: 'var(--itrc-navy)',
  red: '#dc3545',
};
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage
    title={pageData.title}
    subtitle={pageData.description}
    icon={pageData.icon}
    breadcrumb={breadcrumb}
  />

  <section class="participa-section">
    <div class="container">
      <p class="participa-intro">{pageData.intro}</p>

      <h2 class="participa-subtitle">
        <i class="fa-solid fa-hand-point-right" aria-hidden="true"></i>
        El Menú Participa cuenta con 6 secciones:
      </h2>

      <div class="participa-grid">
        {pageData.secciones.map((sec) => {
          const accent = colorMap[sec.color] || 'var(--itrc-gold)';
          return (
            <a href={resolveUrl(sec.url)} class="participa-card" style={`--card-accent: ${accent}`}>
              <div class="participa-card__icon">
                <i class={`fa-solid ${sec.icon}`} aria-hidden="true"></i>
              </div>
              <h3 class="participa-card__title">{sec.titulo}</h3>
              <p class="participa-card__desc">{sec.descripcion}</p>
              <span class="participa-card__arrow">
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>

<style>
  .participa-section {
    padding: var(--space-10) var(--space-6) var(--space-16);
    background: var(--theme-surface);
  }

  .participa-section .container {
    max-width: 1050px;
    margin: 0 auto;
  }

  .participa-intro {
    font-size: var(--font-size-lg);
    line-height: 1.8;
    color: var(--theme-text);
    text-align: center;
    max-width: 900px;
    margin: 0 auto var(--space-8);
  }

  .participa-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    font-size: var(--font-size-lg);
    color: var(--theme-heading);
    margin: 0 0 var(--space-8);
    text-align: center;
  }

  .participa-subtitle i { color: var(--itrc-gold); }

  /* ====== Grid ====== */
  .participa-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  /* ====== Card ====== */
  .participa-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-top: 4px solid var(--card-accent);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-base);
    position: relative;
  }

  .participa-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--card-accent);
  }

  .participa-card__icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--card-accent);
    color: var(--white);
    border-radius: var(--radius-full);
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-5);
    transition: transform var(--transition-base);
  }

  .participa-card:hover .participa-card__icon { transform: scale(1.1); }

  .participa-card__title {
    font-size: var(--font-size-base);
    font-weight: 800;
    color: var(--theme-heading);
    margin: 0 0 var(--space-3);
    transition: color var(--transition-fast);
  }

  .participa-card:hover .participa-card__title { color: var(--card-accent); }

  .participa-card__desc {
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--theme-text-secondary);
    margin: 0;
    flex: 1;
  }

  .participa-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    margin-top: var(--space-5);
    border-radius: var(--radius-full);
    background: rgba(0,0,0,0.04);
    color: var(--theme-text-muted);
    font-size: var(--font-size-sm);
    transition: all var(--transition-fast);
  }

  .participa-card:hover .participa-card__arrow {
    background: var(--card-accent);
    color: var(--white);
  }

  @media (max-width: 900px) {
    .participa-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .participa-section { padding: var(--space-6) var(--space-4) var(--space-12); }
    .participa-intro { font-size: var(--font-size-base); }
    .participa-grid { grid-template-columns: 1fr; gap: var(--space-3); }

    .participa-card {
      flex-direction: row;
      text-align: left;
      padding: var(--space-5);
      gap: var(--space-4);
      border-top: none;
      border-left: 4px solid var(--card-accent);
    }

    .participa-card__icon {
      width: 48px;
      height: 48px;
      font-size: var(--font-size-xl);
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .participa-card__arrow { display: none; }
  }
</style>
