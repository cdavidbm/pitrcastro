---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Comité de Conciliación' }];

const anios = [
  { anio: '2025', docs: [
    { nombre: 'Informe de Gestión — Primer Semestre 2025', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2025/07/Informe-de-Gestion-Comite-de-Conciliacion-Primer-Semestre-2025-.pdf' },
    { nombre: 'Informe de Gestión — Segundo Semestre 2025', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2026/01/Informe-de-Gestion-Comite-de-Conciliacion-Segundo-Semestre-2025.pdf' },
  ]},
  { anio: '2024', docs: [
    { nombre: 'Informe de Gestión — Primer Semestre 2024', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/Informe-de-Gestio%CC%81n-Comite%CC%81-de-Conciliacio%CC%81n-Primer-Semestre-2024.pdf' },
    { nombre: 'Informe de Gestión — Segundo Semestre 2024', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2025/01/Informe-de-Gestion-Comite-de-Conciliacion-segundo-semestre-2024.pdf' },
  ]},
  { anio: '2023', docs: [
    { nombre: 'Informe de Gestión — Primer Semestre 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/08/Informe-de-Gesti%C3%B3n-Comit%C3%A9-de-Conciliaci%C3%B3n-Primer-Semestre-2023.pdf' },
    { nombre: 'Informe de Gestión — Segundo Semestre 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/01/Informe-de-Gesti%C3%B3n-Comit%C3%A9-de-Conciliaci%C3%B3n-Segundo-Semestre-2023.pdf' },
  ]},
];
---

<Base title="Informe de Gestión del Comité de Conciliación" description="Informes del Comité de Conciliación y Defensa Jurídica de la Agencia ITRC">
  <HeroPage title="Comité de Conciliación" subtitle="Informes de gestión del Comité de Conciliación y Defensa Jurídica" icon="fa-handshake" breadcrumb={breadcrumb} />
  <section class="comite-section"><div class="container">
    <p class="comite-intro">La Secretaría Técnica del Comité de Conciliación de la Agencia ITRC presenta el informe de gestión en cumplimiento a lo dispuesto en el artículo 127 de la Ley 2220 de 2022 (Estatuto de Conciliación).</p>

    {anios.map((g) => (
      <div class="year-group">
        <h2 class="year-title"><i class="fa-solid fa-calendar" aria-hidden="true"></i> {g.anio}</h2>
        <div class="doc-list">
          {g.docs.map((d) => (
            <a href={d.url} target="_blank" rel="noopener" class="doc-item">
              <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
              <span>{d.nombre}</span>
              <i class="fa-solid fa-download" aria-hidden="true"></i>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>

<style>
  .comite-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .comite-section .container { max-width: 800px; margin: 0 auto; }
  .comite-intro { font-size: var(--font-size-base); line-height: 1.8; color: var(--theme-text); margin-bottom: var(--space-8); }
  .year-group { margin-bottom: var(--space-6); }
  .year-title { display: flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-lg); color: var(--theme-heading); margin: 0 0 var(--space-3); padding-bottom: var(--space-2); border-bottom: 2px solid var(--theme-border-light); }
  .year-title i { color: var(--itrc-gold); }
  .doc-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .doc-item { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .doc-item:hover { border-color: rgba(220,53,69,0.3); box-shadow: var(--shadow-md); transform: translateX(4px); }
  .doc-item > i:first-child { color: var(--file-pdf); font-size: var(--font-size-lg); }
  .doc-item span { flex: 1; font-size: var(--font-size-sm); font-weight: 700; color: var(--theme-heading); }
  .doc-item:hover span { color: var(--file-pdf); }
  .doc-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .doc-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .comite-section { padding: var(--space-6) var(--space-4) var(--space-12); } }
</style>
