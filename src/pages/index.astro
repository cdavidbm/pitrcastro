---
/**
 * Pagina de inicio del sitio ITRC
 */
import Base from '../layouts/Base.astro';
import HeroSlider from '../components/HeroSlider.astro';
import QuickAccess from '../components/QuickAccess.astro';
import NewsSection from '../components/NewsSection.astro';
import EventsSection from '../components/EventsSection.astro';
import contactLocal from '../content/settings/contact.json';
import siteLocal from '../content/settings/site.json';
import { getHome, getSite, getContact } from '../utils/strapi-fetchers';

const homeData = await getHome();

// Strapi primary para site + contact, fallback JSON local
const siteRemote: any = await getSite().catch(() => null);
const contactRemote: any = await getContact().catch(() => null);
const siteData: any = (siteRemote && siteRemote.name) ? siteRemote : siteLocal;
const contactData: any = (contactRemote && contactRemote.address) ? contactRemote : contactLocal;
const base = import.meta.env.BASE_URL;
---

<Base title="Inicio" class="page-home" strapiSlug="home">
  <!-- Modal de bienvenida — CIPREP 2026 -->
  <div
    class="welcome-modal"
    role="dialog"
    aria-modal="true"
    aria-label="II Congreso Internacional para la Protección de los Recursos Públicos - ITRC"
    aria-describedby="welcome-modal-desc"
    data-welcome-modal
    hidden
  >
    <div class="welcome-modal__backdrop" data-welcome-close></div>
    <div class="welcome-modal__panel">
      <button
        type="button"
        class="welcome-modal__close"
        aria-label="Cerrar"
        data-welcome-close
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <a
        href={`${base}ciprep2026`}
        class="welcome-modal__cta-link"
        aria-label="II Congreso Internacional para la Protección de los Recursos Públicos - ITRC. 3 y 4 de agosto, Bogotá. Inscripción gratuita."
      >
        <div class="welcome-modal__body">
          <img
            src={`${base}images/ciprep2026/logo-ii-congreso.png`}
            alt="II Congreso Internacional para la Protección de los Recursos Públicos - ITRC"
            class="welcome-modal__logo"
            width="440"
            height="197"
            loading="eager"
            decoding="async"
          />
          <span class="welcome-modal__eyebrow">3 y 4 de agosto · Bogotá</span>
          <p id="welcome-modal-desc" class="welcome-modal__text">
            Inscripción gratuita. Conoce los ejes temáticos, ponentes confirmados y agenda completa.
          </p>
          <span class="welcome-modal__btn">
            Ir al Congreso <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
          </span>
        </div>
      </a>
    </div>
  </div>

  <script is:inline>
    (function() {
      var KEY = 'itrc-welcome-ciprep2026-dismissed';
      // No mostrar si ya lo cerró antes
      if (localStorage.getItem(KEY) === '1') return;
      var modal = document.querySelector('[data-welcome-modal]');
      if (!modal) return;
      function show() {
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        var close = modal.querySelector('[data-welcome-close]');
        if (close) close.focus();
      }
      function hide() {
        modal.hidden = true;
        document.body.style.overflow = '';
        localStorage.setItem(KEY, '1');
      }
      // Pequeño delay para que no salte instantáneamente al cargar
      setTimeout(show, 600);
      modal.querySelectorAll('[data-welcome-close]').forEach(function(el) {
        el.addEventListener('click', hide);
      });
      // Si hace click en el CTA (link), también marcamos como visto
      var ctaLink = modal.querySelector('.welcome-modal__cta-link');
      if (ctaLink) ctaLink.addEventListener('click', function() { localStorage.setItem(KEY, '1'); });
      // Tecla Esc cierra
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && !modal.hidden) hide();
      });
    })();
  </script>

  <style>
    .welcome-modal { position: fixed; inset: 0; z-index: 9000; display: flex; align-items: center; justify-content: center; padding: var(--space-4); }
    .welcome-modal[hidden] { display: none; }
    .welcome-modal__backdrop { position: absolute; inset: 0; background: rgba(0, 33, 71, 0.72); backdrop-filter: blur(3px); animation: fadeIn .25s ease-out; }
    .welcome-modal__panel { position: relative; max-width: 520px; width: 100%; background: var(--white, #fff); border-radius: var(--radius-xl); overflow: hidden; box-shadow: 0 25px 60px rgba(0,0,0,.35); animation: scaleUp .3s cubic-bezier(.16,1,.3,1); }
    .welcome-modal__close { position: absolute; top: 12px; right: 12px; z-index: 2; width: 38px; height: 38px; border: none; border-radius: 50%; background: rgba(255,255,255,.92); color: var(--itrc-navy, #002147); font-size: 1.1rem; cursor: pointer; box-shadow: 0 4px 12px rgba(0,0,0,.18); display: flex; align-items: center; justify-content: center; }
    .welcome-modal__close:hover { background: var(--itrc-gold, #b38b40); color: #fff; }
    .welcome-modal__cta-link { display: block; text-decoration: none; color: inherit; }
    .welcome-modal__body { padding: var(--space-7, 1.75rem) var(--space-6) var(--space-6); text-align: center; }
    .welcome-modal__logo { display: block; width: clamp(260px, 90%, 440px); height: auto; margin: 0 auto var(--space-5); padding-bottom: var(--space-5); border-bottom: 1px solid var(--theme-border, #e5e7eb); }
    .welcome-modal__eyebrow { display: inline-block; font-size: var(--font-size-xs); font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--itrc-gold, #b38b40); margin-bottom: var(--space-2); }
    .welcome-modal__title { font-size: var(--font-size-xl); color: var(--itrc-navy, #002147); margin: 0 0 var(--space-3); line-height: 1.25; }
    .welcome-modal__text { font-size: var(--font-size-sm); color: var(--theme-text-secondary, #555); margin: 0 0 var(--space-4); }
    .welcome-modal__btn { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-6); background: var(--itrc-navy, #002147); color: var(--white, #fff); border-radius: var(--radius-full, 999px); font-weight: 700; font-size: var(--font-size-sm); transition: background .2s; }
    .welcome-modal__cta-link:hover .welcome-modal__btn { background: var(--itrc-gold, #b38b40); }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes scaleUp { from { transform: scale(.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  </style>

  <HeroSlider slider="home" />
  <QuickAccess />
  <NewsSection limit={3} />
  <EventsSection limit={3} />

  <!-- Video -->
  <section class="video-section" aria-labelledby="video-title">
    <div class="container">
      <h2 id="video-title" class="section-title-decorated">Conoce la Agencia ITRC</h2>
      <div class="video-wrapper">
        <iframe
          src={siteData.featuredVideo.url}
          title={siteData.featuredVideo.title}
          frameborder="0"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div class="ver-mas">
        <a href={`${base}videos-itrc`} class="btn btn--outline">Ver todos los videos</a>
      </div>
    </div>
  </section>

  <!-- Entidades vigiladas -->
  <section class="entidades-section" aria-labelledby="entidades-title">
    <div class="container">
      <h2 id="entidades-title" class="section-title-decorated">Entidades vigiladas por la ITRC</h2>
      <div class="entidades-grid">
        {homeData.entidadesVigiladas.map((entidad) => (
          <a href={entidad.url} class="entidad" target="_blank" rel="noopener noreferrer">
            <img src={`${base}images/entidades/${entidad.logo}`} alt={entidad.alt} loading="lazy">
            <span class="entidad__nombre">{entidad.nombre}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section class="servicios-section" aria-labelledby="servicios-title">
    <div class="container">
      <h2 id="servicios-title" class="section-title-decorated section-title-decorated--full">Servicios a la Ciudadanía</h2>
      <div class="servicios-grid">
        {homeData.columnasServicios.map((columna) => (
          <div class="servicios-columna">
            <ul class="servicios-lista">
              {columna.items.map((item) => (
                item.tipo === 'external' ? (
                  <li><a href={item.url} target="_blank" rel="noopener noreferrer">{item.texto} <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></a></li>
                ) : (
                  <li><a href={`${base}${item.url}`}>{item.texto}</a></li>
                )
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section class="contact-section" aria-labelledby="contact-title">
    <div class="container">
      <h2 id="contact-title" class="section-title-decorated">Canales de Atención</h2>
      <p class="contact-section__intro">Estamos para servirle. Encuentre la mejor forma de comunicarse con nosotros.</p>

      <div class="contact-section__cards">
        <div class="contact-card">
          <div class="contact-card__icon">
            <i class="fa-solid fa-phone" aria-hidden="true"></i>
          </div>
          <h3>Teléfonos</h3>
          <p>{contactData.phone}</p>
          <p class="contact-card__sub">Línea gratuita: {contactData.tollFree}</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon">
            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          </div>
          <h3>Correo</h3>
          <p>{contactData.email}</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon">
            <i class="fa-solid fa-clock" aria-hidden="true"></i>
          </div>
          <h3>Horario</h3>
          <p>Lunes a Viernes</p>
          <p class="contact-card__sub">8:00 am - 4:30 pm</p>
        </div>

        <div class="contact-card">
          <div class="contact-card__icon">
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
          </div>
          <h3>Dirección</h3>
          <p>{contactData.address}</p>
          <p class="contact-card__sub">{contactData.city}</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Video Section */
  .video-section {
    background: var(--theme-surface);
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .video-section h2 {
    margin-bottom: var(--space-8);
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto var(--space-8);
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ver-mas {
    margin-top: var(--space-6);
  }

  /* Entidades Section */
  .entidades-section {
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .entidades-section h2 {
    margin-bottom: var(--space-10);
  }

  .entidades-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .entidad {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--theme-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    text-decoration: none;
    min-width: 180px;
  }

  .entidad:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .entidad img {
    height: 80px;
    width: auto;
    max-width: 150px;
    object-fit: contain;
  }

  .entidad__nombre {
    font-weight: 600;
    color: var(--theme-heading);
    font-size: var(--font-size-sm);
  }

  /* Servicios Section */
  .servicios-section {
    background: var(--theme-dark-section-bg);
    padding: var(--space-16) var(--space-6);
    color: var(--theme-dark-section-heading);
  }

  .servicios-section h2 {
    color: var(--itrc-gold);
    margin-bottom: var(--space-10);
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .servicios-lista {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .servicios-lista li {
    margin-bottom: var(--space-3);
  }

  .servicios-lista a {
    color: var(--theme-dark-section-text);
    font-size: var(--font-size-sm);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: color var(--transition-fast);
  }

  .servicios-lista a:hover {
    color: var(--itrc-gold);
  }

  .servicios-lista a i {
    font-size: 0.7rem;
    opacity: 0.7;
  }

  /* Contact Section */
  .contact-section {
    background: var(--theme-surface);
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .contact-section h2 {
    margin-bottom: var(--space-4);
  }

  .contact-section__intro {
    color: var(--theme-text-secondary);
    margin-bottom: var(--space-10);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .contact-section__cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .contact-card {
    background: var(--theme-surface);
    padding: var(--space-8) var(--space-6);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .contact-card__icon {
    width: 60px;
    height: 60px;
    margin: 0 auto var(--space-5);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--itrc-gold-light), var(--itrc-gold));
    border-radius: var(--radius-full);
    color: var(--itrc-navy);
    font-size: var(--font-size-2xl);
  }

  .contact-card h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-2);
  }

  .contact-card p {
    margin: 0;
    color: var(--theme-text);
  }

  .contact-card__sub {
    font-size: var(--font-size-sm);
    color: var(--theme-text-muted);
    margin-top: var(--space-1);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .servicios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .video-section,
    .entidades-section,
    .servicios-section,
    .contact-section {
      padding: var(--space-12) var(--space-4);
    }

    .servicios-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .entidades-grid {
      gap: var(--space-6);
    }

    .entidad {
      min-width: 140px;
      padding: var(--space-4);
    }

    .contact-section__cards {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }

    .contact-card {
      padding: var(--space-6) var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .contact-section__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
