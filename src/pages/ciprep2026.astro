---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { resolveUrl } from '../utils/url';

// Página informativa de CIPREP 2026 con datos confirmados al momento.
// La inscripción se delega a un formulario de Microsoft Forms gestionado
// por otra área. Agenda, ponentes y aliados se completarán cuando el
// equipo organizador entregue la información definitiva; mientras tanto
// se muestran datos provisionales claramente marcados como tales.

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Congresos', href: resolveUrl('/ciprep2026') },
  { label: 'CIPREP 2026' },
];

const INSCRIPCION_URL =
  'https://forms.office.com/pages/responsepage.aspx?id=3NElp2Q-g0KVXt1OUTYI5lXhhwicK9BAtrKaNXbBEVlUOVBQQjc2QzlVNFZQSDVGNktFN01DQVkzRC4u&route=shorturl';

const MAPS_URL =
  'https://www.google.com/maps/search/?api=1&query=Carrera+7+%23+6b-80+Bogot%C3%A1+Ministerio+de+Hacienda';

const sections = [
  { id: 'acerca', label: 'Acerca del Congreso' },
  { id: 'agenda', label: 'Agenda' },
  { id: 'aliados', label: 'Aliados' },
  { id: 'info', label: 'Información' },
  { id: 'inscripcion', label: 'Inscripción' },
];

// Pre-agenda v3 entregada por el comité organizador (junio 2026).
// Horarios y ponencias pueden tener ajustes hasta la versión oficial.
const agenda = [
  {
    dia: 'Día 1 — lunes 3 de agosto de 2026',
    franjas: [
      { hora: '8:00', tipo: 'apertura', titulo: 'Apertura institucional', detalle: 'Palabras de la Dra. Eva Carolina Madrid Torres, Directora General ITRC', franja: 'APERTURA' },
      { hora: '8:15', ponente: 'Paula Andrea Ramírez Barbosa', entidad: 'CIDCE', pais: 'Colombia', bandera: '🇨🇴', foto: '/images/ciprep2026/ponentes/paula-andrea-ramirez-barbosa.jpg', titulo: 'Aporte de la IA en la estrategia para la detección y prueba de la corrupción', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '8:45', ponente: 'Gabriel Andrés Álzate Acuña', entidad: 'DATOSCOL', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '9:15', ponente: 'Francia Inés Hernández', entidad: 'Asociación de Mujeres Aduaneras', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '9:45', ponente: 'Silvina Coronelo', entidad: 'Estudio Coronello & Asoc. / UBA', pais: 'Argentina', bandera: '🇦🇷', titulo: 'Ponencia por confirmar', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '10:15', tipo: 'pausa', titulo: '☕ Coffee break', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '10:30', ponente: 'Ángela Cortés Hernández', entidad: 'MinTIC — COLCERT', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '11:00', ponente: 'María Anayme Barón Durán', entidad: 'Auditoría General de la Nación', pais: 'Colombia', bandera: '🇨🇴', foto: '/images/ciprep2026/ponentes/maria-anayme-baron-duran.jpg', titulo: 'Ponencia por confirmar', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '11:30', tipo: 'pausa', titulo: '🍽 Almuerzo', franja: 'EJE I — IA, ANALÍTICA DE DATOS Y HERRAMIENTAS TECNOLÓGICAS' },
      { hora: '13:00', ponente: 'Susan Rose-Ackerman', entidad: 'Universidad de Yale', pais: 'Estados Unidos', bandera: '🇺🇸', foto: '/images/ciprep2026/ponentes/susan-rose-ackerman.jpg', titulo: 'Riesgos de corrupción en administración tributaria y de seguridad social', franja: 'EJE II — RIESGOS DE CORRUPCIÓN EN LA ADMINISTRACIÓN TRIBUTARIA Y PARAFISCAL' },
      { hora: '13:45', ponente: 'Tte. Cnel. Gonzalo Andrés Córdoba Camacho', entidad: 'Interpol Colombia', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Cooperación internacional para combatir el crimen transnacional y capacidades de INTERPOL', franja: 'EJE II — RIESGOS DE CORRUPCIÓN EN LA ADMINISTRACIÓN TRIBUTARIA Y PARAFISCAL' },
      { hora: '14:15', ponente: 'Nicolás Soto Troncoso', entidad: 'Anticorruption Risk', pais: 'Chile', bandera: '🇨🇱', titulo: 'Ponencia por confirmar', franja: 'EJE II — RIESGOS DE CORRUPCIÓN EN LA ADMINISTRACIÓN TRIBUTARIA Y PARAFISCAL' },
      { hora: '15:00', tipo: 'cierre', titulo: 'Cierre Día 1', franja: 'EJE II — RIESGOS DE CORRUPCIÓN EN LA ADMINISTRACIÓN TRIBUTARIA Y PARAFISCAL' },
    ],
  },
  {
    dia: 'Día 2 — martes 4 de agosto de 2026',
    franjas: [
      { hora: '8:00', ponente: 'Ruth Marisol Apraez Benabidez', entidad: 'Procuraduría General de la Nación', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '8:30', ponente: 'Julio Roberto Piza', entidad: 'Universidad Externado de Colombia', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '9:00', ponente: 'Ruth Owen', entidad: 'Defensora del Contribuyente (Australia y Reino Unido)', pais: 'Australia', bandera: '🇦🇺', foto: '/images/ciprep2026/ponentes/ruth-owen.jpg', titulo: 'Ponencia por confirmar', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '9:45', ponente: 'José Andrés Romero Tarazona', entidad: 'Instituto Colombiano de Derecho Tributario (ICDT)', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '10:15', ponente: 'Ponente por confirmar', entidad: 'Kroll', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '10:45', tipo: 'pausa', titulo: '☕ Coffee break', franja: 'EJE III — RECUPERACIÓN DE ACTIVOS Y ESTRATEGIAS JURÍDICAS CONTRA EL FRAUDE AL ESTADO' },
      { hora: '11:00', ponente: 'Pascal Saint-Amans', entidad: 'SAGA', pais: 'Francia', bandera: '🇫🇷', foto: '/images/ciprep2026/ponentes/pascal-saint-amans.png', titulo: 'Public CBCR: ¿qué implicaciones para la región de LAC?', franja: 'EJE IV — TRANSPARENCIA, ÉTICA PÚBLICA Y CULTURA DE INTEGRIDAD' },
      { hora: '11:45', ponente: 'Camilo Rey', entidad: 'Ministerio de Hacienda y Crédito Público', pais: 'Colombia', bandera: '🇨🇴', titulo: 'Ponencia por confirmar', franja: 'EJE IV — TRANSPARENCIA, ÉTICA PÚBLICA Y CULTURA DE INTEGRIDAD' },
      { hora: '12:15', ponente: 'Miguel Ángel Espinoza', entidad: 'FITAC', pais: 'Colombia', bandera: '🇨🇴', foto: '/images/ciprep2026/ponentes/miguel-angel-espinosa.jpg', titulo: 'Ponencia por confirmar', franja: 'EJE IV — TRANSPARENCIA, ÉTICA PÚBLICA Y CULTURA DE INTEGRIDAD' },
      { hora: '12:30', tipo: 'pausa', titulo: '🍽 Almuerzo', franja: 'EJE IV — TRANSPARENCIA, ÉTICA PÚBLICA Y CULTURA DE INTEGRIDAD' },
      { hora: '13:30', tipo: 'cierre', titulo: 'Clausura y cierre del congreso', franja: 'EJE IV — TRANSPARENCIA, ÉTICA PÚBLICA Y CULTURA DE INTEGRIDAD' },
    ],
  },
];

const aliados = [
  { nombre: 'Ministerio de Hacienda y Crédito Público', tipo: 'Aliado estratégico', logo: '/images/ciprep2026/aliados/minhacienda.png' },
  { nombre: 'FITAC — Federación Colombiana de Agentes Logísticos en Comercio Internacional', tipo: 'Aliado estratégico', logo: '/images/ciprep2026/aliados/fitac.jpg' },
];

const entidadesExpositoras = [
  { nombre: 'CIDCE', logo: '/images/ciprep2026/entidades/cidce.svg' },
  { nombre: 'DATOSCOL', logo: '/images/ciprep2026/entidades/datoscol.png' },
  { nombre: 'MinTIC', logo: '/images/ciprep2026/entidades/mintic.jpg' },
  { nombre: 'Universidad de Buenos Aires', logo: '/images/ciprep2026/entidades/uba.jpg' },
  { nombre: 'Universidad de Yale', logo: '/images/ciprep2026/entidades/yale.webp' },
  { nombre: 'ICDT — Instituto Colombiano de Derecho Tributario', logo: '/images/ciprep2026/entidades/icdt.png' },
  { nombre: 'IGTO — International Government Tax Office', logo: '/images/ciprep2026/entidades/igto.png' },
  { nombre: 'SAGA', logo: '/images/ciprep2026/entidades/saga.png' },
];
---

<Base
  title="II Congreso Internacional para la Protección de los Recursos Públicos — CIPREP 2026"
  description="Segunda edición del Congreso Internacional CIPREP. 3 y 4 de agosto de 2026 en Bogotá. Evento gratuito, híbrido y bilingüe organizado por la Agencia ITRC."
>
  <!-- ======================== Hero Banner ======================== -->
  <section class="banner-hero" aria-labelledby="ciprep-2026-title">
    <div class="container banner-hero__breadcrumb">
      <nav aria-label="Migas de pan">
        <ol>
          {breadcrumb.map((b, i) => (
            <li>
              {b.href
                ? <a href={b.href}>{b.label}</a>
                : <span aria-current="page">{b.label}</span>}
              {i < breadcrumb.length - 1 && <span aria-hidden="true">/</span>}
            </li>
          ))}
        </ol>
      </nav>
    </div>
    <picture class="banner-hero__img-wrap">
      <img
        src={resolveUrl('/images/sliders/slider-ciprep-2026.jpg')}
        alt="II Congreso Internacional para la Protección de los Recursos Públicos — 3 y 4 de agosto de 2026 en Bogotá. Un país más transparente se construye con conocimiento y acción."
        class="banner-hero__img"
        width="3801"
        height="1201"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    <h1 id="ciprep-2026-title" class="visually-hidden">
      II Congreso Internacional para la Protección de los Recursos Públicos — CIPREP 2026
    </h1>
    <div class="container banner-hero__actions">
      <a href={INSCRIPCION_URL} class="btn btn--primary btn--lg" target="_blank" rel="noopener">
        <i class="fa-solid fa-user-plus"></i> Inscríbete al Congreso
      </a>
      <a href="#agenda" class="btn btn--ghost-dark">
        <i class="fa-solid fa-calendar-days"></i> Ver agenda
      </a>
    </div>
  </section>

  <!-- ======================== Countdown ======================== -->
  <section class="ciprep-countdown" aria-labelledby="ciprep-countdown-title">
    <div class="container">
      <h2 id="ciprep-countdown-title" class="ciprep-countdown__title">
        Faltan para el inicio del Congreso
      </h2>
      <div class="ciprep-countdown__grid" role="timer" aria-live="off" data-ciprep-countdown data-target="2026-08-03T08:00:00-05:00">
        <div class="ciprep-countdown__cell">
          <span class="ciprep-countdown__num" data-unit="days">—</span>
          <span class="ciprep-countdown__label">días</span>
        </div>
        <div class="ciprep-countdown__cell">
          <span class="ciprep-countdown__num" data-unit="hours">—</span>
          <span class="ciprep-countdown__label">horas</span>
        </div>
        <div class="ciprep-countdown__cell">
          <span class="ciprep-countdown__num" data-unit="minutes">—</span>
          <span class="ciprep-countdown__label">min</span>
        </div>
        <div class="ciprep-countdown__cell">
          <span class="ciprep-countdown__num" data-unit="seconds">—</span>
          <span class="ciprep-countdown__label">seg</span>
        </div>
      </div>
      <p class="ciprep-countdown__date">
        <i class="fa-solid fa-calendar-day" aria-hidden="true"></i>
        Lunes 3 y martes 4 de agosto de 2026 · Bogotá
      </p>
    </div>
  </section>

  <nav class="ciprep-tabs" aria-label="Secciones del Congreso">
    <div class="container">
      <ul>
        {sections.map((s) => <li><a href={`#${s.id}`}>{s.label}</a></li>)}
      </ul>
    </div>
  </nav>

  <script is:inline>
    (function() {
      var el = document.querySelector('[data-ciprep-countdown]');
      if (!el) return;
      var target = new Date(el.getAttribute('data-target')).getTime();
      var nums = {
        days: el.querySelector('[data-unit="days"]'),
        hours: el.querySelector('[data-unit="hours"]'),
        minutes: el.querySelector('[data-unit="minutes"]'),
        seconds: el.querySelector('[data-unit="seconds"]'),
      };
      function pad(n) { return String(n).padStart(2, '0'); }
      function tick() {
        var diff = target - Date.now();
        if (diff <= 0) {
          nums.days.textContent = '0';
          nums.hours.textContent = '00';
          nums.minutes.textContent = '00';
          nums.seconds.textContent = '00';
          el.setAttribute('data-finished', '');
          var title = document.getElementById('ciprep-countdown-title');
          if (title) title.textContent = '¡El Congreso CIPREP 2026 está en curso!';
          return false;
        }
        var s = Math.floor(diff / 1000);
        var d = Math.floor(s / 86400);
        var h = Math.floor((s % 86400) / 3600);
        var m = Math.floor((s % 3600) / 60);
        var sec = s % 60;
        nums.days.textContent = String(d);
        nums.hours.textContent = pad(h);
        nums.minutes.textContent = pad(m);
        nums.seconds.textContent = pad(sec);
        return true;
      }
      if (tick()) setInterval(function() { if (!tick()) clearInterval(this); }, 1000);
    })();
  </script>

  <!-- ======================== Acerca del Congreso ======================== -->
  <section id="acerca" class="ciprep-section">
    <div class="container">
      <SectionTitle title="Acerca del Congreso" />
      <div class="ciprep-prose">
        <p>
          La <strong>Agencia del Inspector General de Tributos, Rentas y Contribuciones Parafiscales (ITRC)</strong> convoca la <strong>Segunda Edición del Congreso Internacional para la Protección de los Recursos Públicos (CIPREP 2026)</strong>, un espacio de diálogo y articulación nacional e internacional que da continuidad al exitoso primer congreso realizado en 2025.
        </p>
        <p>
          CIPREP 2026 reúne a representantes del sector público, organismos multilaterales, academia y aliados estratégicos del país y del exterior para fortalecer estrategias frente al fraude, la evasión fiscal, el contrabando y otras conductas que afectan la integridad en la gestión de los recursos públicos.
        </p>
        <p>
          Esta segunda edición profundiza los temas trabajados en 2025 e incorpora nuevos ejes sobre <em>cooperación internacional, innovación tecnológica para el control fiscal e integridad pública</em>, con el propósito de consolidar a la Agencia ITRC como referente técnico regional en la prevención, detección y respuesta frente a los riesgos que comprometen la gestión adecuada de los recursos de la nación.
        </p>
      </div>
      <div class="ciprep-recall">
        <p>
          ¿Te perdiste la primera edición? Consulta las
          <a href={resolveUrl('/ciprep2025')}>memorias del Congreso CIPREP 2025</a>:
          agenda completa, ponentes y grabaciones disponibles.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================== Agenda ======================== -->
  <section id="agenda" class="ciprep-section ciprep-section--alt">
    <div class="container">
      <SectionTitle title="Agenda" />
      <p class="ciprep-section__lead">
        Dos jornadas en el Auditorio Casas de Santa Bárbara del Ministerio de Hacienda, organizadas en cuatro ejes temáticos sobre detección del fraude, riesgos de corrupción, recuperación de activos y cultura de integridad.
      </p>

      <div class="ciprep-agenda">
        {agenda.map((day) => {
          let lastFranja = '';
          return (
            <article class="ciprep-day">
              <header class="ciprep-day__header">
                <span class="ciprep-day__badge">{day.dia.split('—')[0].trim().toUpperCase()}</span>
                <h3>{day.dia.split('—')[1]?.trim() ?? day.dia}</h3>
              </header>
              <ol class="ciprep-day__items">
                {day.franjas.map((item) => {
                  const showFranja = item.franja && item.franja !== lastFranja;
                  if (showFranja) lastFranja = item.franja;
                  const isPause = item.tipo === 'pausa' || item.tipo === 'cierre' || item.tipo === 'apertura';
                  return (
                    <>
                      {showFranja && (
                        <li class="ciprep-day__franja"><span>{item.franja}</span></li>
                      )}
                      <li class={`ciprep-item ${isPause ? 'ciprep-item--pausa' : ''}`}>
                        <div class="ciprep-item__time">{item.hora}</div>
                        <div class="ciprep-item__body">
                          {item.ponente && (
                            <div class="ciprep-item__ponente">
                              {item.foto ? (
                                <img src={resolveUrl(item.foto)} alt={item.ponente} class="ciprep-item__avatar" loading="lazy" />
                              ) : (
                                <div class="ciprep-item__avatar ciprep-item__avatar--placeholder">
                                  <i class="fa-solid fa-user" aria-hidden="true"></i>
                                </div>
                              )}
                              <div class="ciprep-item__ponente-info">
                                <strong class="ciprep-item__ponente-name">{item.ponente}</strong>
                                <span class="ciprep-item__ponente-entidad">{item.entidad} · {item.bandera} {item.pais}</span>
                              </div>
                            </div>
                          )}
                          <h4 class="ciprep-item__title">{item.titulo}</h4>
                          {item.detalle && <p class="ciprep-item__detalle">{item.detalle}</p>}
                        </div>
                      </li>
                    </>
                  );
                })}
              </ol>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ======================== Aliados ======================== -->
  <section id="aliados" class="ciprep-section">
    <div class="container">
      <SectionTitle title="Aliados Estratégicos" />
      <p class="ciprep-section__lead">
        FITAC y el Ministerio de Hacienda y Crédito Público se suman como aliados estratégicos del Segundo Congreso Internacional para la Protección de los Recursos Públicos, aportando su experiencia y liderazgo en la promoción de la transparencia, la integridad y el fortalecimiento de la gestión pública. Su respaldo fortalece este escenario de cooperación y diálogo para enfrentar los desafíos asociados al fraude y la corrupción.
      </p>
      <div class="ciprep-aliados-grid">
        {aliados.map((a) => (
          <article class="ciprep-aliado-card">
            <img src={resolveUrl(a.logo)} alt={`Logo ${a.nombre}`} class="ciprep-aliado-card__logo" loading="lazy" />
            <div>
              <h3>{a.nombre}</h3>
              <p>{a.tipo}</p>
            </div>
          </article>
        ))}
      </div>

      <SectionTitle title="Entidades expositoras" />
      <p class="ciprep-section__lead">
        Universidades, organismos internacionales, centros de investigación y entidades públicas que aportan ponentes al Congreso.
      </p>
      <div class="ciprep-entidades-grid">
        {entidadesExpositoras.map((e) => (
          <div class="ciprep-entidad-card" title={e.nombre}>
            <img src={resolveUrl(e.logo)} alt={`Logo ${e.nombre}`} loading="lazy" />
            <span class="ciprep-entidad-card__name">{e.nombre}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== Información del evento ======================== -->
  <section id="info" class="ciprep-section ciprep-section--alt">
    <div class="container">
      <SectionTitle title="Información del evento" />
      <div class="ciprep-info">
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-calendar"></i> Fechas</h3>
          <p>3 y 4 de agosto de 2026</p>
          <p class="ciprep-info__hint">Lunes y martes, jornada completa.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-location-dot"></i> Lugar</h3>
          <p><strong>Auditorio Casas de Santa Bárbara</strong></p>
          <p class="ciprep-info__addr">Ministerio de Hacienda y Crédito Público<br/>Carrera 7 # 6b-80, Bogotá</p>
          <div class="ciprep-info__maps">
            <a href={MAPS_URL} target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i> Cómo llegar
            </a>
          </div>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-tower-broadcast"></i> Modalidad</h3>
          <p><strong>Híbrida</strong></p>
          <p class="ciprep-info__hint">Presencial en Bogotá + transmisión en línea para asistentes remotos.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-ticket"></i> Inscripción</h3>
          <p><strong>Gratuita</strong></p>
          <p class="ciprep-info__hint">Cupos limitados según capacidad del auditorio. Se valida documento en puerta.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-language"></i> Idiomas</h3>
          <p><strong>Español</strong> (idioma principal)</p>
          <p class="ciprep-info__hint">Algunas intervenciones internacionales podrán ser en inglés.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-handshake"></i> Organiza</h3>
          <p><strong>Agencia ITRC</strong></p>
          <p class="ciprep-info__hint">Inspector General de Tributos, Rentas y Contribuciones Parafiscales.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== Inscripción / CTA ======================== -->
  <section id="inscripcion" class="ciprep-section">
    <div class="container">
      <div class="ciprep-cta">
        <h3>Inscripción al Congreso CIPREP 2026</h3>
        <p>
