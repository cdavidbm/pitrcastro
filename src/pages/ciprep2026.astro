---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { resolveUrl } from '../utils/url';

// Página informativa de CIPREP 2026 con datos confirmados al momento.
// La inscripción se delega a un formulario de Microsoft Forms gestionado
// por otra área. Agenda, ponentes y aliados se completarán cuando el
// equipo organizador entregue la información definitiva; mientras tanto
// se muestran datos provisionales claramente marcados como tales.

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Congresos', href: resolveUrl('/ciprep2026') },
  { label: 'CIPREP 2026' },
];

const INSCRIPCION_URL =
  'https://forms.office.com/pages/responsepage.aspx?id=3NElp2Q-g0KVXt1OUTYI5lXhhwicK9BAtrKaNXbBEVlUOVBQQjc2QzlVNFZQSDVGNktFN01DQVkzRC4u&route=shorturl';

const MAPS_URL =
  'https://www.google.com/maps/search/?api=1&query=Auditorio+Casas+de+Santa+B%C3%A1rbara+Ministerio+de+Hacienda+Bogot%C3%A1';

const sections = [
  { id: 'acerca', label: 'Acerca del Congreso' },
  { id: 'agenda', label: 'Agenda' },
  { id: 'aliados', label: 'Aliados' },
  { id: 'info', label: 'Información' },
  { id: 'inscripcion', label: 'Inscripción' },
];

// Agenda provisional. Marcada visualmente como tentativa hasta que el
// equipo organizador entregue la versión final.
const agendaTentativa = [
  {
    dia: 'Día 1 — lunes 3 de agosto de 2026',
    franjas: [
      { hora: '7:30 – 8:30 a.m.', titulo: 'Registro y bienvenida', franja: 'APERTURA' },
      { hora: '8:30 – 9:00 a.m.', titulo: 'Instalación oficial', franja: 'APERTURA' },
      {
        hora: '9:00 – 10:30 a.m.',
        titulo: 'Panel inaugural: lecciones del Primer Congreso',
        franja: 'APERTURA',
      },
      { hora: '10:30 – 11:00 a.m.', titulo: 'Receso', franja: 'APERTURA' },
      {
        hora: '11:00 a.m. – 12:30 p.m.',
        titulo: 'Conversatorio: cooperación internacional contra el fraude fiscal',
        franja: 'FRANJA 1: COOPERACIÓN',
      },
      { hora: '12:30 – 2:00 p.m.', titulo: 'Almuerzo libre', franja: 'FRANJA 1: COOPERACIÓN' },
      {
        hora: '2:00 – 4:00 p.m.',
        titulo: 'Mesas técnicas: control aduanero y trazabilidad',
        franja: 'FRANJA 2: CONTROL',
      },
      { hora: '4:00 – 4:30 p.m.', titulo: 'Cierre del día 1', franja: 'FRANJA 2: CONTROL' },
    ],
  },
  {
    dia: 'Día 2 — martes 4 de agosto de 2026',
    franjas: [
      { hora: '8:00 – 8:30 a.m.', titulo: 'Apertura del segundo día', franja: 'FRANJA 3: INNOVACIÓN' },
      {
        hora: '8:30 – 10:00 a.m.',
        titulo: 'Panel: tecnología y datos al servicio del control fiscal',
        franja: 'FRANJA 3: INNOVACIÓN',
      },
      { hora: '10:00 – 10:30 a.m.', titulo: 'Receso', franja: 'FRANJA 3: INNOVACIÓN' },
      {
        hora: '10:30 a.m. – 12:00 p.m.',
        titulo: 'Conversatorio: integridad pública y cultura ciudadana',
        franja: 'FRANJA 4: INTEGRIDAD',
      },
      { hora: '12:00 – 1:30 p.m.', titulo: 'Almuerzo libre', franja: 'FRANJA 4: INTEGRIDAD' },
      {
        hora: '1:30 – 3:00 p.m.',
        titulo: 'Sesión de clausura y compromisos',
        franja: 'FRANJA 5: CIERRE',
      },
      {
        hora: '3:00 – 3:30 p.m.',
        titulo: 'Palabras de cierre y fotografías oficiales',
        franja: 'FRANJA 5: CIERRE',
      },
    ],
  },
];

const aliados = [
  { nombre: 'Ministerio de Hacienda y Crédito Público', tipo: 'Aliado estratégico' },
  { nombre: 'FITAC — Federación Colombiana de Agentes Logísticos en Comercio Internacional', tipo: 'Aliado institucional' },
];
---

<Base
  title="II Congreso Internacional para la Protección de los Recursos Públicos — CIPREP 2026"
  description="Segunda edición del Congreso Internacional CIPREP. 3 y 4 de agosto de 2026 en Bogotá. Evento gratuito, híbrido y bilingüe organizado por la Agencia ITRC."
>
  <HeroPage
    title="II Congreso Internacional para la Protección de los Recursos Públicos"
    subtitle="Segunda edición — 3 y 4 de agosto de 2026"
    icon="fa-landmark-flag"
    badge="II edición · 3 y 4 de agosto de 2026"
    breadcrumb={breadcrumb}
  >
    <div class="ciprep-hero-meta">
      <span><i class="fa-solid fa-location-dot"></i> Auditorio Casas de Santa Bárbara — Min. Hacienda, Bogotá</span>
      <span><i class="fa-solid fa-tower-broadcast"></i> Modalidad híbrida (presencial + transmisión)</span>
      <span><i class="fa-solid fa-circle-check"></i> Inscripción gratuita</span>
    </div>
    <div class="ciprep-hero-cta">
      <a href={INSCRIPCION_URL} class="btn btn--primary" target="_blank" rel="noopener">
        <i class="fa-solid fa-user-plus"></i> Inscribirme al congreso
      </a>
      <a href="#agenda" class="btn btn--ghost">
        <i class="fa-solid fa-calendar-days"></i> Ver agenda tentativa
      </a>
    </div>
  </HeroPage>

  <nav class="ciprep-tabs" aria-label="Secciones del Congreso">
    <div class="container">
      <ul>
        {sections.map((s) => <li><a href={`#${s.id}`}>{s.label}</a></li>)}
      </ul>
    </div>
  </nav>

  <!-- ======================== Acerca del Congreso ======================== -->
  <section id="acerca" class="ciprep-section">
    <div class="container">
      <SectionTitle title="Acerca del Congreso" />
      <div class="ciprep-prose">
        <p>
          La <strong>Agencia del Inspector General de Tributos, Rentas y Contribuciones Parafiscales (ITRC)</strong> convoca la <strong>Segunda Edición del Congreso Internacional para la Protección de los Recursos Públicos (CIPREP 2026)</strong>, un espacio de diálogo y articulación nacional e internacional que da continuidad al exitoso primer congreso realizado en 2025.
        </p>
        <p>
          CIPREP 2026 reúne a representantes del sector público, organismos multilaterales, academia y aliados estratégicos del país y del exterior para fortalecer estrategias frente al fraude, la evasión fiscal, el contrabando y otras conductas que afectan la integridad en la gestión de los recursos públicos.
        </p>
        <p>
          Esta segunda edición profundiza los temas trabajados en 2025 e incorpora nuevos ejes sobre <em>cooperación internacional, innovación tecnológica para el control fiscal e integridad pública</em>, con el propósito de consolidar a la Agencia ITRC como referente técnico regional en la prevención, detección y respuesta frente a los riesgos que comprometen la gestión adecuada de los recursos de la nación.
        </p>
      </div>
      <div class="ciprep-recall">
        <p>
          ¿Te perdiste la primera edición? Consulta las
          <a href={resolveUrl('/ciprep2025')}>memorias del Congreso CIPREP 2025</a>:
          agenda completa, ponentes y grabaciones disponibles.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================== Agenda tentativa ======================== -->
  <section id="agenda" class="ciprep-section ciprep-section--alt">
    <div class="container">
      <SectionTitle title="Agenda tentativa" />
      <p class="ciprep-section__lead">
        Dos jornadas en el Auditorio Casas de Santa Bárbara del Ministerio de Hacienda. La agenda definitiva, con ponentes confirmados, se publicará semanas antes del evento.
      </p>

      <div class="ciprep-tentative-banner">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>Programación provisional. Sujeta a ajustes hasta la publicación oficial.</span>
      </div>

      <div class="ciprep-agenda">
        {agendaTentativa.map((day) => {
          let lastFranja = '';
          return (
            <article class="ciprep-day">
              <header class="ciprep-day__header">
                <span class="ciprep-day__badge">{day.dia.split('—')[0].trim().toUpperCase()}</span>
                <h3>{day.dia.split('—')[1]?.trim() ?? day.dia}</h3>
              </header>
              <ol class="ciprep-day__items">
                {day.franjas.map((item) => {
                  const showFranja = item.franja && item.franja !== lastFranja;
                  if (showFranja) lastFranja = item.franja;
                  return (
                    <>
                      {showFranja && (
                        <li class="ciprep-day__franja"><span>{item.franja}</span></li>
                      )}
                      <li class="ciprep-item">
                        <div class="ciprep-item__time">{item.hora}</div>
                        <div class="ciprep-item__body">
                          <h4 class="ciprep-item__title">{item.titulo}</h4>
                        </div>
                      </li>
                    </>
                  );
                })}
              </ol>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ======================== Aliados ======================== -->
  <section id="aliados" class="ciprep-section">
    <div class="container">
      <SectionTitle title="Aliados" />
      <p class="ciprep-section__lead">
        La organización del Congreso es liderada por la Agencia ITRC con el respaldo de aliados institucionales. La lista continuará creciendo.
      </p>
      <div class="ciprep-aliados-grid">
        {aliados.map((a) => (
          <article class="ciprep-aliado-card">
            <i class="fa-solid fa-handshake"></i>
            <div>
              <h3>{a.nombre}</h3>
              <p>{a.tipo}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="ciprep-soon">
        Más aliados se anunciarán en las próximas semanas.
      </p>
    </div>
  </section>

  <!-- ======================== Información del evento ======================== -->
  <section id="info" class="ciprep-section ciprep-section--alt">
    <div class="container">
      <SectionTitle title="Información del evento" />
      <div class="ciprep-info">
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-calendar"></i> Fechas</h3>
          <p>3 y 4 de agosto de 2026</p>
          <p class="ciprep-info__hint">Lunes y martes, jornada completa.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-location-dot"></i> Lugar</h3>
          <p><strong>Auditorio Casas de Santa Bárbara</strong></p>
          <p class="ciprep-info__addr">Ministerio de Hacienda y Crédito Público<br/>Carrera 7 # 6D-82, Bogotá</p>
          <div class="ciprep-info__maps">
            <a href={MAPS_URL} target="_blank" rel="noopener">
              <i class="fa-brands fa-google"></i> Cómo llegar
            </a>
          </div>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-tower-broadcast"></i> Modalidad</h3>
          <p><strong>Híbrida</strong></p>
          <p class="ciprep-info__hint">Presencial en Bogotá + transmisión en línea para asistentes remotos.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-ticket"></i> Inscripción</h3>
          <p><strong>Gratuita</strong></p>
          <p class="ciprep-info__hint">Cupos limitados según capacidad del auditorio. Se valida documento en puerta.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-language"></i> Idiomas</h3>
          <p><strong>Español</strong> (idioma principal)</p>
          <p class="ciprep-info__hint">Algunas intervenciones internacionales podrán ser en inglés.</p>
        </div>
        <div class="ciprep-info__card">
          <h3><i class="fa-solid fa-handshake"></i> Organiza</h3>
          <p><strong>Agencia ITRC</strong></p>
          <p class="ciprep-info__hint">Inspector General de Tributos, Rentas y Contribuciones Parafiscales.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== Inscripción / CTA ======================== -->
  <section id="inscripcion" class="ciprep-section">
    <div class="container">
      <div class="ciprep-cta">
        <h3>Inscripción al Congreso CIPREP 2026</h3>
        <p>
          La inscripción es <strong>gratuita</strong> y se realiza a través del formulario oficial del Ministerio de Hacienda. El formulario solicita autorización de tratamiento de datos personales conforme a la Ley 1581 de 2012 y el Decreto 1377 de 2013.
        </p>
        <a href={INSCRIPCION_URL} class="btn btn--primary btn--lg" target="_blank" rel="noopener">
          <i class="fa-solid fa-user-plus"></i> Diligenciar formulario de inscripción
        </a>
        <p class="ciprep-cta__note">
          El formulario se abre en una pestaña nueva. Al finalizar recibirás el acuse oficial de Microsoft Forms.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  /* === Hero === */
  .ciprep-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
    margin-top: var(--space-3);
    color: var(--white);
    opacity: 0.92;
    font-size: var(--font-size-sm);
  }
  .ciprep-hero-meta i { margin-right: var(--space-2); color: var(--itrc-gold); }
  .ciprep-hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-5);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: all var(--transition-base);
    border: 2px solid transparent;
  }
  .btn--primary { background: var(--itrc-gold); color: var(--itrc-navy); }
  .btn--primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn--ghost {
    background: transparent;
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--itrc-gold);
  }
  .btn--lg { padding: var(--space-4) var(--space-8); font-size: var(--font-size-base); }

  /* === Tabs sticky === */
  .ciprep-tabs {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--theme-surface);
    border-bottom: 1px solid var(--theme-border);
    box-shadow: var(--shadow-sm);
  }
  .ciprep-tabs ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    overflow-x: auto;
  }
  .ciprep-tabs a {
    display: block;
    padding: var(--space-3) var(--space-5);
    color: var(--theme-text-secondary);
    text-decoration: none;
    font-weight: 700;
    font-size: var(--font-size-sm);
    border-bottom: 3px solid transparent;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }
  .ciprep-tabs a:hover { color: var(--itrc-gold); border-color: var(--itrc-gold); }

  /* === Sections === */
  .ciprep-section { padding: var(--space-12) var(--space-6); background: var(--theme-surface); }
  .ciprep-section--alt { background: var(--theme-surface-alt); }
  .ciprep-section .container { max-width: 1100px; margin: 0 auto; }
  .ciprep-section__lead {
    text-align: center;
    color: var(--theme-text-secondary);
    max-width: 760px;
    margin: 0 auto var(--space-6);
    font-size: var(--font-size-base);
    line-height: 1.7;
  }
  .ciprep-prose p {
    line-height: 1.8;
    color: var(--theme-text);
    margin-bottom: var(--space-4);
    text-align: justify;
  }
  .ciprep-recall {
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: rgba(var(--itrc-gold-rgb), 0.10);
    border-left: 4px solid var(--itrc-gold);
    border-radius: var(--radius-md);
  }
  .ciprep-recall p { margin: 0; color: var(--theme-text); }
  .ciprep-recall a { color: var(--itrc-navy); font-weight: 700; }

  /* === Banner provisional === */
  .ciprep-tentative-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    margin: 0 auto var(--space-6);
    max-width: 720px;
    background: rgba(var(--itrc-gold-rgb), 0.15);
    color: var(--itrc-navy);
    border: 1px solid rgba(var(--itrc-gold-rgb), 0.5);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  .ciprep-tentative-banner i { color: var(--itrc-gold); }

  /* === Agenda === */
  .ciprep-agenda {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .ciprep-day {
    background: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-top: 4px solid var(--itrc-gold);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }
  .ciprep-day__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--theme-border-light);
  }
  .ciprep-day__badge {
    background: var(--itrc-navy);
    color: var(--white);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: 800;
    letter-spacing: 1px;
  }
  .ciprep-day__header h3 {
    margin: 0;
    color: var(--theme-heading);
    font-size: var(--font-size-lg);
  }
  .ciprep-day__items { list-style: none; margin: 0; padding: 0; }
  .ciprep-day__franja {
    margin-top: var(--space-4);
    margin-bottom: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: rgba(var(--itrc-gold-rgb), 0.12);
    color: var(--itrc-gold);
    font-weight: 800;
    font-size: var(--font-size-xs);
    letter-spacing: 0.5px;
    border-radius: var(--radius-md);
  }
  .ciprep-day__franja:first-child { margin-top: 0; }
  .ciprep-item {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px dashed var(--theme-border-light);
  }
  .ciprep-item:last-child { border-bottom: none; }
  .ciprep-item__time {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--itrc-gold);
    white-space: nowrap;
  }
  .ciprep-item__title {
    font-size: var(--font-size-sm);
    margin: 0;
    color: var(--theme-heading);
    line-height: 1.4;
  }

  /* === Aliados === */
  .ciprep-aliados-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }
  .ciprep-aliado-card {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-5);
    background: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-left: 4px solid var(--itrc-gold);
    border-radius: var(--radius-lg);
  }
  .ciprep-aliado-card i {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(var(--itrc-gold-rgb), 0.15);
    color: var(--itrc-gold);
    font-size: 1.4rem;
  }
  .ciprep-aliado-card h3 {
    margin: 0 0 4px;
    color: var(--theme-heading);
    font-size: var(--font-size-base);
    line-height: 1.3;
  }
  .ciprep-aliado-card p {
    margin: 0;
    color: var(--theme-text-secondary);
    font-size: var(--font-size-xs);
  }
  .ciprep-soon {
    text-align: center;
    color: var(--theme-text-muted);
    font-style: italic;
    font-size: var(--font-size-sm);
  }

  /* === Info === */
  .ciprep-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .ciprep-info__card {
    padding: var(--space-5);
    background: var(--theme-surface);
    border: 1px solid var(--theme-border);
    border-top: 4px solid var(--itrc-gold);
    border-radius: var(--radius-lg);
  }
  .ciprep-info__card h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--font-size-base);
    color: var(--theme-heading);
  }
  .ciprep-info__card h3 i { color: var(--itrc-gold); margin-right: var(--space-2); }
  .ciprep-info__card p {
    margin: 0 0 var(--space-2);
    color: var(--theme-text);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }
  .ciprep-info__addr {
    color: var(--theme-text-secondary) !important;
    font-size: var(--font-size-xs) !important;
  }
  .ciprep-info__hint {
    color: var(--theme-text-muted) !important;
    font-size: var(--font-size-xs) !important;
    font-style: italic;
  }
  .ciprep-info__maps { display: flex; gap: var(--space-3); margin-top: var(--space-3); }
  .ciprep-info__maps a {
    color: var(--itrc-gold);
    text-decoration: none;
    font-size: var(--font-size-xs);
    font-weight: 700;
  }
  .ciprep-info__maps a:hover { text-decoration: underline; }

  /* === CTA Inscripción === */
  .ciprep-cta {
    padding: var(--space-10);
    text-align: center;
    background: linear-gradient(135deg, var(--theme-cta-from, var(--itrc-navy)), var(--theme-cta-to, #003a7a));
    color: var(--white);
    border-radius: var(--radius-xl);
  }
  .ciprep-cta h3 {
    margin: 0 0 var(--space-3);
    color: var(--white);
    font-size: var(--font-size-xl);
  }
  .ciprep-cta p {
    margin: 0 auto var(--space-5);
    max-width: 720px;
    color: rgba(255, 255, 255, 0.9);
