---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import pageData from '../content/pages/transparencia/sede-horarios.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="sede-section">
    <div class="container">
      <div class="sede-grid">
        <div class="sede-card sede-card--direccion">
          <div class="sede-card__icon"><i class="fa-solid fa-location-dot" aria-hidden="true"></i></div>
          <h2>{pageData.sede.nombre}</h2>
          <p class="sede-card__main">{pageData.sede.direccion}{pageData.sede.piso ? `, ${pageData.sede.piso}` : ''}</p>
          <p class="sede-card__sub">{pageData.sede.ciudad}{pageData.sede.codigoPostal ? ` · Código Postal ${pageData.sede.codigoPostal}` : ''}</p>
        </div>

        <div class="sede-card sede-card--horario">
          <div class="sede-card__icon"><i class="fa-solid fa-clock" aria-hidden="true"></i></div>
          <h2>Horario de atención</h2>
          <p class="sede-card__main">{pageData.horario.dias}</p>
          <p class="sede-card__sub">{pageData.horario.inicio} — {pageData.horario.fin}</p>
          {pageData.horario.nota && <p class="sede-card__nota">{pageData.horario.nota}</p>}
        </div>

        <div class="sede-card sede-card--contacto">
          <div class="sede-card__icon"><i class="fa-solid fa-phone" aria-hidden="true"></i></div>
          <h2>Teléfono</h2>
          <p class="sede-card__main">{pageData.contacto.telefono}</p>
          {pageData.contacto.extension && <p class="sede-card__sub">Ext. {pageData.contacto.extension}</p>}
          {pageData.contacto.lineaGratuita && <p class="sede-card__sub">Línea gratuita: {pageData.contacto.lineaGratuita}</p>}
        </div>

        <div class="sede-card sede-card--email">
          <div class="sede-card__icon"><i class="fa-solid fa-envelope" aria-hidden="true"></i></div>
          <h2>Correo electrónico</h2>
          <p class="sede-card__main">
            <a href={`mailto:${pageData.contacto.email}`}>{pageData.contacto.email}</a>
          </p>
        </div>
      </div>

      {pageData.mapa && pageData.mapa.embedUrl && (
        <div class="sede-mapa">
          <h2><i class="fa-solid fa-map" aria-hidden="true"></i> Ubicación</h2>
          <iframe
            src={pageData.mapa.embedUrl}
            width="100%"
            height="420"
            style="border: 0; border-radius: 12px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de la Sede Principal"
          ></iframe>
        </div>
      )}

      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .sede-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .sede-section .container { max-width: 1100px; margin: 0 auto; }

  .sede-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-5); margin-bottom: var(--space-10); }

  .sede-card { padding: var(--space-6); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-xl); box-shadow: var(--shadow-sm); transition: all var(--transition-base); }
  .sede-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); border-color: var(--itrc-gold); }

  .sede-card__icon { width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--itrc-gold-light), var(--itrc-gold)); color: var(--itrc-navy); border-radius: var(--radius-lg); font-size: var(--font-size-xl); margin-bottom: var(--space-4); }

  .sede-card h2 { font-size: var(--font-size-base); font-weight: 800; color: var(--theme-heading); margin: 0 0 var(--space-2); }
  .sede-card__main { font-size: var(--font-size-lg); font-weight: 700; color: var(--theme-heading); margin: 0 0 4px; line-height: 1.4; }
  .sede-card__sub { font-size: var(--font-size-sm); color: var(--theme-text-secondary); margin: 0; line-height: 1.5; }
  .sede-card__nota { font-size: var(--font-size-xs); color: var(--theme-text-muted); font-style: italic; margin-top: var(--space-2); }

  .sede-card--email .sede-card__main a { color: var(--itrc-gold); text-decoration: none; }
  .sede-card--email .sede-card__main a:hover { text-decoration: underline; }

  .sede-mapa { margin-bottom: var(--space-8); }
  .sede-mapa h2 { display: flex; align-items: center; gap: var(--space-3); font-size: var(--font-size-xl); color: var(--theme-heading); margin: 0 0 var(--space-5); padding-bottom: var(--space-3); border-bottom: 2px solid var(--itrc-gold); }
  .sede-mapa h2 i { color: var(--itrc-gold); }

  .back-link { text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>
