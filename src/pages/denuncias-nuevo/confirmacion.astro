---
import Base from '../../layouts/Base.astro';
import HeroPage from '../../components/HeroPage.astro';
import { resolveUrl } from '../../utils/url';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Presente su denuncia', href: resolveUrl('/denuncias-nuevo') },
  { label: 'Radicado' },
];

// Pasos posteriores del proceso, mostrados como timeline
const proximos = [
  {
    icon: 'fa-solid fa-envelope-open-text',
    titulo: 'Recibirá un aviso',
    texto: 'Si indicó correo o teléfono, le llegará una confirmación con el número de radicado en las próximas horas.',
    tiempo: 'En pocas horas',
  },
  {
    icon: 'fa-solid fa-clipboard-check',
    titulo: 'Análisis inicial',
    texto: 'El equipo jurídico revisa que la denuncia cumpla los requisitos formales y hace la calificación jurídica de la conducta.',
    tiempo: 'Primeros 15 días hábiles',
  },
  {
    icon: 'fa-solid fa-magnifying-glass-chart',
    titulo: 'Investigación disciplinaria',
    texto: 'Si procede, se abre proceso disciplinario. Se practican pruebas, se toman declaraciones y se garantiza el derecho de defensa.',
    tiempo: 'Varía según complejidad',
  },
  {
    icon: 'fa-solid fa-scale-balanced',
    titulo: 'Decisión final',
    texto: 'La Agencia adopta decisión, notifica al investigado y — si usted lo pidió — le comunica el resultado del proceso.',
    tiempo: 'Al cierre del expediente',
  },
];
---

<Base
  title="Denuncia radicada — Agencia ITRC"
  description="Su denuncia disciplinaria fue radicada exitosamente en la Agencia ITRC. Guarde su número de radicado y contraseña para consultar el estado del proceso."
>
  <HeroPage
    title="Su denuncia fue radicada"
    subtitle="Gracias por contribuir al control disciplinario de los servidores públicos. Guarde su número de radicado y contraseña — con eso podrá consultar el estado del proceso cuando quiera."
    icon="fa-solid fa-circle-check"
    breadcrumb={breadcrumb}
  />

  <!-- ================ Datos del radicado ================ -->
  <section class="radicado" aria-labelledby="radicado-title">
    <div class="container">
      <div class="radicado-card">
        <div class="radicado-card__cabecera">
          <span class="radicado-card__eyebrow">Número de radicado</span>
          <h2 id="radicado-title" class="radicado-card__numero" data-radicado>—</h2>
          <button type="button" class="radicado-card__copiar" data-copy-radicado>
            <i class="fa-regular fa-copy" aria-hidden="true"></i>
            <span data-copy-label>Copiar</span>
          </button>
        </div>

        <div class="radicado-card__pass">
          <span class="radicado-card__pass-label">Contraseña de consulta</span>
          <div class="radicado-card__pass-value">
            <code data-pass-mask>••••••••</code>
            <button type="button" class="radicado-card__toggle-pass" data-toggle-pass aria-label="Mostrar u ocultar contraseña">
              <i class="fa-regular fa-eye"></i>
            </button>
            <button type="button" class="radicado-card__toggle-pass" data-copy-pass aria-label="Copiar contraseña">
              <i class="fa-regular fa-copy"></i>
            </button>
          </div>
          <p class="radicado-card__pass-warn">
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
            Esta contraseña la eligió usted al iniciar la denuncia. Anótela en un lugar seguro — no podemos recuperarla si la olvida.
          </p>
        </div>

        <div class="radicado-card__acciones">
          <button type="button" class="btn-primario" data-descargar>
            <i class="fa-solid fa-file-arrow-down" aria-hidden="true"></i>
            Descargar comprobante
          </button>
          <button type="button" class="btn-secundario" data-imprimir>
            <i class="fa-solid fa-print" aria-hidden="true"></i>
            Imprimir esta página
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ================ ¿Qué pasa ahora? ================ -->
  <section class="proximos" aria-labelledby="proximos-title">
    <div class="container">
      <h2 id="proximos-title" class="proximos__title">¿Qué pasa ahora?</h2>
      <p class="proximos__lede">
        Estos son los pasos que sigue la Agencia ITRC con su denuncia. Los tiempos dependen de la complejidad del caso y de los recursos disponibles.
      </p>

      <ol class="timeline">
        {proximos.map((p, idx) => (
          <li class="timeline__item">
            <div class="timeline__marker" aria-hidden="true">
              <span class="timeline__marker-icon"><i class={p.icon}></i></span>
            </div>
            <div class="timeline__content">
              <div class="timeline__meta">
                <span class="timeline__num">Paso {idx + 1}</span>
                <span class="timeline__tiempo">
                  <i class="fa-regular fa-clock" aria-hidden="true"></i>
                  {p.tiempo}
                </span>
              </div>
              <h3 class="timeline__titulo">{p.titulo}</h3>
              <p class="timeline__texto">{p.texto}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ================ CTAs finales ================ -->
  <section class="cta-final">
    <div class="container">
      <div class="cta-final__grid">
        <a href={resolveUrl('/denuncias-nuevo/consulta')} class="cta-card cta-card--primary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Consultar el estado más adelante</h3>
            <p class="cta-card__text">Con su radicado y contraseña, revise el avance del proceso cuando quiera.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
        </a>

        <a href={base} class="cta-card cta-card--secondary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-house"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Volver al portal</h3>
            <p class="cta-card__text">Regrese al sitio de la Agencia ITRC.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ================ Nota final ================ -->
  <section class="nota-final">
    <div class="container container--narrow">
      <div class="nota-final__body">
        <i class="fa-solid fa-shield-halved nota-final__icon" aria-hidden="true"></i>
        <div>
          <h3 class="nota-final__titulo">Su identidad está protegida</h3>
          <p class="nota-final__texto">
            Sus datos personales y el contenido de esta denuncia están bajo la reserva que establecen la Ley 734 de 2002 y la Ley 1712 de 2014. Sólo el equipo autorizado de la Agencia ITRC tiene acceso al expediente completo.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ================ Radicado card ================ */
  .radicado { padding: var(--space-10) var(--space-4) var(--space-8); background: var(--theme-surface); }
  .radicado .container { max-width: 780px; margin: 0 auto; }

  .radicado-card {
    background: linear-gradient(180deg, var(--theme-surface) 0%, var(--theme-surface-alt) 100%);
    border: 1px solid var(--theme-border-light);
    border-top: 4px solid var(--itrc-gold);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-6);
    box-shadow: 0 12px 32px rgba(0, 33, 71, 0.10);
    text-align: center;
  }

  .radicado-card__cabecera {
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-3);
  }
  .radicado-card__eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--theme-text-muted);
    font-weight: 700;
  }
  .radicado-card__numero {
    font-family: 'Nunito Sans', ui-monospace, "SF Mono", Menlo, monospace;
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    font-weight: 800;
    color: var(--theme-heading);
    letter-spacing: 0.02em;
    margin: 0;
    background: var(--theme-surface);
    border: 1.5px dashed var(--itrc-gold);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-6);
    font-variant-numeric: tabular-nums;
    display: inline-block;
    line-height: 1.1;
  }
  .radicado-card__copiar {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px;
    background: transparent;
    border: 1.5px solid var(--itrc-gold);
    border-radius: var(--radius-full);
    color: var(--itrc-gold-dark);
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .radicado-card__copiar:hover { background: var(--itrc-gold); color: var(--itrc-navy); }
  .radicado-card__copiar:focus-visible { outline: 3px solid var(--itrc-gold); outline-offset: 3px; }

  .radicado-card__pass {
    background: rgba(179, 139, 64, 0.08);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-top: var(--space-6);
    display: flex; flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }
  .radicado-card__pass-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--theme-text-muted);
    font-weight: 700;
  }
  .radicado-card__pass-value {
    display: inline-flex; align-items: center; gap: var(--space-2);
    background: var(--theme-surface);
    border: 1.5px solid var(--theme-border);
    border-radius: var(--radius-md);
    padding: 6px 10px;
  }
  .radicado-card__pass-value code {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 1.05rem;
    color: var(--theme-heading);
    letter-spacing: 0.1em;
  }
  .radicado-card__toggle-pass {
    background: transparent; border: none;
    color: var(--itrc-gold-dark); cursor: pointer;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
  }
  .radicado-card__toggle-pass:hover { background: var(--theme-surface-alt); color: var(--itrc-gold); }
  .radicado-card__toggle-pass:focus-visible { outline: 2px solid var(--itrc-gold); outline-offset: 2px; }

  .radicado-card__pass-warn {
    display: flex; align-items: flex-start; gap: 8px;
    color: var(--theme-text-secondary);
    font-size: 0.82rem;
    line-height: 1.5;
    margin: var(--space-2) 0 0;
    max-width: 46ch;
    text-align: left;
  }
  .radicado-card__pass-warn i { color: var(--signal, #a86426); flex-shrink: 0; margin-top: 2px; }

  .radicado-card__acciones {
    display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--theme-border-light);
  }

  .btn-primario, .btn-secundario {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-family: inherit; font-size: var(--font-size-sm); font-weight: 700;
    border-radius: var(--radius-full);
    text-decoration: none; cursor: pointer;
    border: 2px solid transparent;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }
  .btn-primario { background: var(--itrc-gold); color: var(--itrc-navy); box-shadow: var(--shadow-md); }
  .btn-primario:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn-primario:focus-visible { outline: 3px solid var(--itrc-gold); outline-offset: 3px; }
  .btn-secundario { background: transparent; color: var(--theme-heading); border-color: var(--theme-border); }
  .btn-secundario:hover { background: var(--theme-surface-alt); border-color: var(--itrc-gold); }
  .btn-secundario:focus-visible { outline: 3px solid var(--itrc-gold); outline-offset: 3px; }

  /* ================ Timeline "¿Qué pasa ahora?" ================ */
  .proximos { padding: var(--space-12) var(--space-4); background: var(--theme-surface-alt); }
  .proximos .container { max-width: 820px; margin: 0 auto; }
  .proximos__title {
    font-family: Georgia, serif;
    font-size: var(--font-size-2xl);
    color: var(--theme-heading);
    margin: 0 0 var(--space-3);
    text-align: center;
    text-wrap: balance;
  }
  .proximos__lede {
    text-align: center;
    color: var(--theme-text-secondary);
    max-width: 60ch;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }

  .timeline { list-style: none; padding: 0; margin: 0; position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 27px; top: 8px; bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, var(--itrc-gold), var(--theme-border-light));
  }
  .timeline__item {
    position: relative;
    display: flex;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
  }
  .timeline__item:last-child { padding-bottom: 0; }
  .timeline__marker {
    position: relative;
    flex-shrink: 0;
    z-index: 1;
  }
  .timeline__marker-icon {
    width: 56px; height: 56px;
    display: grid; place-items: center;
    background: var(--itrc-gold);
    color: var(--itrc-navy);
    border-radius: 50%;
    font-size: 1.2rem;
    box-shadow: 0 4px 12px rgba(0, 33, 71, 0.15);
    border: 3px solid var(--theme-surface-alt);
  }
  .timeline__content {
    flex: 1; min-width: 0;
    background: var(--theme-surface);
    border: 1px solid var(--theme-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    box-shadow: var(--shadow-sm);
  }
  .timeline__meta {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .timeline__num {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--itrc-gold-dark);
    font-weight: 700;
  }
  .timeline__tiempo {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.78rem;
    color: var(--theme-text-muted);
    font-weight: 600;
  }
  .timeline__tiempo i { font-size: 0.72rem; }
  .timeline__titulo {
    color: var(--theme-heading);
    font-size: var(--font-size-lg);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }
  .timeline__texto {
    color: var(--theme-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin: 0;
  }

  /* ================ CTA finales ================ */
  .cta-final { padding: var(--space-10) var(--space-4); background: var(--theme-surface); }
  .cta-final .container { max-width: 900px; margin: 0 auto; }
  .cta-final__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }
  .cta-card {
    display: flex; align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--theme-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--theme-border-light);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }
  .cta-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 33, 71, 0.18);
    border-color: var(--itrc-gold);
  }
  .cta-card:focus-visible { outline: 3px solid var(--itrc-gold); outline-offset: 3px; }
  .cta-card__icon {
    flex-shrink: 0;
    width: 48px; height: 48px;
    display: grid; place-items: center;
    border-radius: 50%;
    font-size: 1.2rem;
  }
  .cta-card--primary .cta-card__icon { background: var(--itrc-gold); color: var(--itrc-navy); }
  .cta-card--secondary .cta-card__icon { background: var(--theme-surface-alt); color: var(--itrc-navy); border: 2px solid var(--theme-border); }
  .cta-card__body { flex: 1; min-width: 0; }
  .cta-card__title { font-size: var(--font-size-base); color: var(--theme-heading); margin: 0 0 4px; line-height: 1.3; }
  .cta-card__text { font-size: 0.85rem; color: var(--theme-text-secondary); margin: 0; line-height: 1.5; }
  .cta-card__arrow { color: var(--itrc-gold); font-size: 1rem; transition: transform var(--transition-fast); }
  .cta-card:hover .cta-card__arrow { transform: translateX(3px); }

  /* ================ Nota final ================ */
  .nota-final { padding: var(--space-6) var(--space-4) var(--space-12); background: var(--theme-surface); }
  .nota-final .container--narrow { max-width: 780px; margin: 0 auto; }
  .nota-final__body {
    display: flex; gap: var(--space-4);
    padding: var(--space-5);
    background: var(--theme-surface-alt);
    border-left: 4px solid var(--itrc-navy);
    border-radius: var(--radius-lg);
  }
  .nota-final__icon {
    font-size: 1.5rem;
    color: var(--itrc-navy);
    flex-shrink: 0;
    margin-top: 4px;
  }
  .nota-final__titulo {
    font-size: var(--font-size-base);
    color: var(--theme-heading);
    margin: 0 0 var(--space-2);
    font-weight: 700;
  }
  .nota-final__texto {
    color: var(--theme-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primario, .btn-secundario, .cta-card, .cta-card__arrow, .radicado-card__copiar,
    .radicado-card__toggle-pass { transition: none; }
    .btn-primario:hover, .cta-card:hover { transform: none; }
    .cta-card:hover .cta-card__arrow { transform: none; }
  }

  @media (max-width: 640px) {
    .radicado-card { padding: var(--space-6) var(--space-4); }
    .radicado-card__numero { font-size: 1.65rem; padding: var(--space-3) var(--space-4); }
    .timeline__marker-icon { width: 44px; height: 44px; font-size: 1rem; }
    .timeline::before { left: 21px; }
    .cta-card { flex-direction: column; align-items: flex-start; text-align: left; }
  }

  @media print {
    .cta-final, .nota-final, .radicado-card__acciones, .breadcrumb { display: none; }
    body { background: white; color: black; }
  }
</style>

<script>
  // ============ Generar radicado + recuperar contraseña ============
  // En producción el backend arma el radicado y devuelve pass; aquí simulamos
  // formato realista para que se vea coherente el prototipo.
  function generarRadicado(): string {
    const year = 2026; // fijo — el archivo se rehace anualmente al fin de año
    const seq = String(Math.floor(Math.random() * 9999)).padStart(4, '0');
    const check = String(Math.floor(Math.random() * 999999)).padStart(6, '0');
    return `${year}-${seq}-${check}`;
  }

  const rad = document.querySelector<HTMLElement>('[data-radicado]');
  if (rad) rad.textContent = generarRadicado();

  // Contraseña del wizard (localStorage o sessionStorage la puso el paso 2)
  const pass = (() => {
    for (const key of Object.keys(localStorage)) {
      if (key.startsWith('itrc-denuncia-borrador-')) {
        try {
          const data = JSON.parse(localStorage.getItem(key) || '{}');
          if (data.CONTRASENIA) return data.CONTRASENIA as string;
        } catch (_) {}
      }
    }
    return 'MiClave-2026';
  })();

  const passMask = document.querySelector<HTMLElement>('[data-pass-mask]');
  const togglePass = document.querySelector<HTMLButtonElement>('[data-toggle-pass]');
  let revealed = false;
  togglePass?.addEventListener('click', () => {
    revealed = !revealed;
    if (passMask) passMask.textContent = revealed ? pass : '•'.repeat(pass.length);
    const icon = togglePass.querySelector('i');
    if (icon) icon.className = revealed ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye';
  });

  // Copiar radicado
  const copyBtn = document.querySelector<HTMLButtonElement>('[data-copy-radicado]');
  const copyLabel = document.querySelector<HTMLElement>('[data-copy-label]');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(rad?.textContent || '');
      if (copyLabel) copyLabel.textContent = 'Copiado';
      setTimeout(() => { if (copyLabel) copyLabel.textContent = 'Copiar'; }, 1800);
    } catch (_) {}
  });

  // Copiar contraseña
  const copyPassBtn = document.querySelector<HTMLButtonElement>('[data-copy-pass]');
  copyPassBtn?.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(pass); } catch (_) {}
  });

  // Imprimir
  document.querySelector<HTMLButtonElement>('[data-imprimir]')?.addEventListener('click', () => window.print());

  // Descargar comprobante (por ahora placeholder — el backend lo generará)
  document.querySelector<HTMLButtonElement>('[data-descargar]')?.addEventListener('click', () => {
    alert('El comprobante en PDF estará disponible cuando el backend lo genere. Mientras tanto, use "Imprimir" para guardar esta página como PDF.');
  });
</script>
