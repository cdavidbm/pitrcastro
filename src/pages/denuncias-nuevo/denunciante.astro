    .paso-indicador__item::after { width: 12px; margin-left: var(--space-1); }
    .fieldset { padding: var(--space-5) var(--space-4); }
    .fieldset__ayuda { margin-left: 0; }
    .tipo-persona__grid, .campo-grid, .campo, .check-inline { margin-left: 0; }
    .form-actions { flex-direction: column-reverse; }
    .form-actions .btn-primario, .form-actions .btn-secundario { width: 100%; justify-content: center; }
  }
</style>

<script>
  // === Entidad chip: leer ?entidad=X del querystring ===
  // Los 3 logos ya están en el DOM ocultos; el JS solo destapa el que corresponde
  // (así Astro resuelve la URL correcta con basePath en build; no dependemos de baseURI en runtime).
  const chip = document.querySelector<HTMLElement>('[data-entidad-chip]');
  const formIdInput = document.querySelector<HTMLInputElement>('[data-form-id]');

  const params = new URLSearchParams(window.location.search);
  const entidadSlug = params.get('entidad') || '';
  const logoActivo = document.querySelector<HTMLImageElement>(`[data-entidad-logo="${entidadSlug}"]`);

  if (chip && logoActivo) {
    logoActivo.hidden = false;
    chip.hidden = false;
    if (formIdInput) formIdInput.value = entidadSlug;
  }

  // === Show/hide de grupos según tipo de persona ===
  const groups = {
    natural:           ['natural', 'contacto', 'ubicacion', 'consulta', 'terms'],
    juridica:          ['juridica', 'contacto', 'ubicacion', 'consulta', 'terms'],
    anonimo:           ['consulta', 'anonimo-contacto', 'terms-anonimo'],
  };

  const allGroups = ['natural', 'juridica', 'contacto', 'ubicacion', 'consulta', 'anonimo-contacto', 'terms', 'terms-anonimo'];
  const actions = document.querySelector<HTMLElement>('[data-actions]');
  const consultaNum = document.querySelector<HTMLElement>('[data-consulta-num]');
  const termsNum = document.querySelector<HTMLElement>('[data-terms-num]');

  const setNum = (el: HTMLElement | null, n: number) => { if (el) el.textContent = String(n); };

  document.querySelectorAll<HTMLInputElement>('[data-tipo-persona]').forEach(radio => {
    radio.addEventListener('change', () => {
      const tipo = radio.value as keyof typeof groups;
      const visibleGroups = groups[tipo] || [];

      allGroups.forEach(g => {
        const el = document.querySelector<HTMLElement>(`[data-group="${g}"]`);
        if (el) el.hidden = !visibleGroups.includes(g);
      });

      // Renumerar el orden del pasillo de fieldsets
      if (tipo === 'anonimo') {
        setNum(consultaNum, 2);
      } else {
        setNum(consultaNum, 5);
        setNum(termsNum, 6);
      }

      if (actions) actions.hidden = false;
    });
  });
</script>
