---
import Base from '../../layouts/Base.astro';
import HeroPage from '../../components/HeroPage.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import Accordion from '../../components/Accordion.astro';
import { resolveUrl } from '../../utils/url';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Presente su denuncia' },
];

const entidades = [
  {
    nombre: 'DIAN',
    descripcion: 'Dirección de Impuestos y Aduanas Nacionales',
    slug: 'dian',
    logo: '/images/entidades/dian.png',
  },
  {
    nombre: 'Coljuegos',
    descripcion: 'Empresa Industrial y Comercial del Estado — Administradora del Monopolio Rentístico de los Juegos de Suerte y Azar',
    slug: 'coljuegos',
    logo: '/images/entidades/coljuegos.png',
  },
  {
    nombre: 'UGPP',
    descripcion: 'Unidad de Gestión Pensional y Parafiscales',
    slug: 'ugpp',
    logo: '/images/entidades/ugpp.png',
  },
];

const pasos = [
  {
    num: '01',
    titulo: 'Elija la entidad',
    texto: 'Seleccione la entidad a la que pertenece el servidor público que va a denunciar: DIAN, Coljuegos o UGPP.',
  },
  {
    num: '02',
    titulo: 'Identifíquese',
    texto: 'Puede hacerlo como persona natural, jurídica, o de manera anónima. La reserva de su identidad está protegida por ley.',
  },
  {
    num: '03',
    titulo: 'Describa los hechos',
    texto: 'Un formulario guiado le ayuda a describir la conducta, aportar detalles y adjuntar evidencia digital si la tiene.',
  },
  {
    num: '04',
    titulo: 'Reciba su radicado',
    texto: 'Al terminar, recibirá un número de radicado y una contraseña para consultar el estado de su denuncia en cualquier momento.',
  },
];

const garantias = [
  {
    icon: 'fa-solid fa-user-shield',
    titulo: 'Reserva de identidad',
    texto: 'Sus datos personales quedan protegidos por la Ley 1712 de 2014 y no son compartidos fuera del proceso disciplinario.',
  },
  {
    icon: 'fa-solid fa-user-secret',
    titulo: 'Denuncia anónima permitida',
    texto: 'Puede presentar la denuncia sin identificarse. Solo cambia el modo en el que se le notifican los avances.',
  },
  {
    icon: 'fa-solid fa-key',
    titulo: 'Consulta con contraseña propia',
    texto: 'Usted elige una contraseña al radicar. Con esa contraseña y el número de radicado consulta el avance cuando quiera.',
  },
  {
    icon: 'fa-solid fa-scale-balanced',
    titulo: 'Marco legal claro',
    texto: 'El trámite se rige por la Ley 734 de 2002 (Código Disciplinario) y por la Ley 2094 de 2021, con garantías para ambas partes.',
  },
];

const faq = [
  {
    title: '¿Quién puede presentar una denuncia?',
    content:
      'Cualquier ciudadano, servidor público o persona jurídica que tenga conocimiento de una posible falta disciplinaria cometida por un servidor público adscrito a DIAN, Coljuegos o UGPP.',
  },
  {
    title: '¿Qué conductas se pueden denunciar?',
    content:
      'Faltas disciplinarias tipificadas en la Ley 734 de 2002, entre otras: peculado, cohecho, prevaricato, concusión, tráfico de influencias, falsedad en documento público, incremento patrimonial no justificado, abuso de función pública, e indebida celebración de contratos.',
  },
  {
    title: '¿Necesito pruebas para denunciar?',
    content:
      'No es requisito, pero cualquier documento, imagen, correo electrónico o testimonio que respalde su denuncia agiliza la investigación. Puede adjuntar archivos digitales durante el proceso.',
  },
  {
    title: '¿Cuánto demora el proceso?',
    content:
      'Los tiempos varían según la complejidad del caso. Podrá consultar el estado del expediente cuando quiera con su número de radicado y su contraseña.',
  },
  {
    title: '¿Corro algún riesgo al denunciar?',
    content:
      'La Ley 1712 de 2014 protege la reserva de su identidad. Si prefiere no identificarse, la denuncia anónima es una opción válida. Su seguridad y confidencialidad son prioritarias para la Agencia ITRC.',
  },
];
---

<Base
  title="Presente su denuncia — Agencia ITRC"
  description="Presente una denuncia disciplinaria contra servidores públicos de DIAN, Coljuegos o UGPP. Proceso guiado, reserva de identidad garantizada y consulta de estado con radicado y contraseña propia."
>
  <HeroPage
    title="Presente su denuncia"
    subtitle="Un canal directo para reportar conductas presuntamente irregulares de servidores públicos adscritos a DIAN, Coljuegos y UGPP. Su denuncia importa y su identidad está protegida."
    icon="fa-solid fa-scale-balanced"
    breadcrumb={breadcrumb}
  />

  <!-- ================== CTAs primarios ================== -->
  <section class="cta-band" aria-labelledby="cta-band-title">
    <div class="container">
      <h2 id="cta-band-title" class="visually-hidden">¿Qué desea hacer?</h2>
      <div class="cta-band__grid">
        <a href={resolveUrl('/denuncias-nuevo/entidades')} class="cta-card cta-card--primary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-file-signature"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Presentar una denuncia</h3>
            <p class="cta-card__text">Inicie el proceso guiado. Toma entre 10 y 20 minutos, y puede guardar su avance.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true">
            <i class="fa-solid fa-arrow-right"></i>
          </span>
        </a>

        <a href={resolveUrl('/denuncias-nuevo/consulta')} class="cta-card cta-card--secondary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Consultar mi radicado</h3>
            <p class="cta-card__text">Si ya presentó una denuncia, consulte el estado con su número de radicado y contraseña.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true">
            <i class="fa-solid fa-arrow-right"></i>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ================== Cómo funciona ================== -->
  <section class="proceso" aria-labelledby="proceso-title">
    <div class="container">
      <SectionTitle id="proceso-title">Cómo funciona el proceso</SectionTitle>
      <p class="proceso__lede">
        Cuatro pasos guiados. En cada uno se le indica qué información se necesita y por qué. No requiere conocimiento legal previo.
      </p>
      <ol class="proceso__grid">
        {pasos.map(p => (
          <li class="paso-card">
            <span class="paso-card__num" aria-hidden="true">{p.num}</span>
            <h3 class="paso-card__titulo">{p.titulo}</h3>
            <p class="paso-card__texto">{p.texto}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ================== Garantías ================== -->
  <section class="garantias" aria-labelledby="garantias-title">
    <div class="container">
      <SectionTitle id="garantias-title">Sus garantías al denunciar</SectionTitle>
      <p class="garantias__lede">
        La ley protege a quien denuncia y a quien es denunciado. Estas son las cuatro garantías principales del proceso.
      </p>
      <div class="garantias__grid">
        {garantias.map(g => (
          <article class="garantia-card">
            <div class="garantia-card__icon" aria-hidden="true">
              <i class={g.icon}></i>
            </div>
            <h3 class="garantia-card__titulo">{g.titulo}</h3>
            <p class="garantia-card__texto">{g.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ================== Entidades bajo control disciplinario ================== -->
  <section class="entidades" aria-labelledby="entidades-title">
    <div class="container">
      <SectionTitle id="entidades-title">Entidades cuyos servidores puede denunciar</SectionTitle>
      <p class="entidades__lede">
        La Agencia ITRC ejerce el control disciplinario externo sobre servidores públicos adscritos a estas tres entidades.
      </p>
      <div class="entidades__grid">
        {entidades.map(e => (
          <div class="entidad-card">
            <div class="entidad-card__logo-wrap">
              <img src={resolveUrl(e.logo)} alt={`Logo ${e.nombre}`} class="entidad-card__logo" loading="lazy" />
            </div>
            <p class="entidad-card__desc">{e.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================== FAQ ================== -->
  <section class="faq" aria-labelledby="faq-title">
    <div class="container container--narrow">
      <SectionTitle id="faq-title">Preguntas frecuentes</SectionTitle>
      <Accordion items={faq} variant="content" />
    </div>
  </section>

  <!-- ================== Nota legal ================== -->
  <section class="legal" aria-labelledby="legal-title">
    <div class="container container--narrow">
      <h2 id="legal-title" class="legal__title">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        Marco normativo
      </h2>
      <p class="legal__text">
        El proceso se rige por la <strong>Ley 734 de 2002</strong> (Código Disciplinario Único) y la <strong>Ley 2094 de 2021</strong> (que modifica el Código General Disciplinario). La reserva de la identidad del denunciante y de los documentos de la investigación se ampara en la <strong>Ley 1712 de 2014</strong> de transparencia y acceso a la información pública.
      </p>
      <p class="legal__text">
        Presentar una denuncia con temeridad, mala fe o para causar daño injustificado puede configurar responsabilidad disciplinaria, civil o penal según el caso.
      </p>
    </div>
  </section>

  <!-- ================== CTAs de cierre ================== -->
  <section class="cta-close" aria-labelledby="cta-close-title">
    <div class="container">
      <div class="cta-close__intro">
        <h2 id="cta-close-title" class="cta-close__title">Ya conoce el proceso — dé el siguiente paso</h2>
        <p class="cta-close__lede">
          Presente su denuncia o consulte el estado de una que ya haya radicado. En ambos casos el proceso es guiado y toma pocos minutos.
        </p>
      </div>
      <div class="cta-close__grid">
        <a href={resolveUrl('/denuncias-nuevo/entidades')} class="cta-card cta-card--primary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-file-signature"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Presentar una denuncia</h3>
            <p class="cta-card__text">Inicie el proceso guiado. Toma entre 10 y 20 minutos, y puede guardar su avance.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true">
            <i class="fa-solid fa-arrow-right"></i>
          </span>
        </a>

        <a href={resolveUrl('/denuncias-nuevo/consulta')} class="cta-card cta-card--secondary">
          <div class="cta-card__icon" aria-hidden="true">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <div class="cta-card__body">
            <h3 class="cta-card__title">Consultar mi radicado</h3>
            <p class="cta-card__text">Si ya presentó una denuncia, consulte el estado con su número de radicado y contraseña.</p>
          </div>
          <span class="cta-card__arrow" aria-hidden="true">
            <i class="fa-solid fa-arrow-right"></i>
          </span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============ CTAs primarios ============ */
  .cta-band { padding: var(--space-10) var(--space-4) var(--space-6); background: var(--theme-surface); }
  .cta-band .container { max-width: 1100px; margin: 0 auto; }
  .cta-band__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
    margin-top: calc(var(--space-3) * -1);
    position: relative;
    z-index: 2;
  }
  .cta-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--theme-surface);
    border-radius: var(--radius-lg);
    box-shadow: 0 8px 24px rgba(0, 33, 71, 0.12);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--theme-border-light);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
  }
  .cta-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 33, 71, 0.18);
    border-color: var(--itrc-gold);
  }
  .cta-card:focus-visible {
    outline: 3px solid var(--itrc-gold);
    outline-offset: 3px;
  }
  .cta-card__icon {
    flex-shrink: 0;
    width: 56px; height: 56px;
    display: grid; place-items: center;
    border-radius: 50%;
    font-size: 1.5rem;
  }
  .cta-card--primary .cta-card__icon {
    background: var(--itrc-gold);
    color: var(--itrc-navy);
  }
  .cta-card--secondary .cta-card__icon {
    background: var(--theme-surface-alt);
    color: var(--itrc-navy);
    border: 2px solid var(--theme-border);
  }
  .cta-card__body { flex: 1; min-width: 0; }
  .cta-card__title {
    font-size: var(--font-size-lg);
    color: var(--theme-heading);
    margin: 0 0 var(--space-1);
    line-height: 1.3;
  }
  .cta-card__text {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .cta-card__arrow {
    flex-shrink: 0;
    color: var(--itrc-gold);
    font-size: 1.1rem;
    transition: transform var(--transition-fast);
  }
  .cta-card:hover .cta-card__arrow {
    transform: translateX(4px);
  }

  /* ============ Proceso ============ */
  .proceso { padding: var(--space-12) var(--space-4); background: var(--theme-surface); }
  .proceso .container { max-width: 1100px; margin: 0 auto; }
  .proceso__lede {
    max-width: 68ch;
    color: var(--theme-text-secondary);
    font-size: var(--font-size-base);
    margin: 0 0 var(--space-8);
    line-height: 1.6;
  }
  .proceso__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .paso-card {
    background: var(--theme-surface-alt);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    position: relative;
    border-top: 3px solid var(--itrc-gold);
  }
  .paso-card__num {
    display: block;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--itrc-gold);
    line-height: 1;
    margin-bottom: var(--space-3);
    letter-spacing: -0.03em;
  }
  .paso-card__titulo {
    font-size: var(--font-size-lg);
    color: var(--theme-heading);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }
  .paso-card__texto {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ============ Garantías ============ */
  .garantias {
    padding: var(--space-12) var(--space-4);
    background: linear-gradient(135deg, var(--theme-dark-section-bg) 0%, var(--itrc-navy) 100%);
    color: var(--white);
  }
  .garantias .container { max-width: 1100px; margin: 0 auto; }
  .garantias :global(.section-title__text),
  .garantias :global(.section-title h2) {
    color: var(--white);
  }
  .garantias__lede {
    max-width: 68ch;
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-base);
    margin: 0 0 var(--space-8);
    line-height: 1.6;
  }
  .garantias__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .garantia-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
  }
  .garantia-card__icon {
    display: grid; place-items: center;
    width: 48px; height: 48px;
    background: var(--itrc-gold);
    color: var(--itrc-navy);
    border-radius: 50%;
    font-size: 1.25rem;
    margin-bottom: var(--space-4);
  }
  .garantia-card__titulo {
    color: var(--white);
    font-size: var(--font-size-lg);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }
  .garantia-card__texto {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin: 0;
  }

  /* ============ Entidades ============ */
  .entidades { padding: var(--space-12) var(--space-4); background: var(--theme-surface-alt); }
  .entidades .container { max-width: 1100px; margin: 0 auto; }
  .entidades__lede {
    max-width: 68ch;
    color: var(--theme-text-secondary);
    font-size: var(--font-size-base);
    margin: 0 0 var(--space-8);
    line-height: 1.6;
  }
  .entidades__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .entidad-card {
    background: var(--theme-surface);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--itrc-gold);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .entidad-card__logo-wrap {
    display: grid;
    place-items: center;
    height: 60px;
    padding: var(--space-2) 0;
  }
  .entidad-card__logo {
    max-width: 180px;
    max-height: 60px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .entidad-card__desc {
    color: var(--theme-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.5;
    margin: 0;
    text-align: center;
  }

  /* ============ FAQ ============ */
  .faq { padding: var(--space-12) var(--space-4); background: var(--theme-surface); }
  .faq .container--narrow { max-width: 820px; margin: 0 auto; }

  /* ============ CTAs de cierre ============ */
  .cta-close {
    padding: var(--space-12) var(--space-4);
    background: linear-gradient(180deg, var(--theme-surface) 0%, var(--theme-surface-alt) 100%);
  }
  .cta-close .container { max-width: 1100px; margin: 0 auto; }
  .cta-close__intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-8);
  }
  .cta-close__title {
    font-size: var(--font-size-2xl);
    color: var(--theme-heading);
    margin: 0 0 var(--space-3);
    line-height: 1.25;
    text-wrap: balance;
  }
  .cta-close__lede {
    color: var(--theme-text-secondary);
    font-size: var(--font-size-base);
    line-height: 1.6;
    margin: 0;
  }
  .cta-close__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
  }

  /* ============ Legal ============ */
  .legal { padding: var(--space-10) var(--space-4) var(--space-12); background: var(--theme-surface-alt); }
  .legal .container--narrow { max-width: 820px; margin: 0 auto; }
  .legal__title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--theme-heading);
    font-size: var(--font-size-lg);
    margin: 0 0 var(--space-4);
  }
  .legal__title i { color: var(--itrc-gold); }
  .legal__text {
    color: var(--theme-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.7;
    margin: 0 0 var(--space-3);
  }
  .legal__text strong { color: var(--theme-heading); font-weight: 700; }

  /* ============ Utilidad ============ */
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  /* ============ Motion ============ */
  @media (prefers-reduced-motion: reduce) {
    .cta-card, .cta-card__arrow { transition: none; }
    .cta-card:hover { transform: none; }
  }

  /* ============ Móvil ============ */
  @media (max-width: 640px) {
    .cta-card {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      padding: var(--space-5);
    }
    .cta-card__arrow { align-self: flex-end; }
    .paso-card__num { font-size: 2rem; }
  }
</style>
