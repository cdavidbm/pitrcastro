---
import Base from '../../layouts/Base.astro';
import HeroPage from '../../components/HeroPage.astro';
import { resolveUrl } from '../../utils/url';

import pageData from '../../content/pages/observatorio/eje-de-educacion.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="edu-section">
    <div class="container">
      <p class="edu-intro">{pageData.intro}</p>

      <div class="edu-grid">
        {pageData.secciones.map((sec) => (
          <a href={resolveUrl(sec.url)} class="edu-card" style={`--card-accent: ${sec.color}`}>
            <div class="edu-card__icon">
              <i class={`fa-solid ${sec.icon}`} aria-hidden="true"></i>
            </div>
            <h3 class="edu-card__title">{sec.titulo}</h3>
            <p class="edu-card__desc">{sec.descripcion}</p>
            <span class="edu-card__arrow"><i class="fa-solid fa-arrow-right" aria-hidden="true"></i></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .edu-section { padding: var(--space-10) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .edu-section .container { max-width: 1050px; margin: 0 auto; }
  .edu-intro { font-size: var(--font-size-lg); line-height: 1.8; color: var(--theme-text); text-align: center; max-width: 850px; margin: 0 auto var(--space-10); }

  .edu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-5); }

  .edu-card { display: flex; flex-direction: column; align-items: center; text-align: center; padding: var(--space-8) var(--space-5); background: var(--theme-surface); border: 1px solid var(--theme-border); border-top: 4px solid var(--card-accent); border-radius: var(--radius-xl); text-decoration: none; transition: all var(--transition-base); }
  .edu-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--card-accent); }

  .edu-card__icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: var(--card-accent); color: var(--white); border-radius: var(--radius-full); font-size: var(--font-size-2xl); margin-bottom: var(--space-4); transition: transform var(--transition-base); }
  .edu-card:hover .edu-card__icon { transform: scale(1.1); }

  .edu-card__title { font-size: var(--font-size-sm); font-weight: 800; color: var(--theme-heading); margin: 0 0 var(--space-2); transition: color var(--transition-fast); }
  .edu-card:hover .edu-card__title { color: var(--card-accent); }

  .edu-card__desc { font-size: var(--font-size-xs); line-height: 1.6; color: var(--theme-text-secondary); margin: 0; flex: 1; }

  .edu-card__arrow { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; margin-top: var(--space-4); border-radius: var(--radius-full); background: rgba(0,0,0,0.04); color: var(--theme-text-muted); font-size: var(--font-size-sm); transition: all var(--transition-fast); }
  .edu-card:hover .edu-card__arrow { background: var(--card-accent); color: var(--white); }

  @media (max-width: 768px) {
    .edu-section { padding: var(--space-6) var(--space-4) var(--space-12); }
    .edu-intro { font-size: var(--font-size-base); }
    .edu-grid { grid-template-columns: 1fr; gap: var(--space-3); }
    .edu-card { flex-direction: row; text-align: left; padding: var(--space-4); gap: var(--space-3); border-top: none; border-left: 4px solid var(--card-accent); }
    .edu-card__icon { width: 44px; height: 44px; font-size: var(--font-size-xl); margin-bottom: 0; flex-shrink: 0; }
    .edu-card__arrow { display: none; }
  }
</style>
