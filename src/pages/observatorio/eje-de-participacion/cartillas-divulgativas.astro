---
import Base from '../../../layouts/Base.astro';
import HeroPage from '../../../components/HeroPage.astro';
import { resolveUrl } from '../../../utils/url';
import pageData from '../../../content/pages/observatorio/eje-de-participacion/cartillas.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'Eje de Participación', href: resolveUrl('/observatorio/eje-de-participacion') },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="cart-section">
    <div class="container">
      <div class="cart-grid">
        {pageData.cartillas.map((c) => (
          <a href={c.url} target="_blank" rel="noopener" class="cart-card">
            <div class="cart-card__image">
              <img src={c.imagen} alt={c.titulo} loading="lazy" />
              <div class="cart-card__overlay"><i class="fa-solid fa-file-pdf" aria-hidden="true"></i></div>
            </div>
            <div class="cart-card__body">
              <h3>{c.titulo}</h3>
              <span class="cart-card__cta"><i class="fa-solid fa-download" aria-hidden="true"></i> Descargar PDF</span>
            </div>
          </a>
        ))}
      </div>
      <div class="back-link"><a href={resolveUrl('/observatorio/eje-de-participacion')}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver al Eje de Participación</a></div>
    </div>
  </section>
</Base>

<style>
  .cart-section { padding: var(--space-10) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .cart-section .container { max-width: 1000px; margin: 0 auto; }
  .cart-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-5); }

  .cart-card { background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: var(--radius-xl); overflow: hidden; text-decoration: none; transition: all var(--transition-base); display: flex; flex-direction: column; }
  .cart-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--itrc-gold); }
  .cart-card__image { position: relative; aspect-ratio: 3/4; overflow: hidden; background: var(--theme-surface-alt); }
  .cart-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-base); }
  .cart-card:hover .cart-card__image img { transform: scale(1.05); }
  .cart-card__overlay { position: absolute; inset: 0; background: rgba(220,53,69,0.8); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity var(--transition-base); }
  .cart-card:hover .cart-card__overlay { opacity: 1; }
  .cart-card__overlay i { color: var(--white); font-size: var(--font-size-4xl); }

  .cart-card__body { padding: var(--space-4) var(--space-5); display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .cart-card__body h3 { font-size: var(--font-size-sm); font-weight: 800; color: var(--theme-heading); margin: 0; line-height: 1.4; flex: 1; }
  .cart-card__cta { font-size: var(--font-size-xs); color: var(--file-pdf); font-weight: 700; }

  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>
