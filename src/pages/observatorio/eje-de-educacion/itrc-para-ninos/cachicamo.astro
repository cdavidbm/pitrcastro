---
import Base from '../../../../layouts/Base.astro';
import HeroPage from '../../../../components/HeroPage.astro';
import { resolveUrl } from '../../../../utils/url';

// Contenido inline — cuando se decida modelar esto como single-type Strapi,
// mover a `observatorio-eje-de-educacion-cachicamo` con `getObservatorio*`.
const pageData = {
  title: 'La historia del Cachicamo',
  description: 'Un video animado para niños y niñas sobre el cuidado de los recursos públicos',
  icon: 'fa-otter',
  youtubeId: '8qIA_dbC6iw',
  descripcion:
    'Acompaña al Cachicamo en una aventura por el bosque colombiano y aprende con él por qué es tan importante cuidar los recursos públicos. Una historia hecha con cariño para niños, niñas y toda la familia.',
};

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'ITRC para Niños', href: resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos') },
  { label: pageData.title },
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage
    title={pageData.title}
    subtitle={pageData.description}
    icon={pageData.icon}
    breadcrumb={breadcrumb}
  />

  <section class="video-section">
    <div class="container">
      <p class="video-desc">{pageData.descripcion}</p>
      <div class="video-player">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${pageData.youtubeId}`}
          title={pageData.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        ></iframe>
      </div>
      <div class="back-link">
        <a href={resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos')}>
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          Volver a ITRC para Niños
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .video-section { padding: var(--space-10) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .video-section .container { max-width: 900px; margin: 0 auto; text-align: center; }
  .video-desc { font-size: var(--font-size-lg); line-height: 1.8; color: var(--theme-text); margin-bottom: var(--space-8); }
  .video-player { background: #000; border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-lg); aspect-ratio: 16/9; }
  .video-player iframe { width: 100%; height: 100%; display: block; border: 0; }
  .back-link { margin-top: var(--space-8); }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>
