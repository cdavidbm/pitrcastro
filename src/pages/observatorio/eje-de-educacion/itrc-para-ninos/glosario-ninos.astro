---
import Base from '../../../../layouts/Base.astro';
import HeroPage from '../../../../components/HeroPage.astro';
import { resolveUrl } from '../../../../utils/url';
import { getObservatorioEjeDeEducacionGlosarioNinos } from '../../../../utils/strapi-fetchers';
const pageData = await getObservatorioEjeDeEducacionGlosarioNinos();
const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'ITRC para Niños', href: resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos') },
  { label: pageData.title }
];

const palette = ['#e63946', '#f4a261', '#f6c453', '#2a9d8f', '#5b8def', '#9d4edd', '#0943b5', '#b38b40', '#198754', '#6f42c1'];
function colorFor(idx: number) {
  return palette[idx % palette.length];
}

const totalTerminos = pageData.terminos.length;
const conImagen = pageData.terminos.filter((t: any) => t.imagen).length;
---

<Base title={pageData.title} description={pageData.description} strapiSlug="observatorio-eje-de-educacion-glosario-ninos">
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="gn-section">
    <div class="container">
      <p class="gn-intro">{pageData.intro}</p>

      <div class="gn-meta">
        <span class="gn-meta__item"><i class="fa-solid fa-images" aria-hidden="true"></i> {conImagen} ilustradas</span>
        <span class="gn-meta__sep">·</span>
        <span class="gn-meta__item"><i class="fa-solid fa-book-open-reader" aria-hidden="true"></i> {totalTerminos} términos</span>
      </div>

      <div class="gn-search">
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        <input type="search" id="gnSearchInput" placeholder="Buscar un término..." aria-label="Buscar término" autocomplete="off" />
        <button type="button" class="gn-clear" id="gnClearBtn" aria-label="Limpiar búsqueda" hidden>
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </div>

      <div class="gn-gallery" id="gnGallery">
        {pageData.terminos.map((t: any, i: number) => {
          const accent = colorFor(i);
          const tipo = t.imagen ? 'imagen' : 'icono';
          return (
            <article
              class={`gn-card gn-card--${tipo}`}
              style={`--card-accent: ${accent}`}
              data-term={t.termino.toLowerCase()}
              tabindex="0"
            >
              {t.imagen ? (
                <img
                  class="gn-card__img"
                  src={resolveUrl(t.imagen)}
                  alt={`Ilustración: ${t.termino}`}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="gn-card__placeholder" aria-hidden="true">
                  <i class="fa-solid fa-book-open-reader"></i>
                  <span class="gn-card__placeholder-text">{t.termino}</span>
                </div>
              )}

              <div class="gn-card__overlay">
                <h3 class="gn-card__title">{t.termino}</h3>
                <p class="gn-card__def">{t.definicion}</p>
              </div>

              <div class="gn-card__label">
                <span>{t.termino}</span>
                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
              </div>
            </article>
          );
        })}
      </div>

      <p class="gn-empty" id="gnEmpty" hidden>
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        No encontramos ningún término. Prueba con otra palabra.
      </p>

      <div class="back-link">
        <a href={resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos')}>
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a ITRC para Niños
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .gn-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .gn-section .container { max-width: 1200px; margin: 0 auto; }

  .gn-intro { font-size: var(--font-size-lg); line-height: 1.8; color: var(--theme-text); text-align: center; margin: 0 auto var(--space-5); max-width: 820px; }

  .gn-meta { display: flex; justify-content: center; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); font-size: var(--font-size-sm); margin-bottom: var(--space-6); }
  .gn-meta__item i { color: var(--itrc-gold); margin-right: var(--space-1); }
  .gn-meta__sep { opacity: 0.5; }

  .gn-search {
    position: relative; max-width: 480px; margin: 0 auto var(--space-8);
  }
  .gn-search > i:first-child { position: absolute; left: var(--space-4); top: 50%; transform: translateY(-50%); color: var(--theme-text-muted); }
  .gn-search input {
    width: 100%; padding: var(--space-3) var(--space-10) var(--space-3) var(--space-10);
    border: 2px solid var(--theme-border); border-radius: var(--radius-full);
    background: var(--theme-surface); color: var(--theme-text);
    font-family: var(--font-family); font-size: var(--font-size-base);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .gn-search input:focus { outline: none; border-color: var(--itrc-gold); box-shadow: 0 0 0 4px color-mix(in srgb, var(--itrc-gold) 20%, transparent); }
  .gn-clear {
    position: absolute; right: var(--space-3); top: 50%; transform: translateY(-50%);
    width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center;
    border: none; background: var(--theme-surface-alt); color: var(--theme-text-muted);
    border-radius: 50%; cursor: pointer;
  }
  .gn-clear:hover { background: var(--itrc-gold); color: var(--itrc-navy); }
  .gn-clear[hidden] { display: none; }

  .gn-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .gn-card {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--theme-surface);
    border: 2px solid var(--card-accent);
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: pointer;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    outline: none;
  }
  .gn-card:hover, .gn-card:focus-visible { transform: translateY(-6px); box-shadow: var(--shadow-xl); }
  .gn-card:focus-visible { box-shadow: 0 0 0 4px color-mix(in srgb, var(--itrc-gold) 35%, transparent), var(--shadow-xl); }

  .gn-card__img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.5s ease, filter 0.4s ease;
  }
  .gn-card:hover .gn-card__img, .gn-card.is-active .gn-card__img { transform: scale(1.06); filter: blur(2px) brightness(0.55); }

  .gn-card__placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: var(--space-3); padding: var(--space-4);
    background: linear-gradient(135deg, var(--card-accent) 0%, color-mix(in srgb, var(--card-accent) 70%, #000 30%) 100%);
    color: var(--white);
    transition: opacity 0.3s ease;
  }
  .gn-card__placeholder i { font-size: 2.5rem; opacity: 0.85; }
  .gn-card__placeholder-text {
    font-size: var(--font-size-lg); font-weight: 800; text-align: center;
    line-height: 1.2; letter-spacing: 0.01em;
  }
  .gn-card:hover .gn-card__placeholder, .gn-card.is-active .gn-card__placeholder { opacity: 0.25; }

  .gn-card__label {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.55) 60%, transparent 100%);
    color: var(--white);
    display: flex; align-items: center; justify-content: space-between;
    font-weight: 800; font-size: var(--font-size-base);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .gn-card--icono .gn-card__label { background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 100%); }
  .gn-card__label i { font-size: var(--font-size-sm); opacity: 0.8; transition: transform var(--transition-fast); }
  .gn-card:hover .gn-card__label, .gn-card.is-active .gn-card__label { opacity: 0; transform: translateY(8px); }

  .gn-card__overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: center;
    padding: var(--space-5);
    background: linear-gradient(135deg, color-mix(in srgb, var(--card-accent) 92%, #000 8%) 0%, color-mix(in srgb, var(--card-accent) 75%, #000 25%) 100%);
    color: var(--white);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
    overflow-y: auto;
  }
  .gn-card:hover .gn-card__overlay,
  .gn-card:focus-visible .gn-card__overlay,
  .gn-card.is-active .gn-card__overlay {
    opacity: 1;
    transform: translateY(0);
  }
  .gn-card__title {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-lg);
    font-weight: 800;
    line-height: 1.2;
  }
  .gn-card__def {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: rgba(255,255,255,0.95);
  }

  .gn-empty {
    text-align: center; color: var(--theme-text-muted);
    padding: var(--space-8) var(--space-4);
    font-size: var(--font-size-base);
  }
  .gn-empty i { color: var(--itrc-gold); margin-right: var(--space-2); }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  .gn-card[hidden] { display: none; }

  @media (max-width: 768px) {
    .gn-section { padding: var(--space-6) var(--space-4) var(--space-12); }
    .gn-gallery { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: var(--space-3); }
    .gn-card__title { font-size: var(--font-size-base); }
    .gn-card__def { font-size: var(--font-size-xs); line-height: 1.45; }
    .gn-card__placeholder i { font-size: 1.8rem; }
    .gn-card__placeholder-text { font-size: var(--font-size-base); }
    .gn-card__label { padding: var(--space-2) var(--space-3); font-size: var(--font-size-sm); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gn-card, .gn-card__img, .gn-card__overlay, .gn-card__label, .gn-card__placeholder {
      transition: none !important;
    }
    .gn-card:hover .gn-card__img, .gn-card.is-active .gn-card__img { transform: none; }
  }
</style>

<script>
  function initGlosarioGallery() {
    const input = document.getElementById('gnSearchInput') as HTMLInputElement | null;
    const clear = document.getElementById('gnClearBtn') as HTMLButtonElement | null;
    const empty = document.getElementById('gnEmpty');
    const gallery = document.getElementById('gnGallery');
    if (!input || !gallery) return;

    const cards = Array.from(gallery.querySelectorAll<HTMLElement>('.gn-card'));

    function applyFilter() {
      const q = (input!.value || '').trim().toLowerCase();
      let shown = 0;
      cards.forEach(card => {
        const t = card.dataset.term || '';
        const match = q === '' || t.includes(q);
        card.hidden = !match;
        if (match) shown++;
      });
      if (clear) clear.hidden = q === '';
      if (empty) empty.hidden = shown !== 0;
    }

    input.addEventListener('input', applyFilter);
    clear?.addEventListener('click', () => {
      input.value = '';
      applyFilter();
      input.focus();
    });

    // Touch/click toggle: en móvil sin hover, una pulsación abre el overlay,
    // una segunda navega/cierra. También permite enfocarse y leer con teclado.
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const isCoarse = window.matchMedia('(hover: none)').matches;
        if (!isCoarse) return;
        if (!card.classList.contains('is-active')) {
          cards.forEach(c => c.classList.remove('is-active'));
          card.classList.add('is-active');
          e.preventDefault?.();
        } else {
          card.classList.remove('is-active');
        }
      });
      card.addEventListener('keydown', (e) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') {
          ke.preventDefault();
          card.classList.toggle('is-active');
        }
        if (ke.key === 'Escape') card.classList.remove('is-active');
      });
    });

    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest('.gn-card')) {
        cards.forEach(c => c.classList.remove('is-active'));
      }
    });
  }
  initGlosarioGallery();
  document.addEventListener('astro:after-swap', initGlosarioGallery);
</script>
