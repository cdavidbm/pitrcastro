---
import Base from '../../../../layouts/Base.astro';
import HeroPage from '../../../../components/HeroPage.astro';
import { resolveUrl } from '../../../../utils/url';
import { getObservatorioEjeDeEducacionLibroInfantil } from '../../../../utils/strapi-fetchers';
const pageData = await getObservatorioEjeDeEducacionLibroInfantil();
const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'ITRC para Niños', href: resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos') },
  { label: pageData.title }
];
const pdfHref = resolveUrl(pageData.pdfUrl);
---

<Base title={pageData.title} description={pageData.description} strapiSlug="observatorio-eje-de-educacion-libro-infantil">
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="libro-section">
    <div class="container">
      <div class="libro-actions">
        <a href={pdfHref} download class="libro-btn libro-btn--primary">
          <i class="fa-solid fa-download" aria-hidden="true"></i>
          <span>Descargar PDF</span>
          <small>{pageData.pdfSize} · {pageData.pdfPaginas} páginas</small>
        </a>
        <a href={pdfHref} target="_blank" rel="noopener" class="libro-btn libro-btn--secondary">
          <i class="fa-solid fa-up-right-from-square" aria-hidden="true"></i>
          <span>Abrir en pestaña nueva</span>
        </a>
      </div>

      <div class="libro-embed">
        <iframe src={`${pdfHref}#view=FitH`} title={pageData.title} loading="lazy"></iframe>
      </div>

      <p class="libro-help">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        Si el visor no carga en tu dispositivo, usa el botón <strong>Descargar PDF</strong> para verlo sin conexión.
      </p>

      <div class="back-link">
        <a href={resolveUrl('/observatorio/eje-de-educacion/itrc-para-ninos')}>
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a ITRC para Niños
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .libro-section { padding: var(--space-8) var(--space-4) var(--space-12); background: var(--theme-surface); }
  .libro-section .container { max-width: 1100px; margin: 0 auto; }

  .libro-actions {
    display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center;
    margin-bottom: var(--space-6);
  }
  .libro-btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-full); text-decoration: none; font-weight: 700;
    font-size: var(--font-size-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
  }
  .libro-btn small { font-weight: 500; opacity: 0.85; font-size: var(--font-size-xs); margin-left: var(--space-1); }
  .libro-btn--primary { background: var(--itrc-gold); color: var(--itrc-navy); box-shadow: var(--shadow-md); }
  .libro-btn--primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .libro-btn--secondary {
    background: transparent; color: var(--theme-heading);
    border: 2px solid var(--theme-border);
  }
  .libro-btn--secondary:hover { background: var(--theme-surface-alt); border-color: var(--itrc-gold); color: var(--itrc-navy); }

  .libro-embed {
    position: relative; width: 100%; padding-bottom: 130%;
    background: var(--theme-surface-alt); border-radius: var(--radius-xl);
    overflow: hidden; box-shadow: var(--shadow-xl);
  }
  .libro-embed iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

  .libro-help {
    margin-top: var(--space-4); text-align: center;
    font-size: var(--font-size-sm); color: var(--theme-text-secondary);
  }
  .libro-help i { color: var(--itrc-gold); margin-right: var(--space-1); }

  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 768px) {
    .libro-embed { padding-bottom: 140%; }
    .libro-btn { width: 100%; justify-content: center; }
  }
</style>
