---
import Base from '../../../layouts/Base.astro';
import HeroPage from '../../../components/HeroPage.astro';
import { resolveUrl } from '../../../utils/url';
import { getObservatorioEjeDeEducacionItrcParaNinos } from '../../../utils/strapi-fetchers';
const pageData: any = (await getObservatorioEjeDeEducacionItrcParaNinos()) ?? {};
const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'Eje de Educación', href: resolveUrl('/observatorio/eje-de-educacion') },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description} strapiSlug="observatorio-eje-de-educacion-itrc-para-ninos">
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="ninos-section" id="ninosRoot">
    <div class="container">
      <div class="ninos-toolbar">
        <button type="button" class="ninos-paint" id="ninosPaintBtn" aria-expanded="false" aria-controls="ninosPaintPanel">
          <i class="fa-solid fa-palette" aria-hidden="true"></i>
          <span>Personaliza los colores</span>
        </button>

        <div class="ninos-paint-panel" id="ninosPaintPanel" hidden>
          <p class="ninos-paint-panel__title">Elige tu tema favorito:</p>
          <div class="ninos-paint-themes" role="radiogroup" aria-label="Tema de colores">
            <button type="button" class="paint-theme" data-theme="default" aria-label="Tema institucional" aria-checked="true"
              style="--p1:#002147;--p2:#b38b40;--p3:#0943b5"></button>
            <button type="button" class="paint-theme" data-theme="rainbow" aria-label="Arcoíris" aria-checked="false"
              style="--p1:#e63946;--p2:#f6c453;--p3:#2a9d8f"></button>
            <button type="button" class="paint-theme" data-theme="ocean" aria-label="Océano" aria-checked="false"
              style="--p1:#1d3557;--p2:#48cae4;--p3:#caf0f8"></button>
            <button type="button" class="paint-theme" data-theme="jungle" aria-label="Selva" aria-checked="false"
              style="--p1:#386641;--p2:#a7c957;--p3:#f2e8cf"></button>
            <button type="button" class="paint-theme" data-theme="space" aria-label="Espacio" aria-checked="false"
              style="--p1:#22223b;--p2:#9d4edd;--p3:#f72585"></button>
            <button type="button" class="paint-theme" data-theme="candy" aria-label="Caramelo" aria-checked="false"
              style="--p1:#ff70a6;--p2:#ff9770;--p3:#ffd670"></button>
          </div>
          <button type="button" class="paint-reset" id="ninosPaintReset">
            <i class="fa-solid fa-rotate-left" aria-hidden="true"></i> Volver al original
          </button>
        </div>
      </div>

      <p class="ninos-intro">{pageData.intro}</p>

      <div class="ninos-grid">
        {pageData.secciones.map((sec) => (
          <a
            href={sec.externo ? sec.url : resolveUrl(sec.url)}
            target={sec.externo ? '_blank' : undefined}
            rel={sec.externo ? 'noopener' : undefined}
            class="ninos-card"
            style={`--card-accent: ${sec.color}`}
            data-card-original={sec.color}
          >
            <div class="ninos-card__icon"><i class={`fa-solid ${sec.icon}`} aria-hidden="true"></i></div>
            <h3 class="ninos-card__title">{sec.titulo}</h3>
            <p class="ninos-card__desc">{sec.descripcion}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .ninos-section { padding: var(--space-10) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .ninos-section .container { max-width: 1000px; margin: 0 auto; }
  .ninos-intro { font-size: var(--font-size-lg); line-height: 1.8; color: var(--theme-text); text-align: center; margin-bottom: var(--space-10); }

  /* V-11: Toolbar con botón "Personaliza colores" */
  .ninos-toolbar { display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); margin-bottom: var(--space-6); }
  .ninos-paint {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--theme-surface); color: var(--theme-heading);
    border: 2px solid var(--itrc-gold); border-radius: var(--radius-full);
    font-family: var(--font-family); font-size: var(--font-size-sm); font-weight: 700;
    cursor: pointer; transition: all var(--transition-fast);
  }
  .ninos-paint:hover { background: var(--itrc-gold); color: var(--itrc-navy); }
  .ninos-paint i { color: var(--itrc-gold); transition: color var(--transition-fast); }
  .ninos-paint:hover i { color: var(--itrc-navy); }

  .ninos-paint-panel {
    width: 100%; max-width: 360px;
    padding: var(--space-4); background: var(--theme-surface);
    border: 1px solid var(--theme-border); border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .ninos-paint-panel[hidden] { display: none; }
  .ninos-paint-panel__title { margin: 0; font-size: var(--font-size-sm); color: var(--theme-text-secondary); font-weight: 600; }

  .ninos-paint-themes { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; }
  .paint-theme {
    width: 56px; height: 56px; border-radius: 50%; cursor: pointer;
    border: 3px solid var(--theme-surface); padding: 0;
    background: linear-gradient(135deg, var(--p1) 0% 33%, var(--p2) 33% 66%, var(--p3) 66% 100%);
    box-shadow: 0 0 0 1px var(--theme-border);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }
  .paint-theme:hover { transform: scale(1.1); }
  .paint-theme[aria-checked="true"] { box-shadow: 0 0 0 3px var(--itrc-gold); }

  .paint-reset {
    align-self: center;
    background: transparent; color: var(--theme-text-muted);
    border: none; padding: var(--space-1) var(--space-3);
    font-family: var(--font-family); font-size: var(--font-size-xs); cursor: pointer;
    display: inline-flex; align-items: center; gap: var(--space-1);
  }
  .paint-reset:hover { color: var(--itrc-gold); }

  /* Pattern sutil de puntos en el fondo de la sección NNA — guiño visual sin
     romper la coherencia con el resto del sitio */
  .ninos-section {
    background-image: radial-gradient(circle at 1px 1px, color-mix(in srgb, var(--itrc-gold) 12%, transparent) 1px, transparent 0);
    background-size: 32px 32px;
    background-position: 0 0;
  }

  .ninos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-5); }

  .ninos-card {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: var(--space-8) var(--space-5);
    background: var(--theme-surface);
    border: 2px solid var(--card-accent);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: transform var(--transition-base), box-shadow var(--transition-base), background var(--transition-base);
  }
  .ninos-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-xl); background: var(--card-accent); }

  .ninos-card__icon {
    width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    background: var(--card-accent); color: var(--white);
    border-radius: var(--radius-full);
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-4);
    transition: transform var(--transition-base), background var(--transition-base), color var(--transition-base);
  }
  .ninos-card:hover .ninos-card__icon {
    background: var(--white); color: var(--card-accent);
  }

  /* === Huevo de pascua: 8 animaciones distintas por card según posición === */
  .ninos-card:nth-child(1):hover .ninos-card__icon { animation: ninos-wiggle 0.7s ease; }
  .ninos-card:nth-child(2):hover .ninos-card__icon { animation: ninos-flip 0.7s ease; }
  .ninos-card:nth-child(3):hover .ninos-card__icon { animation: ninos-jelly 0.8s ease; }
  .ninos-card:nth-child(4):hover .ninos-card__icon { animation: ninos-swing 0.9s ease; }
  .ninos-card:nth-child(5):hover .ninos-card__icon { animation: ninos-pop 0.5s ease; }
  .ninos-card:nth-child(6):hover .ninos-card__icon { animation: ninos-tilt 0.7s ease; }
  .ninos-card:nth-child(7):hover .ninos-card__icon { animation: ninos-heartbeat 0.9s ease; }
  .ninos-card:nth-child(8):hover .ninos-card__icon { animation: ninos-spin 0.9s ease; }

  /* Cards 9+ (por si crece el grid): cae al bounce clasico */
  .ninos-card:nth-child(n+9):hover .ninos-card__icon { animation: ninos-bounce 0.6s ease; }

  @keyframes ninos-wiggle {
    0%, 100% { transform: rotate(0) scale(1.05); }
    20% { transform: rotate(-12deg) scale(1.08); }
    40% { transform: rotate(10deg) scale(1.08); }
    60% { transform: rotate(-8deg) scale(1.08); }
    80% { transform: rotate(6deg) scale(1.08); }
  }
  @keyframes ninos-flip {
    0% { transform: perspective(400px) rotateY(0) scale(1); }
    50% { transform: perspective(400px) rotateY(180deg) scale(1.05); }
    100% { transform: perspective(400px) rotateY(360deg) scale(1.05); }
  }
  @keyframes ninos-jelly {
    0% { transform: scale(1, 1); }
    25% { transform: scale(1.28, 0.75); }
    45% { transform: scale(0.75, 1.28); }
    65% { transform: scale(1.15, 0.9); }
    85% { transform: scale(0.95, 1.05); }
    100% { transform: scale(1.05, 1.05); }
  }
  @keyframes ninos-swing {
    0%, 100% { transform: rotate(0) scale(1.05); }
    15% { transform: rotate(-18deg) scale(1.05); transform-origin: top center; }
    30% { transform: rotate(14deg) scale(1.05); transform-origin: top center; }
    45% { transform: rotate(-10deg) scale(1.05); transform-origin: top center; }
    60% { transform: rotate(6deg) scale(1.05); transform-origin: top center; }
    80% { transform: rotate(-3deg) scale(1.05); transform-origin: top center; }
  }
  @keyframes ninos-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.35); }
    100% { transform: scale(1.08); }
  }
  @keyframes ninos-tilt {
    0% { transform: perspective(400px) rotateX(0) rotateY(0) scale(1); }
    30% { transform: perspective(400px) rotateX(20deg) rotateY(-20deg) scale(1.1); }
    60% { transform: perspective(400px) rotateX(-15deg) rotateY(15deg) scale(1.08); }
    100% { transform: perspective(400px) rotateX(0) rotateY(0) scale(1.05); }
  }
  @keyframes ninos-heartbeat {
    0%, 100% { transform: scale(1.05); }
    20% { transform: scale(1.3); }
    35% { transform: scale(1.05); }
    50% { transform: scale(1.25); }
    70% { transform: scale(1.05); }
  }
  @keyframes ninos-spin {
    0% { transform: rotate(0) scale(1); }
    100% { transform: rotate(360deg) scale(1.08); }
  }
  @keyframes ninos-bounce {
    0%   { transform: scale(1) rotate(0); }
    30%  { transform: scale(1.18) rotate(-8deg); }
    55%  { transform: scale(0.95) rotate(4deg); }
    80%  { transform: scale(1.08) rotate(-2deg); }
    100% { transform: scale(1.1) rotate(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ninos-card:hover .ninos-card__icon { animation: none !important; transform: scale(1.1); }
  }

  .ninos-card__title { font-size: var(--font-size-lg); font-weight: 800; color: var(--theme-heading); margin: 0 0 var(--space-2); }
  .ninos-card:hover .ninos-card__title { color: var(--white); }

  .ninos-card__desc { font-size: var(--font-size-sm); line-height: 1.55; color: var(--theme-text-secondary); margin: 0; }
  .ninos-card:hover .ninos-card__desc { color: rgba(255,255,255,0.92); }

  /* === Icono del hero: cursor pointer — invita a clickearlo para descubrir
        el huevo de pascua === */
  :global(.hero-page__icon) { cursor: pointer; user-select: none; }
  :global(.hero-page__icon):hover { transform: scale(1.08); transition: transform 0.2s ease; }

  /* === Confeti (huevo de pascua) === */
  :global(.ninos-confetti) {
    position: fixed;
    top: -60px;
    font-size: 2rem;
    pointer-events: none;
    z-index: 9999;
    animation: ninos-confetti-fall 3s cubic-bezier(0.4, 0.6, 0.6, 1) forwards;
    user-select: none;
  }
  @keyframes ninos-confetti-fall {
    0%   { top: -60px; opacity: 1; transform: translateX(0) rotate(0); }
    100% { top: 110vh; opacity: 0.8; transform: translateX(var(--drift, 40px)) rotate(720deg); }
  }

  /* === Toast (huevo de pascua) === */
  :global(.ninos-toast) {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    background: linear-gradient(135deg, var(--itrc-navy) 0%, #4a2fa8 100%);
    color: var(--white);
    padding: 12px 24px;
    border-radius: var(--radius-full);
    font-weight: 700;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
    z-index: 10000;
    animation: ninos-toast-in 3.2s ease forwards;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--font-size-sm);
  }
  :global(.ninos-toast) i { color: var(--itrc-gold); }
  @keyframes ninos-toast-in {
    0%   { transform: translateX(-50%) translateY(120%); opacity: 0; }
    10%, 85% { transform: translateX(-50%) translateY(0); opacity: 1; }
    100% { transform: translateX(-50%) translateY(120%); opacity: 0; }
  }

  /* === Modo fiesta (activado por Konami o 15 clicks) === */
  :global(body.ninos-fiesta) .ninos-card {
    animation: ninos-fiesta-card 1.2s ease infinite alternate;
  }
  :global(body.ninos-fiesta) .ninos-card:nth-child(2n) { animation-delay: 0.15s; }
  :global(body.ninos-fiesta) .ninos-card:nth-child(3n) { animation-delay: 0.3s; }
  :global(body.ninos-fiesta) .ninos-card:nth-child(5n) { animation-delay: 0.45s; }
  @keyframes ninos-fiesta-card {
    0%   { transform: translateY(0) rotate(-1.5deg); }
    100% { transform: translateY(-6px) rotate(1.5deg); }
  }
  :global(body.ninos-fiesta) .ninos-section {
    background-image:
      radial-gradient(circle at 20% 30%, rgba(230,57,70,0.05) 0, transparent 40%),
      radial-gradient(circle at 80% 60%, rgba(157,78,221,0.05) 0, transparent 40%),
      radial-gradient(circle at 1px 1px, color-mix(in srgb, var(--itrc-gold) 12%, transparent) 1px, transparent 0);
    background-size: 100% 100%, 100% 100%, 32px 32px;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.ninos-confetti), :global(.ninos-toast) { animation: none; }
    :global(.ninos-confetti) { display: none; }
    :global(body.ninos-fiesta) .ninos-card { animation: none; }
  }
</style>

<script>
  function initNinosPaint() {
    const STORAGE_KEY = 'itrc-ninos-theme';
    const btn = document.getElementById('ninosPaintBtn');
    const panel = document.getElementById('ninosPaintPanel');
    const reset = document.getElementById('ninosPaintReset');
    const themes = document.querySelectorAll<HTMLButtonElement>('.paint-theme');
    const cards = document.querySelectorAll<HTMLElement>('.ninos-card');
    if (!btn || !panel) return;

    const palettes: Record<string, string[]> = {
      default: [],
      rainbow: ['#e63946', '#f6c453', '#2a9d8f', '#5b8def', '#9d4edd'],
      ocean:   ['#1d3557', '#48cae4', '#0077b6', '#00b4d8', '#caf0f8'],
      jungle:  ['#386641', '#6a994e', '#a7c957', '#bc6c25', '#dda15e'],
      space:   ['#22223b', '#4a4e69', '#9d4edd', '#f72585', '#7209b7'],
      candy:   ['#ff70a6', '#ff9770', '#ffd670', '#a0e8af', '#5fa8d3'],
    };

    function applyTheme(name: string) {
      const palette = palettes[name];
      cards.forEach((card, i) => {
        if (!palette || palette.length === 0) {
          const original = card.dataset.cardOriginal || '';
          card.style.setProperty('--card-accent', original);
        } else {
          card.style.setProperty('--card-accent', palette[i % palette.length]);
        }
      });
      themes.forEach(t => {
        t.setAttribute('aria-checked', t.dataset.theme === name ? 'true' : 'false');
      });
    }

    btn.addEventListener('click', () => {
      const isOpen = !panel.hasAttribute('hidden');
      if (isOpen) panel.setAttribute('hidden', '');
      else panel.removeAttribute('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    themes.forEach(t => {
      t.addEventListener('click', () => {
        const name = t.dataset.theme || 'default';
        applyTheme(name);
        try { localStorage.setItem(STORAGE_KEY, name); } catch {}
      });
    });

    reset?.addEventListener('click', () => {
      applyTheme('default');
      try { localStorage.removeItem(STORAGE_KEY); } catch {}
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved && palettes[saved]) applyTheme(saved);
    } catch {}
  }
  initNinosPaint();
  document.addEventListener('astro:after-swap', initNinosPaint);

  // ================================================================
  //  Huevos de pascua — solo en /observatorio/.../itrc-para-ninos
  //  1) Click contador en el icono del hero (5 = confeti, 15 = fiesta)
  //  2) Konami code (↑↑↓↓←→←→BA) = fiesta instantánea
  // ================================================================
  function initNinosEasterEggs() {
    // Guardia: solo montar en el listing (busca el grid como marcador)
    if (!document.getElementById('ninosRoot')) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---------- Emoji confetti ----------
    const emojis = ['🎉', '✨', '🌟', '⭐', '🎊', '💫', '🎈', '🌈', '🦋'];
    function dispararConfeti(n: number) {
      if (prefersReducedMotion) return;
      for (let i = 0; i < n; i++) {
        const e = document.createElement('span');
        e.textContent = emojis[Math.floor(Math.random() * emojis.length)];
        e.className = 'ninos-confetti';
        e.style.left = Math.random() * 100 + '%';
        e.style.animationDelay = (Math.random() * 0.5) + 's';
        e.style.setProperty('--drift', ((Math.random() - 0.5) * 240) + 'px');
        e.style.fontSize = (1.4 + Math.random() * 1.4) + 'rem';
        document.body.appendChild(e);
        window.setTimeout(() => e.remove(), 3500);
      }
    }

    // ---------- Toast ----------
    function mostrarToast(mensaje: string, icon = 'fa-star') {
      const existing = document.querySelector('.ninos-toast');
      if (existing) existing.remove();
      const t = document.createElement('div');
      t.className = 'ninos-toast';
      t.innerHTML = `<i class="fa-solid ${icon}"></i><span>${mensaje}</span>`;
      document.body.appendChild(t);
      window.setTimeout(() => t.remove(), 3500);
    }

    // ---------- Modo fiesta ----------
    let fiestaTimeout: number | null = null;
    function activarModoFiesta(duracion = 8000, mensaje = '¡Modo fiesta activado!') {
      document.body.classList.add('ninos-fiesta');
      dispararConfeti(35);
      mostrarToast(mensaje, 'fa-party-horn');
      if (fiestaTimeout) window.clearTimeout(fiestaTimeout);
      fiestaTimeout = window.setTimeout(() => {
        document.body.classList.remove('ninos-fiesta');
      }, duracion);
    }

    // ---------- Click contador en icon del hero ----------
    const heroIcon = document.querySelector<HTMLElement>('.hero-page__icon');
    if (heroIcon) {
      let count = 0;
      heroIcon.setAttribute('title', 'Click aquí varias veces...');
      heroIcon.addEventListener('click', () => {
        count++;
        if (count === 5)  { dispararConfeti(15); mostrarToast('¡Encontraste un secreto!', 'fa-star'); }
        if (count === 10) { dispararConfeti(25); mostrarToast('¡Sigues explorando! Estás cerca...', 'fa-wand-magic-sparkles'); }
        if (count === 15) { activarModoFiesta(10000, '¡Modo fiesta desbloqueado!'); count = 0; }
      });
    }

    // ---------- Konami code ----------
    const konami = [
      'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
      'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
      'b', 'a',
    ];
    let seq: string[] = [];
    document.addEventListener('keydown', (e) => {
      seq.push(e.key.length === 1 ? e.key.toLowerCase() : e.key);
      if (seq.length > konami.length) seq = seq.slice(-konami.length);
      if (seq.length === konami.length && seq.every((k, i) => k === konami[i])) {
        activarModoFiesta(12000, '¡Konami code! Eres un explorador legendario');
        seq = [];
      }
    });

    // ---------- Bonus: mover el mouse a la esquina superior derecha
    //           dispara un mini confeti ("secret zone") ----------
    let secretZoneHits = 0;
    let secretZoneTimer: number | null = null;
    document.addEventListener('mousemove', (e) => {
      if (e.clientX > window.innerWidth - 40 && e.clientY < 40) {
        secretZoneHits++;
        if (secretZoneTimer) window.clearTimeout(secretZoneTimer);
        secretZoneTimer = window.setTimeout(() => { secretZoneHits = 0; }, 800);
        if (secretZoneHits > 6) {
          dispararConfeti(8);
          secretZoneHits = 0;
        }
      }
    });
  }

  initNinosEasterEggs();
  document.addEventListener('astro:after-swap', initNinosEasterEggs);
</script>
