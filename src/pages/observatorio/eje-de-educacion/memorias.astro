---
import Base from '../../../layouts/Base.astro';
import HeroPage from '../../../components/HeroPage.astro';
import { resolveUrl } from '../../../utils/url';
import { getObservatorioEjeDeEducacionMemoriasInfo } from '../../../utils/strapi-fetchers';
import memoriasLocal from '../../../content/pages/observatorio/eje-de-educacion/memorias.json';
const remote: any = await getObservatorioEjeDeEducacionMemoriasInfo().catch(() => null);
const pageData: any = remote ?? memoriasLocal;
// Complementar con campos del JSON local que Strapi aún no expone (ej. dashboard)
if (remote && !remote.dashboard && (memoriasLocal as any).dashboard) {
  pageData.dashboard = (memoriasLocal as any).dashboard;
}
const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Observatorio', href: resolveUrl('/observatorio') },
  { label: 'Eje de Educación', href: resolveUrl('/observatorio/eje-de-educacion') },
  { label: pageData.title }
];
const totalMemorias = pageData.anios.reduce((s, a) => s + a.entradas.length, 0);
---

<Base title={pageData.title} description={pageData.description} strapiSlug="observatorio-eje-de-educacion-memorias-info">
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="mem-section">
    <div class="container">
      <div class="mem-count"><i class="fa-solid fa-photo-film" aria-hidden="true"></i> {totalMemorias} memorias</div>

      {pageData.dashboard && (
        <a href={pageData.dashboard.url} target="_blank" rel="noopener" class="mem-dashboard">
          <div class="mem-dashboard__icon">
            <i class={`fa-solid ${pageData.dashboard.icon || 'fa-chart-bar'}`} aria-hidden="true"></i>
          </div>
          <div class="mem-dashboard__body">
            <h3>{pageData.dashboard.titulo}</h3>
            <p>{pageData.dashboard.descripcion}</p>
          </div>
          <span class="mem-dashboard__cta">
            Abrir en Power BI <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
          </span>
        </a>
      )}

      <div class="mem-tabs" role="tablist">
        {pageData.anios.map((g, i) => (
          <button class={`mem-tab ${i === 0 ? 'active' : ''}`} role="tab" data-tab={g.anio}>
            {g.anio}<span class="mem-tab__count">{g.entradas.length}</span>
          </button>
        ))}
      </div>

      {pageData.anios.map((g, i) => (
        <div class={`mem-panel ${i === 0 ? 'active' : ''}`} id={`panel-${g.anio}`} hidden={i !== 0}>
          <div class="mem-grid">
            {g.entradas.map((m) => {
              const card = (
                <>
                  <div class="mem-card__image">
                    <img src={resolveUrl(m.imagen, m.imagen.startsWith('http'))} alt={m.titulo} loading="lazy" />
                  </div>
                  <div class="mem-card__body">
                    <h3>{m.titulo}</h3>
                    <span class="mem-card__date"><i class="fa-regular fa-calendar" aria-hidden="true"></i> {m.fecha}</span>
                  </div>
                </>
              );
              return m.url ? (
                <a class="mem-card" href={resolveUrl(m.url)} aria-label={`Ver memoria: ${m.titulo}`}>{card}</a>
              ) : (
                <article class="mem-card">{card}</article>
              );
            })}
          </div>
        </div>
      ))}

      <div class="back-link"><a href={resolveUrl('/observatorio/eje-de-educacion')}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver al Eje de Educación</a></div>
    </div>
  </section>
</Base>

<style>
  .mem-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .mem-section .container { max-width: 1100px; margin: 0 auto; }
  .mem-count { display: flex; align-items: center; justify-content: center; gap: var(--space-2); font-size: var(--font-size-sm); font-weight: 700; color: var(--itrc-gold); margin-bottom: var(--space-6); }
  .mem-dashboard { display: grid; grid-template-columns: auto 1fr auto; gap: var(--space-4); align-items: center; padding: var(--space-5) var(--space-6); margin-bottom: var(--space-6); background: linear-gradient(135deg, var(--itrc-navy, #002147), #0943b5); color: #fff; border-radius: var(--radius-lg); text-decoration: none; box-shadow: 0 10px 24px rgba(0, 33, 71, 0.2); transition: transform var(--transition-base), box-shadow var(--transition-base); }
  .mem-dashboard:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(0, 33, 71, 0.3); }
  .mem-dashboard__icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, 0.15); border-radius: 50%; font-size: 1.6rem; color: var(--itrc-gold); }
  .mem-dashboard__body h3 { margin: 0 0 var(--space-1); font-size: var(--font-size-lg); color: #fff; }
  .mem-dashboard__body p { margin: 0; font-size: var(--font-size-sm); color: rgba(255, 255, 255, 0.85); }
  .mem-dashboard__cta { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); background: var(--itrc-gold); color: var(--itrc-navy); border-radius: var(--radius-full, 999px); font-weight: 700; font-size: var(--font-size-sm); white-space: nowrap; }
  @media (max-width: 640px) {
    .mem-dashboard { grid-template-columns: 1fr; text-align: center; }
    .mem-dashboard__icon { margin: 0 auto; }
    .mem-dashboard__cta { justify-self: center; }
  }

  .mem-tabs { display: flex; gap: var(--space-1); flex-wrap: wrap; margin-bottom: var(--space-6); border-bottom: 2px solid var(--theme-border); padding-bottom: var(--space-2); }
  .mem-tab { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); border: 1px solid transparent; border-radius: var(--radius-lg) var(--radius-lg) 0 0; background: transparent; color: var(--theme-text-secondary); font-size: var(--font-size-sm); font-weight: 600; font-family: var(--font-family); cursor: pointer; transition: all var(--transition-fast); }
  .mem-tab:hover { background: var(--theme-surface-alt); color: var(--itrc-gold); }
  .mem-tab.active { background: var(--theme-surface-alt); color: var(--itrc-gold); border-color: var(--theme-border); border-bottom-color: var(--theme-surface-alt); font-weight: 800; }
  .mem-tab__count { padding: 1px 7px; background: var(--theme-surface-alt); border-radius: var(--radius-full); font-size: var(--font-size-xs); color: var(--theme-text-muted); }
  .mem-tab.active .mem-tab__count { background: rgba(var(--itrc-gold-rgb), 0.15); color: var(--itrc-gold); }

  .mem-panel { display: none; }
  .mem-panel.active { display: block; }

  .mem-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-5); }

  .mem-card { background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-xl); overflow: hidden; transition: all var(--transition-base); display: block; color: inherit; text-decoration: none; }
  a.mem-card:hover, a.mem-card:focus-visible { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: var(--itrc-gold); outline: none; }
  .mem-card__image { aspect-ratio: 16/10; overflow: hidden; background: var(--theme-surface-alt); }
  .mem-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--transition-base); }
  .mem-card:hover .mem-card__image img { transform: scale(1.05); }
  .mem-card__body { padding: var(--space-4) var(--space-5); }
  .mem-card__body h3 { font-size: var(--font-size-sm); font-weight: 700; color: var(--theme-heading); margin: 0 0 var(--space-2); line-height: 1.4; }
  .mem-card__date { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--font-size-xs); color: var(--theme-text-muted); }

  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>

<script>
  function initMemTabs() {
    const tabs = document.querySelectorAll('.mem-tab');
    const panels = document.querySelectorAll('.mem-panel');
    tabs.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.tab;
        tabs.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        panels.forEach(p => { const a = p.id === `panel-${id}`; p.classList.toggle('active', a); (p as HTMLElement).hidden = !a; });
      });
    });
  }
  initMemTabs();
  document.addEventListener('astro:after-swap', initMemTabs);
</script>
