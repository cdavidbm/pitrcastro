---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';
const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Informes a Organismos de Control' }];
const enlaces = [
  { nombre: 'Rendición de Cuenta Fiscal a la Contraloría General', url: '/informe-rendicion-cuenta-contraloria', icon: 'fa-landmark' },
  { nombre: 'Informe de Gestión Institucional', url: '/agencia/direccionamiento-estrategico/informes', icon: 'fa-chart-bar' },
  { nombre: 'Informe de Rendición de Cuentas', url: '/participa/rendicion-de-cuentas', icon: 'fa-file-contract' },
];
---
<Base title="Informes a Organismos de Inspección, Vigilancia y Control" description="Informes a organismos de inspección, vigilancia y control">
  <HeroPage title="Informes a Organismos de Control" subtitle="Inspección, vigilancia y control" icon="fa-building-shield" breadcrumb={breadcrumb} />
  <section class="org-page"><div class="container">
    <div class="org-links">{enlaces.map((e) => (
      <a href={resolveUrl(e.url)} class="org-link"><div class="org-link__icon"><i class={`fa-solid ${e.icon}`} aria-hidden="true"></i></div><span>{e.nombre}</span><i class="fa-solid fa-chevron-right" aria-hidden="true"></i></a>
    ))}</div>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.org-page{padding:var(--space-10) var(--space-6) var(--space-16);background:var(--theme-surface)}.org-page .container{max-width:750px;margin:0 auto}.org-links{display:flex;flex-direction:column;gap:var(--space-4)}.org-link{display:flex;align-items:center;gap:var(--space-4);padding:var(--space-5) var(--space-6);border:1px solid var(--theme-border);border-radius:var(--radius-xl);text-decoration:none;transition:all var(--transition-base)}.org-link:hover{border-color:var(--itrc-gold);box-shadow:var(--shadow-md);transform:translateY(-2px)}.org-link__icon{width:48px;height:48px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(var(--itrc-gold-rgb),0.1);border-radius:var(--radius-lg);color:var(--itrc-gold);font-size:var(--font-size-xl);transition:all var(--transition-base)}.org-link:hover .org-link__icon{background:var(--itrc-gold);color:var(--white)}.org-link span{flex:1;font-size:var(--font-size-base);font-weight:700;color:var(--theme-heading)}.org-link:hover span{color:var(--itrc-gold)}.org-link>i:last-child{color:var(--theme-text-muted);opacity:0.4}.back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
