---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: 'Procedimientos para tomar decisiones' }
];
---

<Base title="Procedimientos que se siguen para tomar decisiones" description="Procedimientos para la toma de decisiones en las diferentes áreas de la Agencia ITRC">
  <HeroPage title="Procedimientos para tomar decisiones" subtitle="Procesos y procedimientos en las diferentes áreas" icon="fa-diagram-project" breadcrumb={breadcrumb} />

  <section class="simple-page">
    <div class="container">
      <a href="https://www.itrc.gov.co/Itrc/wp-content/uploads/2025/09/Procesos-y-Procedimientos-de-la-Agencia-ITRC.pdf" target="_blank" rel="noopener" class="doc-cta">
        <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
        <span>Procesos y Procedimientos de la Agencia ITRC</span>
        <i class="fa-solid fa-download" aria-hidden="true"></i>
      </a>
      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .simple-page { padding: var(--space-12) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .simple-page .container { max-width: 700px; margin: 0 auto; text-align: center; }
  .doc-cta { display: inline-flex; align-items: center; gap: var(--space-4); padding: var(--space-5) var(--space-8); background: var(--theme-surface); border: 2px solid var(--file-pdf); border-radius: var(--radius-full); text-decoration: none; font-weight: 700; font-size: var(--font-size-base); color: var(--file-pdf); transition: all var(--transition-base); }
  .doc-cta:hover { background: var(--file-pdf); color: var(--white); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .back-link { margin-top: var(--space-8); }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .doc-cta { font-size: var(--font-size-sm); padding: var(--space-4) var(--space-6); } }
</style>
