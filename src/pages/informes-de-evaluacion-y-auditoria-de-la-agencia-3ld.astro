---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';
import pageData from '../content/pages/transparencia/informes/evaluacion-auditoria-3ld.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];

const disponibles = pageData.categorias.filter((c) => c.destino.estado === 'disponible').length;
const proximas = pageData.categorias.filter((c) => c.destino.estado === 'proximamente').length;
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="oci-section">
    <div class="container">
      {pageData.intro && <p class="oci-intro">{pageData.intro}</p>}

      <div class="oci-stats">
        <div class="oci-stats__item oci-stats__item--disp">
          <span class="oci-stats__num">{disponibles}</span>
          <span class="oci-stats__label">Disponibles</span>
        </div>
        <div class="oci-stats__item oci-stats__item--prox">
          <span class="oci-stats__num">{proximas}</span>
          <span class="oci-stats__label">Próximamente</span>
        </div>
        <div class="oci-stats__item oci-stats__item--total">
          <span class="oci-stats__num">{pageData.categorias.length}</span>
          <span class="oci-stats__label">Total categorías</span>
        </div>
      </div>

      <div class="oci-grid">
        {pageData.categorias.map((c) => {
          const disp = c.destino.estado === 'disponible' && c.destino.url;
          const external = c.destino.tipo === 'external';
          const href = disp ? (external ? c.destino.url : resolveUrl(c.destino.url)) : '#';
          const Tag = disp ? 'a' : 'div';
          return (
            <Tag
              href={disp ? href : undefined}
              target={disp && external ? '_blank' : undefined}
              rel={disp && external ? 'noopener noreferrer' : undefined}
              class:list={['oci-card', disp ? 'oci-card--disponible' : 'oci-card--proxima']}
              aria-disabled={!disp}
            >
              <span class="oci-card__num">{c.numero}</span>
              <div class="oci-card__body">
                <h3>{c.titulo}</h3>
                {!disp && <span class="oci-card__badge">Próximamente</span>}
              </div>
              {disp && (
                <i class={`fa-solid ${external ? 'fa-arrow-up-right-from-square' : 'fa-arrow-right'} oci-card__arrow`} aria-hidden="true"></i>
              )}
            </Tag>
          );
        })}
      </div>

      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .oci-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .oci-section .container { max-width: 1100px; margin: 0 auto; }

  .oci-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text-secondary); margin-bottom: var(--space-8); text-align: justify; max-width: 900px; margin-left: auto; margin-right: auto; }

  .oci-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-10); }
  .oci-stats__item { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: var(--space-4); background: var(--theme-surface-alt); border-radius: var(--radius-lg); text-align: center; }
  .oci-stats__item--disp { background: rgba(40,167,69,0.10); border: 1px solid rgba(40,167,69,0.25); }
  .oci-stats__item--prox { background: rgba(179,139,64,0.10); border: 1px solid rgba(179,139,64,0.25); }
  .oci-stats__item--total { background: var(--theme-surface-alt); border: 1px solid var(--theme-border); }
  .oci-stats__num { font-size: var(--font-size-2xl); font-weight: 800; color: var(--theme-heading); line-height: 1; }
  .oci-stats__label { font-size: var(--font-size-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--theme-text-muted); }

  .oci-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: var(--space-4); }

  .oci-card { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .oci-card--disponible:hover { border-color: var(--itrc-gold); box-shadow: var(--shadow-md); transform: translateX(4px); }
  .oci-card--proxima { background: var(--theme-surface-alt); opacity: 0.75; cursor: not-allowed; }

  .oci-card__num { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: var(--itrc-gold); color: var(--itrc-navy); border-radius: var(--radius-md); font-size: var(--font-size-sm); font-weight: 800; font-variant-numeric: tabular-nums; flex-shrink: 0; }
  .oci-card--proxima .oci-card__num { background: var(--theme-border); color: var(--theme-text-muted); }

  .oci-card__body { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .oci-card__body h3 { font-size: var(--font-size-sm); font-weight: 700; color: var(--theme-heading); margin: 0; line-height: 1.4; }

  .oci-card__badge { display: inline-flex; align-items: center; width: fit-content; padding: 2px 8px; background: rgba(179,139,64,0.18); color: var(--itrc-gold); border-radius: var(--radius-full); font-size: var(--font-size-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }

  .oci-card__arrow { color: var(--theme-text-muted); font-size: var(--font-size-sm); opacity: 0.4; transition: all var(--transition-fast); flex-shrink: 0; }
  .oci-card--disponible:hover .oci-card__arrow { color: var(--itrc-gold); opacity: 1; transform: translateX(3px); }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 640px) { .oci-stats { grid-template-columns: repeat(3, 1fr); } }
</style>
