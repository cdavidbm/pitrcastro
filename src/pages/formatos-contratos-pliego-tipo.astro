---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: 'Formatos de Contratos' }
];

function fileIcon(url: string) {
  if (url.endsWith('.xlsx')) return 'fa-file-excel';
  if (url.endsWith('.docx') || url.endsWith('.doc')) return 'fa-file-word';
  return 'fa-file-pdf';
}
function fileColor(url: string) {
  if (url.endsWith('.xlsx')) return 'excel';
  if (url.endsWith('.docx') || url.endsWith('.doc')) return 'word';
  return 'pdf';
}

const formatos = [
  { nombre: 'Formato Acto Administrativo de la Contratación Directa', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/1-Acto-Administrativo-de-la-Contratacion-Directa-codigo-GCO-FT-012-version-6.docx' },
  { nombre: 'Formato verificación especificaciones técnicas de bienes a recibir', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/2-Verificacion-Especificaciones-Tecnicas-codigo-GCO-FT-001-version-3.docx' },
  { nombre: 'Formato Aviso de Convocatoria Pública', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/3-Formato-Aviso-convocatoria-publica-codigo-GCO-FT-006-version-5.docx' },
  { nombre: 'Formato Adenda', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/4-Formato-Adenda-codigo-GCO-FT-007-version-4.docx' },
  { nombre: 'Formato Aprobación de garantías', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/5-Formato-aprobacion-de-garantia-codigo-GCO-FT-008-version-5.docx' },
  { nombre: 'Formato Acta de Inicio', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/6-Formato-Acta-de-inicio-codigo-GCO-FT-009-version-5.docx' },
  { nombre: 'Formato Aceptación de la Oferta', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/7-Formato-aceptacion-oferta-codigo-GCO-FT-011-version-6.docx' },
  { nombre: 'Formato Estudios Previos', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/8-Estudios-Previos-codigo-GCO-FT-010-version-8.docx' },
  { nombre: 'Formato Certificación Contractual', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/9-Certificacion-contractual-codigo-GCO-FT-004-version-2.docx' },
  { nombre: 'Formato Matriz de Riesgos', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/10-Matriz-de-riesgos-codigo-GCO-FT-005-version-4.xlsx' },
];
---

<Base title="Formatos o Modelos de Contratos o Pliego Tipo" description="Formatos y modelos de documentos contractuales de la Agencia ITRC">
  <HeroPage title="Formatos de Contratos y Pliego Tipo" subtitle="Modelos de documentos contractuales" icon="fa-file-pen" breadcrumb={breadcrumb} />

  <section class="docs-section">
    <div class="container">
      <div class="docs-count"><i class="fa-solid fa-file" aria-hidden="true"></i> {formatos.length} formatos disponibles</div>
      <div class="docs-list">
        {formatos.map((f) => (
          <a href={f.url} target="_blank" rel="noopener" class={`doc-item doc--${fileColor(f.url)}`}>
            <div class="doc-item__icon"><i class={`fa-solid ${fileIcon(f.url)}`} aria-hidden="true"></i></div>
            <span>{f.nombre}</span>
            <i class="fa-solid fa-download" aria-hidden="true"></i>
          </a>
        ))}
      </div>
      <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
    </div>
  </section>
</Base>

<style>
  .docs-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .docs-section .container { max-width: 850px; margin: 0 auto; }
  .docs-count { display: flex; align-items: center; justify-content: center; gap: var(--space-2); font-size: var(--font-size-sm); font-weight: 700; color: var(--itrc-gold); margin-bottom: var(--space-6); }
  .docs-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .doc-item { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .doc-item:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
  .doc-item__icon { width: 40px; height: 40px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); font-size: var(--font-size-lg); transition: all var(--transition-base); }
  .doc--word .doc-item__icon { background: rgba(13,110,253,0.08); color: var(--file-word); }
  .doc--word:hover .doc-item__icon { background: var(--file-word); color: var(--white); }
  .doc--word:hover { border-color: rgba(13,110,253,0.3); }
  .doc--excel .doc-item__icon { background: rgba(25,135,84,0.08); color: var(--file-excel); }
  .doc--excel:hover .doc-item__icon { background: var(--file-excel); color: var(--white); }
  .doc--excel:hover { border-color: rgba(25,135,84,0.3); }
  .doc--pdf .doc-item__icon { background: rgba(220,53,69,0.08); color: var(--file-pdf); }
  .doc--pdf:hover .doc-item__icon { background: var(--file-pdf); color: var(--white); }
  .doc-item span { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .doc-item:hover span { color: var(--itrc-gold); }
  .doc-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .doc-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .docs-section { padding: var(--space-6) var(--space-4) var(--space-12); } .doc-item span { font-size: var(--font-size-xs); } }
</style>
