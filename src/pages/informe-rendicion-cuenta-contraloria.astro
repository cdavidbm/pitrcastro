---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: 'Rendición Cuenta Fiscal CGR' }];

function fileIcon(url: string) { return url.endsWith('.xls') || url.endsWith('.xlsx') ? 'fa-file-excel' : 'fa-file-pdf'; }
function fileColor(url: string) { return url.endsWith('.xls') || url.endsWith('.xlsx') ? 'excel' : 'pdf'; }

const docs = [
  { nombre: 'Certificación Rendición de cuenta anual consolidada CGR 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/Certificacion-Cuenta-CGR-ITRC-2023.pdf' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2023', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/CuentaRendida-CGR-2023.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2022', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2023/08/Rendicion-Cuenta-Fiscal-2022-CGR.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2021', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/03/Rendicion-Cuenta-Fiscal-2021-CGR.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2020', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/03/Rendicion-cuenta-CGR-2020.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2019', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/09/FORMULARIOS-SIRECI-2019.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2018', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/09/FORMULARIOS-SIRECI-2018.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2017', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/09/FORMULARIOS-SIRECI-2017.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2016', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2020/09/FORMULARIOS-SIRECI-2016.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2015', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2016/11/Rendicin-de-Cuenta-Anual-Consolidada-2015.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2014', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2016/11/Rendicin-de-Cuenta-Anual-Consolidada-2014.xlsx' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2013', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2016/11/Rendicin-de-Cuenta-Anual-Consolidada-2013.xls' },
  { nombre: 'Rendición de cuenta anual consolidada CGR 2012', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2016/11/Rendicin-de-Cuenta-Anual-Consolidada-2012.xls' },
];
---

<Base title="Rendición Cuenta Fiscal — Contraloría General" description="Informe de rendición de la cuenta fiscal a la Contraloría General de la República">
  <HeroPage title="Rendición Cuenta Fiscal — CGR" subtitle="Informes a la Contraloría General de la República" icon="fa-landmark" breadcrumb={breadcrumb} />
  <section class="docs-section"><div class="container">
    <div class="docs-count"><i class="fa-solid fa-file" aria-hidden="true"></i> {docs.length} informes</div>
    <div class="docs-list">
      {docs.map((d) => (
        <a href={d.url} target="_blank" rel="noopener" class={`doc-item doc--${fileColor(d.url)}`}>
          <div class="doc-item__icon"><i class={`fa-solid ${fileIcon(d.url)}`} aria-hidden="true"></i></div>
          <span>{d.nombre}</span><i class="fa-solid fa-download" aria-hidden="true"></i>
        </a>
      ))}
    </div>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>

<style>
  .docs-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .docs-section .container { max-width: 850px; margin: 0 auto; }
  .docs-count { display: flex; align-items: center; justify-content: center; gap: var(--space-2); font-size: var(--font-size-sm); font-weight: 700; color: var(--itrc-gold); margin-bottom: var(--space-6); }
  .docs-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .doc-item { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .doc-item:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
  .doc-item__icon { width: 40px; height: 40px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); font-size: var(--font-size-lg); transition: all var(--transition-base); }
  .doc--pdf .doc-item__icon { background: rgba(220,53,69,0.08); color: var(--file-pdf); }
  .doc--pdf:hover .doc-item__icon { background: var(--file-pdf); color: var(--white); }
  .doc--excel .doc-item__icon { background: rgba(25,135,84,0.08); color: var(--file-excel); }
  .doc--excel:hover .doc-item__icon { background: var(--file-excel); color: var(--white); }
  .doc-item span { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .doc-item:hover span { color: var(--itrc-gold); }
  .doc-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .doc-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .docs-section { padding: var(--space-6) var(--space-4) var(--space-12); } .doc-item span { font-size: var(--font-size-xs); } }
</style>
