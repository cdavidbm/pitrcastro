---
/**
 * Buzón Ético Virtual Institucional — Agencia ITRC
 *
 * Landing del canal de reportes/denuncias de integridad. El contenido se basa
 * en el "Protocolo para la implementación del Buzón Ético Virtual Institucional".
 * El formulario se delega a Microsoft Forms (gestionado por Talento Humano) y se
 * EMBEBE más abajo. Mientras no exista el enlace público de inserción, se muestra
 * un placeholder claro. Para activarlo: pegar el "Insertar/Embed" de Forms en
 * FORM_EMBED_URL (NO el enlace de edición/diseño).
 */
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';

const base = import.meta.env.BASE_URL;

// Formulario propio (Opción B). El backend (endpoint en santorini + Postgres) aún
// NO existe: esta es una VISTA PREVIA para evaluadores. El botón Enviar está
// deshabilitado para que nadie envíe una denuncia real sin destino. Cuando el
// backend esté listo, se conecta el submit a /api/buzon/submit (mismo dominio).
const FORM_OPERATIVO = false;

// Opciones de los desplegables. Las dependencias son provisionales — confirmar
// con la entidad la lista oficial.
const dependencias = [
  'Dirección General',
  'Secretaría General',
  'Subdirección de Asuntos Legales',
  'Subdirección de Instrucción Disciplinaria',
  'Oficina Asesora de Control Interno',
  'Oficina Asesora de Planeación',
  'Gestión del Talento Humano',
  'Gestión Administrativa y Financiera',
  'Tecnologías de la Información',
  'Otra / No estoy seguro',
];
const gradosAfectacion = ['Bajo', 'Medio', 'Alto', 'Muy alto'];
const relaciones = [
  'Servidor público de la entidad', 'Contratista', 'Ciudadano', 'Usuario',
  'Proveedor', 'Pasante o practicante', 'Compañero de trabajo',
  'Superior jerárquico', 'Subalterno', 'Ninguna', 'Otro',
];

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Atención y Servicios', href: resolveUrl('/atencion-y-servicios') },
  { label: 'Buzón Ético Virtual' },
];

const principios = [
  { icon: 'fa-user-shield', titulo: 'Confidencialidad', texto: 'Tu información se trata bajo estricta reserva. El acceso se restringe únicamente al personal autorizado de Talento Humano y la Subdirección de Asuntos Legales.' },
  { icon: 'fa-shield-heart', titulo: 'No represalia', texto: 'Quien reporta de buena fe no será objeto de represalias, discriminación ni intimidación de ningún tipo.' },
  { icon: 'fa-eye', titulo: 'Transparencia', texto: 'Cada reporte se documenta y puede ser objeto de seguimiento, garantizando trazabilidad y legitimidad del mecanismo.' },
  { icon: 'fa-scale-balanced', titulo: 'Debido proceso', texto: 'Todos los reportes se gestionan de forma objetiva e imparcial, respetando los derechos de las personas involucradas.' },
  { icon: 'fa-universal-access', titulo: 'Accesibilidad', texto: 'Disponible para usuarios internos y externos, sin barreras y con disponibilidad permanente.' },
  { icon: 'fa-lock', titulo: 'Protección del denunciante', texto: 'Se adoptan medidas para salvaguardar tu identidad y evitar tu exposición innecesaria.' },
];

const quienesPueden = [
  'Servidores públicos de cualquier dependencia',
  'Contratistas y personal vinculado',
  'Practicantes y judicantes',
  'Ciudadanía en general',
  'Visitantes y usuarios externos',
  'Proveedores y terceros relacionados',
];

const queReportar = [
  { icon: 'fa-handcuffs', t: 'Posibles actos de corrupción' },
  { icon: 'fa-arrows-split-up-and-left', t: 'Conflictos de interés' },
  { icon: 'fa-book-skull', t: 'Conductas contrarias al Código de Integridad' },
  { icon: 'fa-ban', t: 'Situaciones de discriminación' },
  { icon: 'fa-coins', t: 'Uso indebido de recursos públicos' },
  { icon: 'fa-file-circle-exclamation', t: 'Irregularidades administrativas' },
  { icon: 'fa-triangle-exclamation', t: 'Riesgos que afecten la transparencia o la ética pública' },
];

// Tabla 3 del protocolo — valores del Código de Integridad y conductas asociadas.
const valoresIntegridad = [
  { valor: 'Honestidad', desc: 'Actúo con fundamento en la verdad, con transparencia y rectitud.', conductas: ['Trato preferencial para favorecer a terceros', 'Aceptar incentivos o beneficios indebidos', 'Uso de recursos públicos para fines personales', 'Manejo inadecuado de información a cargo'] },
  { valor: 'Respeto', desc: 'Reconozco y trato con dignidad a todas las personas.', conductas: ['Actos discriminatorios', 'Conductas groseras u ofensivas', 'Decisiones basadas en prejuicios', 'Maltrato a ciudadanos o servidores'] },
  { valor: 'Compromiso', desc: 'Actúo en función del bienestar de la ciudadanía.', conductas: ['Actitud negativa en las funciones', 'Desinterés frente a las necesidades ciudadanas', 'Falta de atención a usuarios', 'Ignorar inquietudes o solicitudes'] },
  { valor: 'Diligencia', desc: 'Cumplo mis funciones con prontitud, eficiencia y calidad.', conductas: ['Mal uso o desperdicio de recursos', 'Retraso u omisión injustificados', 'Desinterés en actuaciones institucionales', 'Incumplimiento de funciones'] },
  { valor: 'Justicia', desc: 'Actúo con imparcialidad, equidad e igualdad.', conductas: ['Favorecimiento indebido a particulares', 'Actuaciones inequitativas', 'Influencia de intereses personales', 'Afectación a la igualdad de las personas'] },
];

const queTenerListo = [
  { icon: 'fa-list-check', t: 'Tipo de reporte', d: 'Código de Integridad (valor y conducta) o conflicto de interés.' },
  { icon: 'fa-align-left', t: 'Descripción de los hechos', d: 'Qué ocurrió, cómo y cuándo, de forma clara y cronológica.' },
  { icon: 'fa-location-dot', t: 'Lugar y personas', d: 'Dependencia o área involucrada y, si los conoces, los presuntos implicados.' },
  { icon: 'fa-paperclip', t: 'Evidencias (opcional)', d: 'PDF, Word, Excel, imágenes o audio que respalden tu reporte.' },
];

const proceso = [
  { n: 1, t: 'Recepción del reporte', d: 'Registras la información de forma anónima o identificada.', tiempo: 'Inmediato' },
  { n: 2, t: 'Registro y radicación', d: 'El sistema asigna un número único para la trazabilidad.', tiempo: 'Inmediato' },
  { n: 3, t: 'Clasificación', d: 'Talento Humano determina la naturaleza y el nivel de riesgo.', tiempo: 'Hasta 5 días hábiles' },
  { n: 4, t: 'Análisis preliminar', d: 'Se verifica pertinencia, suficiencia y competencia institucional.', tiempo: 'Hasta 5 días hábiles' },
  { n: 5, t: 'Asignación del caso', d: 'Se remite a la instancia competente según su naturaleza.', tiempo: 'Hasta 5 días hábiles' },
  { n: 6, t: 'Gestión del caso', d: 'Se desarrollan las acciones conforme a la normativa vigente.', tiempo: 'Según complejidad' },
  { n: 7, t: 'Seguimiento y cierre', d: 'Se documentan actuaciones y se registra el resultado.', tiempo: 'Según el caso' },
  { n: 8, t: 'Retroalimentación', d: 'Se informa al denunciante cuando aplique.', tiempo: '5 días hábiles tras el cierre' },
];

// Mapa valor → conductas (Tabla 3), para el desplegable dependiente del formulario.
const conductasMap = Object.fromEntries(valoresIntegridad.map((v) => [v.valor, v.conductas]));
---

<Base
  title="Buzón Ético Virtual"
  description="Canal institucional de la Agencia ITRC para reportar, de forma anónima o identificada, posibles riesgos de integridad: corrupción, conflictos de interés, conductas contrarias al Código de Integridad e irregularidades."
  class="page-buzon"
>
  <HeroPage
    title="Buzón Ético Virtual"
    subtitle="Un canal seguro y confidencial para reportar posibles riesgos de integridad en la Agencia ITRC."
    badge="Integridad Institucional"
    icon="fa-shield-halved"
    breadcrumb={breadcrumb}
  />

  <!-- Intro + CTA -->
  <section class="buzon-intro">
    <div class="container buzon-intro__grid">
      <div class="buzon-intro__text">
        <h2>¿Qué es el Buzón Ético Virtual?</h2>
        <p>
          Es un mecanismo institucional para la <strong>recepción, análisis y gestión</strong> de
          reportes, denuncias, quejas o alertas relacionadas con posibles riesgos de integridad.
          Permite identificar oportunamente situaciones que puedan constituir actos de corrupción,
          conflictos de interés, conductas contrarias al Código de Integridad o irregularidades
          administrativas.
        </p>
        <p>
          Su uso está garantizado bajo condiciones de <strong>confidencialidad, protección al
          denunciante, accesibilidad y debido proceso</strong>. Puedes presentar tu reporte de forma
          <strong> anónima o identificada</strong>.
        </p>
        <a href="#formulario" class="buzon-btn buzon-btn--primary">
          <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i> Presentar un reporte
        </a>
      </div>
      <aside class="buzon-intro__card" aria-label="Garantía de anonimato">
        <i class="fa-solid fa-user-secret" aria-hidden="true"></i>
        <h3>Tu reporte puede ser anónimo</h3>
        <p>
          Los campos de identificación <strong>no son obligatorios</strong> y no limitan el envío.
          Decides tú si te identificas o no.
        </p>
      </aside>
    </div>
  </section>

  <!-- Principios -->
  <section class="buzon-section buzon-section--surface" aria-labelledby="principios-title">
    <div class="container">
      <h2 id="principios-title" class="buzon-h2">Nuestros principios</h2>
      <p class="buzon-lead">Cada actuación del Buzón Ético Virtual se rige por estos principios.</p>
      <div class="buzon-principios">
        {principios.map((p) => (
          <article class="buzon-principio">
            <div class="buzon-principio__icon"><i class={`fa-solid ${p.icon}`} aria-hidden="true"></i></div>
            <h3>{p.titulo}</h3>
            <p>{p.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Quién + Qué -->
  <section class="buzon-section" aria-labelledby="alcance-title">
    <div class="container buzon-dos-col">
      <div>
        <h2 id="alcance-title" class="buzon-h2">¿Quién puede usarlo?</h2>
        <ul class="buzon-lista-check">
          {quienesPueden.map((q) => (
            <li><i class="fa-solid fa-circle-check" aria-hidden="true"></i><span>{q}</span></li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="buzon-h2">¿Qué puedes reportar?</h2>
        <ul class="buzon-lista-reportar">
          {queReportar.map((r) => (
            <li><i class={`fa-solid ${r.icon}`} aria-hidden="true"></i><span>{r.t}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Valores del Código de Integridad -->
  <section class="buzon-section buzon-section--surface" aria-labelledby="valores-title">
    <div class="container">
      <h2 id="valores-title" class="buzon-h2">Valores del Código de Integridad</h2>
      <p class="buzon-lead">
        Si tu reporte se relaciona con el Código de Integridad, podrás indicar el valor presuntamente
        afectado y la conducta asociada.
      </p>
      <div class="buzon-valores">
        {valoresIntegridad.map((v) => (
          <article class="buzon-valor">
            <h3>{v.valor}</h3>
            <p class="buzon-valor__desc">{v.desc}</p>
            <ul>
              {v.conductas.map((c) => (<li>{c}</li>))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Antes de empezar -->
  <section class="buzon-section" aria-labelledby="listo-title">
    <div class="container">
      <h2 id="listo-title" class="buzon-h2">Antes de empezar, ten a la mano</h2>
      <div class="buzon-listo">
        {queTenerListo.map((q) => (
          <div class="buzon-listo__item">
            <i class={`fa-solid ${q.icon}`} aria-hidden="true"></i>
            <div>
              <h3>{q.t}</h3>
              <p>{q.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formulario a medida -->
  <section id="formulario" class="buzon-section buzon-section--dark" aria-labelledby="form-title">
    <div class="container">
      <h2 id="form-title" class="buzon-h2 buzon-h2--light">Presentar un reporte</h2>
      <p class="buzon-form__intro">
        Diligencia el siguiente formulario. Puedes hacerlo de forma <strong>anónima</strong> o
        identificada. Al enviar, autorizas el tratamiento de tus datos conforme a la
        <a href={resolveUrl('/proteccion-de-datos-personales')}>Política de Tratamiento de Datos Personales</a>
        (Ley 1581 de 2012).
      </p>

      {!FORM_OPERATIVO && (
        <div class="buzon-aviso" role="status">
          <i class="fa-solid fa-flask" aria-hidden="true"></i>
          <p><strong>Vista previa.</strong> El formulario está en revisión y <strong>aún no está operativo</strong>. Por ahora no envíes información real: los reportes todavía no se reciben.</p>
        </div>
      )}

      <form class="buzon-form" novalidate data-buzon-form aria-label="Formulario del Buzón Ético Virtual">

        <!-- 1. Clasificación -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">1</span> Clasificación del reporte</legend>

          <div class="buzon-field">
            <label for="tipo">¿Qué tipo de reporte desea presentar? <span class="req">*</span></label>
            <select id="tipo" name="tipo" required data-tipo>
              <option value="" selected disabled>Selecciona una opción…</option>
              <option value="codigo">Código de Integridad</option>
              <option value="conflicto">Conflicto de interés</option>
            </select>
          </div>

          <div class="buzon-field" data-cond="codigo" hidden>
            <label for="valor">¿Cuál valor del Código de Integridad considera afectado? <span class="req">*</span></label>
            <select id="valor" name="valor" data-valor>
              <option value="" selected disabled>Selecciona un valor…</option>
              <option>Honestidad</option><option>Respeto</option><option>Compromiso</option><option>Diligencia</option><option>Justicia</option>
            </select>
          </div>

          <div class="buzon-field" data-cond="codigo" hidden>
            <label for="conducta">¿Cuál es la situación o conducta que desea reportar? <span class="req">*</span></label>
            <select id="conducta" name="conducta" data-conducta>
              <option value="" selected disabled>Primero selecciona un valor…</option>
            </select>
          </div>
        </fieldset>

        <!-- 2. Información del reporte -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">2</span> Información del reporte</legend>

          <div class="buzon-field">
            <label for="descripcion">Describa los hechos que desea reportar <span class="req">*</span></label>
            <textarea id="descripcion" name="descripcion" rows="6" required
              placeholder="Describa de manera clara, objetiva y cronológica lo sucedido: qué ocurrió, cómo ocurrió y cualquier información relevante."></textarea>
          </div>

          <div class="buzon-row">
            <div class="buzon-field">
              <label for="fecha">¿Cuándo ocurrieron los hechos? <span class="req">*</span></label>
              <input type="date" id="fecha" name="fecha" required />
            </div>
            <div class="buzon-field">
              <label for="lugar">¿Dónde ocurrieron los hechos? <span class="req">*</span></label>
              <select id="lugar" name="lugar" required>
                <option value="" selected disabled>Dependencia, oficina o área…</option>
                {dependencias.map((d) => (<option>{d}</option>))}
              </select>
            </div>
          </div>

          <div class="buzon-field">
            <label for="involucrados">¿Quiénes estuvieron presuntamente involucrados? <span class="req">*</span></label>
            <input type="text" id="involucrados" name="involucrados" required
              placeholder="Nombres, cargos o cualquier información que permita identificarlos." />
          </div>
        </fieldset>

        <!-- 3. Información del denunciante -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">3</span> Información del denunciante</legend>

          <div class="buzon-field">
            <span class="buzon-label">¿Cómo desea presentar el reporte? <span class="req">*</span></span>
            <div class="buzon-radios" role="radiogroup">
              <label class="buzon-radio"><input type="radio" name="modalidad" value="anonima" data-modalidad checked /> <span><i class="fa-solid fa-user-secret"></i> Denuncia anónima</span></label>
              <label class="buzon-radio"><input type="radio" name="modalidad" value="identificada" data-modalidad /> <span><i class="fa-solid fa-id-card"></i> Denuncia identificada</span></label>
            </div>
          </div>

          <div class="buzon-row" data-cond="identificada" hidden>
            <div class="buzon-field">
              <label for="correo">Correo electrónico</label>
              <input type="email" id="correo" name="correo" placeholder="nombre@correo.com" />
            </div>
            <div class="buzon-field">
              <label for="telefono">Número de teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="Opcional" />
            </div>
          </div>
        </fieldset>

        <!-- 4. Información complementaria -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">4</span> Información complementaria</legend>

          <div class="buzon-row">
            <div class="buzon-field">
              <label for="afectacion">Grado de afectación ocasionado <span class="req">*</span></label>
              <select id="afectacion" name="afectacion" required>
                <option value="" selected disabled>Selecciona…</option>
                {gradosAfectacion.map((g) => (<option>{g}</option>))}
              </select>
            </div>
            <div class="buzon-field">
              <label for="relacion">¿Cuál es su relación con la persona involucrada? <span class="req">*</span></label>
              <select id="relacion" name="relacion" required>
                <option value="" selected disabled>Selecciona…</option>
                {relaciones.map((r) => (<option>{r}</option>))}
              </select>
            </div>
          </div>

          <div class="buzon-field">
            <label for="anexos">¿Desea adjuntar evidencias que respalden su reporte?</label>
            <input type="file" id="anexos" name="anexos" multiple
              accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.mp3,.mp4" />
            <small class="buzon-help">Formatos permitidos: PDF, Word, Excel, JPG, PNG, MP3, MP4.</small>
          </div>
        </fieldset>

        <!-- 5. Preguntas adicionales -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">5</span> Información adicional</legend>

          <div class="buzon-row">
            <div class="buzon-field">
              <label for="continuan">¿Los hechos continúan ocurriendo actualmente?</label>
              <select id="continuan" name="continuan">
                <option value="" selected disabled>Selecciona…</option>
                <option>Sí</option><option>No</option><option>No sabe</option>
              </select>
            </div>
            <div class="buzon-field">
              <label for="reportado">¿Ha reportado anteriormente esta situación?</label>
              <select id="reportado" name="reportado">
                <option value="" selected disabled>Selecciona…</option>
                <option>Sí</option><option>No</option><option>No recuerda</option>
              </select>
            </div>
          </div>

          <div class="buzon-field">
            <label for="testigos">¿Existen otras personas que puedan aportar información sobre estos hechos?</label>
            <input type="text" id="testigos" name="testigos" placeholder="Opcional" />
          </div>
        </fieldset>

        <!-- 6. Seguimiento + datos -->
        <fieldset class="buzon-fs">
          <legend><span class="buzon-fs__n">6</span> Seguimiento y protección de datos</legend>

          <div class="buzon-field" data-cond="identificada" hidden>
            <span class="buzon-label">¿Por cuál medio desea recibir información sobre el trámite?</span>
            <div class="buzon-radios" role="radiogroup">
              <label class="buzon-radio"><input type="radio" name="canal" value="correo" /> <span>Correo electrónico</span></label>
              <label class="buzon-radio"><input type="radio" name="canal" value="telefono" /> <span>Teléfono</span></label>
            </div>
          </div>
          <p class="buzon-anon-nota" data-cond="anonima">
            <i class="fa-solid fa-circle-info"></i> Al ser anónima, no recibirás respuesta directa. Guarda el <strong>número de radicado</strong> que se generará al enviar para consultar el estado.
          </p>

          <label class="buzon-check">
            <input type="checkbox" name="autorizacion" required />
            <span>Declaro que he leído y acepto la <a href={resolveUrl('/proteccion-de-datos-personales')} target="_blank" rel="noopener">Política de Tratamiento de Datos Personales</a> de la Agencia ITRC y autorizo el tratamiento de mis datos conforme a la normatividad vigente. <span class="req">*</span></span>
          </label>
        </fieldset>

        <div class="buzon-actions">
          <button type="submit" class="buzon-btn buzon-btn--primary buzon-btn--lg" disabled={!FORM_OPERATIVO}>
            <i class="fa-solid fa-paper-plane"></i> {FORM_OPERATIVO ? 'Enviar reporte' : 'Envío no disponible (vista previa)'}
          </button>
          <button type="reset" class="buzon-btn buzon-btn--ghost">Limpiar</button>
        </div>
      </form>
    </div>
  </section>

  <!-- El proceso -->
  <section class="buzon-section buzon-section--surface" aria-labelledby="proceso-title">
    <div class="container">
      <h2 id="proceso-title" class="buzon-h2">¿Qué pasa después de tu reporte?</h2>
      <p class="buzon-lead">Cada reporte sigue una ruta clara y con tiempos definidos.</p>
      <ol class="buzon-proceso">
        {proceso.map((p) => (
          <li class="buzon-paso">
            <span class="buzon-paso__num">{p.n}</span>
            <div class="buzon-paso__body">
              <h3>{p.t}</h3>
              <p>{p.d}</p>
              <span class="buzon-paso__tiempo"><i class="fa-regular fa-clock" aria-hidden="true"></i> {p.tiempo}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Nota de confidencialidad -->
  <section class="buzon-section" aria-label="Nota de confidencialidad">
    <div class="container">
      <div class="buzon-nota">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        <p>
          La gestión del Buzón Ético Virtual tiene un enfoque <strong>preventivo</strong>, no
          sancionatorio. La información se trata conforme a la normativa de protección de datos
          personales (Leyes 1581 de 2012 y 1266 de 2008) y la reserva legal aplicable (Ley 1755 de
          2015). Si de un reporte se desprende la posible comisión de un ilícito o conducta
          disciplinaria, será puesto en conocimiento de las autoridades competentes.
        </p>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ CONDUCTAS: conductasMap }}>
    (function () {
      var form = document.querySelector('[data-buzon-form]');
      if (!form) return;

      // Muestra/oculta cualquier bloque con data-cond según el valor activo.
      function toggleCond(key, on) {
        form.querySelectorAll('[data-cond="' + key + '"]').forEach(function (el) {
          el.hidden = !on;
        });
      }

      // 1. Tipo de reporte → muestra valor/conducta solo para "Código de Integridad"
      var tipo = form.querySelector('[data-tipo]');
      tipo && tipo.addEventListener('change', function () {
        toggleCond('codigo', tipo.value === 'codigo');
      });

      // 1.1 → 1.2 desplegable dependiente de conductas
      var valor = form.querySelector('[data-valor]');
      var conducta = form.querySelector('[data-conducta]');
      valor && valor.addEventListener('change', function () {
        var lista = CONDUCTAS[valor.value] || [];
        conducta.innerHTML = '<option value="" selected disabled>Selecciona la conducta…</option>';
        lista.forEach(function (c) {
          var o = document.createElement('option');
          o.textContent = c;
          conducta.appendChild(o);
        });
      });

      // 3. Modalidad anónima/identificada → muestra contacto + canal de respuesta
      function syncModalidad() {
        var sel = form.querySelector('[data-modalidad]:checked');
        var ident = sel && sel.value === 'identificada';
        toggleCond('identificada', ident);
        toggleCond('anonima', !ident);
      }
      form.querySelectorAll('[data-modalidad]').forEach(function (r) {
        r.addEventListener('change', syncModalidad);
      });

      // Estado inicial
      toggleCond('codigo', false);
      syncModalidad();
    })();
  </script>
</Base>

