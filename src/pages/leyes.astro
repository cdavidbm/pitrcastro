---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: 'Leyes' }
];

const leyes = [
  { nombre: 'Ley 2365 de 2024', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-2365-de-2024.pdf' },
  { nombre: 'Ley 2220 de 2022', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-2220-de-2022.pdf' },
  { nombre: 'Ley 2195 de 2022', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-2195-de-2022.pdf' },
  { nombre: 'Ley 2094 de 2021', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-2094-de-2021.pdf' },
  { nombre: 'Ley 2080 de 2021', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY_2080_DE_2021.pdf' },
  { nombre: 'Ley 1955 de 2019', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-1955-DE-2019.pdf' },
  { nombre: 'Ley 1952 de 2019', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-1952-de-2019.pdf' },
  { nombre: 'Ley 1755 de 2015', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-1755-DE-2015.pdf' },
  { nombre: 'Ley 1753 de 2015', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/Ley-1753-de-2015.pdf' },
  { nombre: 'Ley 1712 de 2014', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-1712-de-2014.pdf' },
  { nombre: 'Ley 1564 de 2012', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-1564-de-2012.pdf' },
  { nombre: 'Ley 1474 de 2011', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-1474-de-2011.pdf' },
  { nombre: 'Ley 1437 de 2011', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2024/07/LEY-1437-de-2011.pdf' },
  { nombre: 'Ley 734 de 2002', url: 'https://www.itrc.gov.co/Itrc/wp-content/uploads/2022/07/LEY-734-DE-2002.pdf' },
];
---

<Base title="Leyes" description="Leyes aplicables a la Agencia ITRC">
  <HeroPage title="Leyes" subtitle="Marco legal aplicable a la Agencia ITRC" icon="fa-scale-balanced" breadcrumb={breadcrumb} />

  <section class="leyes-section">
    <div class="container">
      <div class="leyes-count"><i class="fa-solid fa-file-pdf" aria-hidden="true"></i> {leyes.length} leyes</div>
      <div class="leyes-list">
        {leyes.map((ley) => (
          <a href={ley.url} target="_blank" rel="noopener" class="ley-item">
            <div class="ley-item__icon"><i class="fa-solid fa-file-pdf" aria-hidden="true"></i></div>
            <span>{ley.nombre}</span>
            <i class="fa-solid fa-download" aria-hidden="true"></i>
          </a>
        ))}
      </div>
      <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
    </div>
  </section>
</Base>

<style>
  .leyes-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .leyes-section .container { max-width: 800px; margin: 0 auto; }
  .leyes-count { display: flex; align-items: center; justify-content: center; gap: var(--space-2); font-size: var(--font-size-sm); font-weight: 700; color: var(--file-pdf); margin-bottom: var(--space-6); }
  .leyes-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .ley-item { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .ley-item:hover { border-color: rgba(220,53,69,0.3); box-shadow: var(--shadow-md); transform: translateX(4px); }
  .ley-item__icon { width: 40px; height: 40px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: rgba(220,53,69,0.08); border-radius: var(--radius-md); color: var(--file-pdf); font-size: var(--font-size-lg); transition: all var(--transition-base); }
  .ley-item:hover .ley-item__icon { background: var(--file-pdf); color: var(--white); }
  .ley-item span { flex: 1; font-size: var(--font-size-base); font-weight: 700; color: var(--theme-heading); }
  .ley-item:hover span { color: var(--file-pdf); }
  .ley-item > i:last-child { color: var(--theme-text-muted); opacity: 0.4; }
  .ley-item:hover > i:last-child { opacity: 1; color: var(--itrc-gold); }
  .back-link { margin-top: var(--space-8); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
  @media (max-width: 768px) { .leyes-section { padding: var(--space-6) var(--space-4) var(--space-12); } .ley-item span { font-size: var(--font-size-sm); } }
</style>
