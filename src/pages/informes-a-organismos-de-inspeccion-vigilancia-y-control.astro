---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import { resolveUrl } from '../utils/url';
import pageData from '../content/pages/transparencia/informes-organismos-ivc.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

  <section class="hub-section">
    <div class="container">
      {pageData.intro && <p class="hub-intro">{pageData.intro}</p>}

      <div class="hub-grid">
        {pageData.enlaces.map((e) => (
          <a
            href={e.tipo === 'external' ? e.url : resolveUrl(e.url)}
            target={e.tipo === 'external' ? '_blank' : '_self'}
            rel={e.tipo === 'external' ? 'noopener noreferrer' : ''}
            class="hub-card"
          >
            <div class="hub-card__icon" aria-hidden="true">
              <i class={`fa-solid ${e.icon || 'fa-arrow-right'}`}></i>
            </div>
            <div class="hub-card__body">
              <h3>{e.titulo}</h3>
              {e.descripcion && <p>{e.descripcion}</p>}
            </div>
            <i class={`fa-solid ${e.tipo === 'external' ? 'fa-arrow-up-right-from-square' : 'fa-arrow-right'} hub-card__arrow`} aria-hidden="true"></i>
          </a>
        ))}
      </div>

      <div class="back-link">
        <a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hub-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .hub-section .container { max-width: 1000px; margin: 0 auto; }

  .hub-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text-secondary); margin-bottom: var(--space-10); text-align: center; max-width: 720px; margin-left: auto; margin-right: auto; }

  .hub-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-5); }

  .hub-card { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-6); background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: var(--radius-xl); text-decoration: none; transition: all var(--transition-base); box-shadow: var(--shadow-sm); }
  .hub-card:hover { box-shadow: var(--shadow-lg); border-color: var(--itrc-gold); transform: translateY(-3px); }

  .hub-card__icon { width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--itrc-gold-light), var(--itrc-gold)); color: var(--itrc-navy); border-radius: var(--radius-lg); font-size: var(--font-size-xl); flex-shrink: 0; }

  .hub-card__body { flex: 1; }
  .hub-card__body h3 { font-size: var(--font-size-base); font-weight: 800; color: var(--theme-heading); margin: 0 0 4px; line-height: 1.3; }
  .hub-card__body p { font-size: var(--font-size-xs); color: var(--theme-text-secondary); margin: 0; line-height: 1.5; }

  .hub-card__arrow { color: var(--theme-text-muted); font-size: var(--font-size-sm); opacity: 0.4; transition: all var(--transition-fast); }
  .hub-card:hover .hub-card__arrow { color: var(--itrc-gold); opacity: 1; transform: translateX(4px); }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>
