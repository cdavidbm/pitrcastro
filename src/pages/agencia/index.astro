---
import Base from '../../layouts/Base.astro';
import HeroPage from '../../components/HeroPage.astro';
import { resolveUrl } from '../../utils/url';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'La Agencia' }
];

const secciones = [
  { titulo: 'Misión, Visión y Propósito Estratégico', descripcion: 'Conozca nuestra razón de ser y hacia dónde nos dirigimos', icon: 'fa-bullseye', url: '/agencia/mision-vision', color: 'var(--itrc-gold)' },
  { titulo: 'Nuestra Estructura', descripcion: 'Organigrama y estructura organizacional de la entidad', icon: 'fa-sitemap', url: '/agencia/organigrama', color: 'var(--itrc-navy)' },
  { titulo: 'Equipo Directivo', descripcion: 'Conozca al equipo que lidera la Agencia ITRC', icon: 'fa-users-gear', url: '/agencia/equipo-directivo', color: '#0943b5' },
  { titulo: 'Direccionamiento Estratégico', descripcion: 'Planes, políticas e informes estratégicos', icon: 'fa-compass', url: '/agencia/direccionamiento-estrategico', color: '#198754' },
  { titulo: 'Sistema Integrado de Gestión', descripcion: 'Procesos y procedimientos institucionales', icon: 'fa-gears', url: '/agencia/sistema-integrado-de-gestion', color: '#6f42c1' },
  { titulo: 'Gestión Misional', descripcion: 'Subdirecciones y funciones misionales de la entidad', icon: 'fa-briefcase', url: '/agencia/gestion-misional', color: '#dc3545' },
  { titulo: 'Sistema de Control Interno', descripcion: 'Informes legales, planes de mejoramiento y control', icon: 'fa-clipboard-check', url: '/agencia/control-interno', color: '#fd7e14' },
  { titulo: 'Información Financiera', descripcion: 'Estados financieros y ejecución presupuestal', icon: 'fa-chart-line', url: '/agencia/informacion-financiera', color: '#0dcaf0' },
];
---

<Base title="La Agencia" description="Información institucional de la Agencia del Inspector General de Tributos, Rentas y Contribuciones Parafiscales — ITRC">
  <HeroPage
    title="La Agencia"
    subtitle="Información institucional de la Agencia ITRC"
    icon="fa-building-columns"
    breadcrumb={breadcrumb}
  />

  <section class="hub-section">
    <div class="container">
      <div class="hub-grid">
        {secciones.map((sec) => (
          <a href={resolveUrl(sec.url)} class="hub-card" style={`--card-accent: ${sec.color}`}>
            <div class="hub-card__icon">
              <i class={`fa-solid ${sec.icon}`} aria-hidden="true"></i>
            </div>
            <h3 class="hub-card__title">{sec.titulo}</h3>
            <p class="hub-card__desc">{sec.descripcion}</p>
            <span class="hub-card__arrow"><i class="fa-solid fa-arrow-right" aria-hidden="true"></i></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .hub-section { padding: var(--space-10) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .hub-section .container { max-width: 1050px; margin: 0 auto; }
  .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-5); }

  .hub-card { display: flex; flex-direction: column; align-items: center; text-align: center; padding: var(--space-10) var(--space-6); background: var(--theme-surface); border: 1px solid var(--theme-border); border-top: 4px solid var(--card-accent); border-radius: var(--radius-xl); text-decoration: none; transition: all var(--transition-base); }
  .hub-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--card-accent); }
  .hub-card__icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: var(--card-accent); color: var(--white); border-radius: var(--radius-full); font-size: var(--font-size-2xl); margin-bottom: var(--space-4); transition: transform var(--transition-base); }
  .hub-card:hover .hub-card__icon { transform: scale(1.1); }
  .hub-card__title { font-size: var(--font-size-base); font-weight: 800; color: var(--theme-heading); margin: 0 0 var(--space-2); transition: color var(--transition-fast); }
  .hub-card:hover .hub-card__title { color: var(--card-accent); }
  .hub-card__desc { font-size: var(--font-size-sm); line-height: 1.6; color: var(--theme-text-secondary); margin: 0; flex: 1; }
  .hub-card__arrow { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; margin-top: var(--space-4); border-radius: var(--radius-full); background: rgba(0,0,0,0.04); color: var(--theme-text-muted); font-size: var(--font-size-sm); transition: all var(--transition-fast); }
  .hub-card:hover .hub-card__arrow { background: var(--card-accent); color: var(--white); }

  @media (max-width: 768px) {
    .hub-section { padding: var(--space-6) var(--space-4) var(--space-12); }
    .hub-grid { grid-template-columns: 1fr; gap: var(--space-3); }
    .hub-card { flex-direction: row; text-align: left; padding: var(--space-4); gap: var(--space-4); border-top: none; border-left: 4px solid var(--card-accent); }
    .hub-card__icon { width: 44px; height: 44px; font-size: var(--font-size-xl); margin-bottom: 0; flex-shrink: 0; }
    .hub-card__arrow { display: none; }
  }
</style>
