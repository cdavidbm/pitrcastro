---
import Base from '../../../layouts/Base.astro';
import HeroPage from '../../../components/HeroPage.astro';
import Accordion from '../../../components/Accordion.astro';
import Tabs from '../../../components/Tabs.astro';
import DocumentItem from '../../../components/DocumentItem.astro';
import type { DocumentPage } from '../../../types/content';
import {
  getAgenciaDireccionamientoInformes,
  getAgenciaDireccionamientoPlanes,
  getAgenciaDireccionamientoPoliticas,
} from '../../../utils/strapi-fetchers';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const [politicas, planes, informes] = await Promise.all([
    getAgenciaDireccionamientoPoliticas(),
    getAgenciaDireccionamientoPlanes(),
    getAgenciaDireccionamientoInformes(),
  ]);
  const entries: Array<{ slug: string; data: DocumentPage }> = [
    { slug: 'politicas', data: politicas as DocumentPage },
    { slug: 'planes', data: planes as DocumentPage },
    { slug: 'informes', data: informes as DocumentPage },
  ];
  return entries.map(({ slug, data }) => ({
    params: { slug },
    props: { pageData: data },
  }));
}

const { slug } = Astro.params;
const { pageData } = Astro.props;

const sectionConfig: Record<string, { color: string; icon: string }> = {
  politicas: { color: 'navy', icon: 'fa-scale-balanced' },
  planes: { color: 'gold', icon: 'fa-clipboard-list' },
  informes: { color: 'green', icon: 'fa-chart-line' },
};

const config = sectionConfig[slug as string] || { color: 'navy', icon: 'fa-folder-open' };

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Direccionamiento Estratégico', href: `${base}agencia/direccionamiento-estrategico` },
  { label: pageData.title },
];

// Ordenar documentos por año descendente dentro de cada sección
// (rangos "2023-2026" cuentan por el año superior; sin año → al final)
function yearKey(anio?: string | null): number {
  if (!anio) return -1;
  const m = String(anio).match(/(\d{4})(?:[^\d]+(\d{4}))?/);
  if (!m) return -1;
  return m[2] ? parseInt(m[2], 10) : parseInt(m[1], 10);
}

if (pageData?.sections) {
  for (const section of pageData.sections) {
    if (Array.isArray(section.documents)) {
      section.documents = [...section.documents].sort((a: any, b: any) => yearKey(b.anio) - yearKey(a.anio));
    }
  }
}

// === Reorganizar /planes por category en el orden del legacy WordPress ===
// Los usuarios extrañan la organización por tipo (PEI, PES, PAI, ...) que tenía
// el sitio anterior. Reagrupamos los documentos de la única section "Planes de
// la Agencia ITRC" en varias sub-sections una por category.
if (slug === 'planes' && pageData?.sections?.length) {
  // Orden institucional (mismo que el legacy):
  // https://www.itrc.gov.co/version-anterior/Itrc/direccionamiento-estrategico/planes/index.html
  const ORDEN_CATEGORIAS = [
    'PEI - Plan Estratégico Institucional',
    'PES - Plan Estratégico Sectorial',
    'PAI - Plan de Acción Institucional',
    'PIGA - Plan Institucional de Gestión Ambiental',
    'PAA - Plan Anual de Adquisiciones',
    'Plan de Participación Ciudadana',
    'Mapa de Riesgos de Corrupción',
    'PAAC - Plan Anticorrupción',
    'PIC - Plan Institucional de Capacitación',
    'Plan Anual de Vacantes',
    'Plan de Previsión de Recursos Humanos',
    'PETH - Plan Estratégico de Talento Humano',
    'Plan de Bienestar e Incentivos',
    'Plan de Seguridad y Salud en el Trabajo',
    'PETI - Plan Estratégico de TI',
    'Plan de Tratamiento de Riesgos',
    'Plan Institucional de Archivos',
    'Plan de Austeridad',
    'Programa de Transparencia y Ética Pública',
  ];

  // Icono representativo por category (Font Awesome)
  const ICONO_POR_CATEGORIA: Record<string, string> = {
    'PEI - Plan Estratégico Institucional':          'fa-flag',
    'PES - Plan Estratégico Sectorial':              'fa-diagram-project',
    'PAI - Plan de Acción Institucional':            'fa-list-check',
    'PIGA - Plan Institucional de Gestión Ambiental':'fa-leaf',
    'PAA - Plan Anual de Adquisiciones':             'fa-cart-shopping',
    'Plan de Participación Ciudadana':               'fa-people-group',
    'Mapa de Riesgos de Corrupción':                 'fa-map',
    'PAAC - Plan Anticorrupción':                    'fa-shield-halved',
    'PIC - Plan Institucional de Capacitación':      'fa-graduation-cap',
    'Plan Anual de Vacantes':                        'fa-user-plus',
    'Plan de Previsión de Recursos Humanos':         'fa-users-gear',
    'PETH - Plan Estratégico de Talento Humano':     'fa-user-tie',
    'Plan de Bienestar e Incentivos':                'fa-heart',
    'Plan de Seguridad y Salud en el Trabajo':       'fa-hard-hat',
    'PETI - Plan Estratégico de TI':                 'fa-microchip',
    'Plan de Tratamiento de Riesgos':                'fa-triangle-exclamation',
    'Plan Institucional de Archivos':                'fa-box-archive',
    'Plan de Austeridad':                            'fa-scale-balanced',
    'Programa de Transparencia y Ética Pública':     'fa-eye',
  };

  // Aplanar todos los documentos de las sections actuales
  const todosDocs: any[] = [];
  for (const s of pageData.sections) {
    if (Array.isArray(s.documents)) todosDocs.push(...s.documents);
  }

  // Agrupar por category
  const porCategoria: Record<string, any[]> = {};
  for (const doc of todosDocs) {
    const cat = (doc as any).category || 'Otros';
    (porCategoria[cat] ||= []).push(doc);
  }

  // Armar nuevas sections en el orden institucional; las categories no listadas van al final
  const nuevasSections: any[] = [];
  const listadas = new Set(ORDEN_CATEGORIAS);
  for (const cat of ORDEN_CATEGORIAS) {
    if (porCategoria[cat]?.length) {
      nuevasSections.push({
        sectionTitle: cat,
        sectionIcon: ICONO_POR_CATEGORIA[cat] || 'fa-folder',
        displayMode: 'accordion',
        documents: [...porCategoria[cat]].sort((a, b) => yearKey(b.anio) - yearKey(a.anio)),
      });
    }
  }
  for (const [cat, docs] of Object.entries(porCategoria)) {
    if (!listadas.has(cat) && docs.length) {
      nuevasSections.push({
        sectionTitle: cat,
        sectionIcon: 'fa-folder',
        displayMode: 'accordion',
        documents: [...docs].sort((a, b) => yearKey(b.anio) - yearKey(a.anio)),
      });
    }
  }

  (pageData as any).sections = nuevasSections;
}
---

<Base title={pageData.title} class={`page-documentos page-documentos--${config.color}`}>
  <HeroPage
    title={pageData.title}
    subtitle={pageData.description}
    icon={config.icon}
    breadcrumb={breadcrumb}
  />

  <section class="actions-bar">
    <div class="container">
      <a href={`${base}agencia/direccionamiento-estrategico`} class="back-link">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Volver a Direccionamiento Estratégico
      </a>
    </div>
  </section>

  <section class="documents-section">
    <div class="container">
      {pageData.sections.map((section, idx) => (
        <div class="doc-section">
          {section.displayMode === 'accordion' && (
            <Accordion
              variant="document"
              sections={[{
                sectionTitle: section.sectionTitle,
                sectionIcon: section.sectionIcon,
                documents: section.documents,
              }]}
              defaultOpen={0}
              showCount={false}
            />
          )}

          {section.displayMode === 'tabs' && (
            <Tabs
              documents={section.documents}
              id={`tabs-${idx}`}
            />
          )}

          {section.displayMode === 'list' && (
            <div>
              {section.sectionTitle && (
                <h2 class="doc-section__title">{section.sectionTitle}</h2>
              )}
              <ul class="doc-list" role="list">
                {section.documents.map((doc) => (
                  <li>
                    <DocumentItem document={doc} />
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="nav-secciones">
    <div class="container">
      <h2 class="sr-only">Otras secciones</h2>
      <div class="nav-secciones__grid">
        {slug !== 'politicas' && (
          <a href={`${base}agencia/direccionamiento-estrategico/politicas`} class="nav-seccion nav-seccion--navy">
            <i class="fa-solid fa-scale-balanced" aria-hidden="true"></i>
            <span>Políticas</span>
          </a>
        )}
        {slug !== 'planes' && (
          <a href={`${base}agencia/direccionamiento-estrategico/planes`} class="nav-seccion nav-seccion--gold">
            <i class="fa-solid fa-clipboard-list" aria-hidden="true"></i>
            <span>Planes</span>
          </a>
        )}
        {slug !== 'informes' && (
          <a href={`${base}agencia/direccionamiento-estrategico/informes`} class="nav-seccion nav-seccion--green">
            <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
            <span>Informes</span>
          </a>
        )}
      </div>
    </div>
  </section>
</Base>

<style>
  .actions-bar {
    background: var(--theme-surface);
    border-bottom: 1px solid var(--theme-border);
    padding: var(--space-4) var(--space-6);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .actions-bar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1000px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--theme-heading);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .back-link:hover {
    color: var(--itrc-gold);
    gap: var(--space-3);
  }

  .documents-section {
    padding: var(--space-12) var(--space-6);
    background: var(--theme-surface-alt);
    min-height: 50vh;
  }

  .documents-section .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .doc-section {
    margin-bottom: var(--space-8);
  }

  .doc-section__title {
    color: var(--theme-heading);
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-6);
  }

  .doc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    background: var(--theme-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .doc-list li {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--theme-border-light);
  }

  .doc-list li:last-child {
    border-bottom: none;
  }

  .nav-secciones {
    padding: var(--space-10) var(--space-6);
    background: var(--theme-surface);
    border-top: 1px solid var(--theme-border);
  }

  .nav-secciones__grid {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    max-width: 600px;
    margin: 0 auto;
  }

  .nav-seccion {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--font-size-sm);
    transition: all var(--transition-base);
  }

  .nav-seccion--navy {
    background: rgba(21, 37, 63, 0.1);
    color: var(--theme-heading);
  }

  .nav-seccion--navy:hover {
    background: var(--itrc-navy);
    color: var(--white);
  }

  .nav-seccion--gold {
    background: rgba(var(--itrc-gold-rgb), 0.15);
    color: var(--itrc-gold);
  }

  .nav-seccion--gold:hover {
    background: var(--itrc-gold);
    color: var(--itrc-navy);
  }

  .nav-seccion--green {
    background: rgba(5, 150, 105, 0.1);
    color: var(--green-accent);
  }

  .nav-seccion--green:hover {
    background: var(--green-accent);
    color: var(--white);
  }

  @media (max-width: 768px) {
    .actions-bar {
      padding: var(--space-3) var(--space-4);
    }

    .actions-bar .container {
      flex-direction: column;
      gap: var(--space-3);
      align-items: flex-start;
    }

    .documents-section {
      padding: var(--space-8) var(--space-4);
    }

    .nav-secciones {
      padding: var(--space-8) var(--space-4);
    }

    .nav-secciones__grid {
      flex-direction: column;
      gap: var(--space-3);
    }

    .nav-seccion {
      justify-content: center;
    }
  }
</style>
