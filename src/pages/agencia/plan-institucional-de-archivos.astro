---
import Base from '../../layouts/Base.astro';
import HeroPage from '../../components/HeroPage.astro';
import { resolveUrl } from '../../utils/url';
import pageData from '../../content/pages/agencia/plan-institucional-de-archivos.json';

const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Agencia', href: '#' },
  { label: 'Sistema Integrado de Gestión', href: resolveUrl('/agencia/sistema-integrado-de-gestion') },
  { label: pageData.title }
];
---

<Base title={pageData.title} description={pageData.description}>
  <HeroPage
    title={pageData.title}
    subtitle={pageData.description}
    icon={pageData.icon}
    breadcrumb={breadcrumb}
  />

  <section class="pinar-section">
    <div class="container">
      <p class="pinar-intro">{pageData.intro}</p>

      <ul class="pinar-list">
        {pageData.documentos.map((doc) => (
          <li class="pinar-item">
            <a href={doc.url} target="_blank" rel="noopener noreferrer" class="pinar-item__link">
              <div class="pinar-item__icon" aria-hidden="true">
                <i class="fa-solid fa-file-pdf"></i>
              </div>
              <div class="pinar-item__info">
                <span class="pinar-item__titulo">{doc.titulo}</span>
                {doc.anio && <span class="pinar-item__anio">{doc.anio}</span>}
              </div>
              <i class="fa-solid fa-arrow-up-right-from-square pinar-item__ext" aria-hidden="true"></i>
            </a>
          </li>
        ))}
      </ul>

      <div class="back-link">
        <a href={resolveUrl('/agencia/sistema-integrado-de-gestion')}>
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          Volver al Sistema Integrado de Gestión
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .pinar-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .pinar-section .container { max-width: 900px; margin: 0 auto; }

  .pinar-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text-secondary); margin-bottom: var(--space-10); text-align: center; max-width: 720px; margin-left: auto; margin-right: auto; }

  .pinar-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-4); }

  .pinar-item__link { display: flex; align-items: center; gap: var(--space-5); padding: var(--space-5) var(--space-6); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .pinar-item__link:hover { box-shadow: var(--shadow-md); border-color: var(--itrc-gold); transform: translateX(4px); }

  .pinar-item__icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--itrc-gold-light), var(--itrc-gold)); color: var(--itrc-navy); border-radius: var(--radius-md); font-size: var(--font-size-xl); flex-shrink: 0; }

  .pinar-item__info { flex: 1; display: flex; flex-direction: column; gap: var(--space-1); }
  .pinar-item__titulo { font-weight: 700; color: var(--theme-heading); font-size: var(--font-size-base); }
  .pinar-item__anio { font-size: var(--font-size-sm); color: var(--theme-text-muted); font-weight: 600; }

  .pinar-item__ext { font-size: var(--font-size-sm); color: var(--theme-text-muted); }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 640px) {
    .pinar-item__link { flex-wrap: wrap; padding: var(--space-4); }
  }
</style>
