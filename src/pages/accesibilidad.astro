---
import Base from '../layouts/Base.astro';
import HeroPage from '../components/HeroPage.astro';
import pageData from '../content/pages/transparencia/accesibilidad.json';

const base = import.meta.env.BASE_URL;
const breadcrumb = [{ label: 'Inicio', href: base }, { label: 'Transparencia', href: `${base}transparencia` }, { label: pageData.title }];

const iconMap: Record<string, string> = { pdf: 'fa-file-pdf', xlsx: 'fa-file-excel' };
---
<Base title={pageData.title} description={pageData.description}>
  <HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />
  <section class="acc-page"><div class="container">
    <p class="acc-intro">{pageData.texto}</p>
    <div class="acc-list">{pageData.documentos.map((d) => (
      <a href={d.url} target="_blank" rel="noopener" class={`acc-item acc--${d.tipo}`}><i class={`fa-solid ${iconMap[d.tipo] || 'fa-file-pdf'}`} aria-hidden="true"></i><span>{d.nombre}</span><i class="fa-solid fa-download" aria-hidden="true"></i></a>
    ))}</div>
    <div class="back-link"><a href={`${base}transparencia`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia</a></div>
  </div></section>
</Base>
<style>.acc-page{padding:var(--space-10) var(--space-6) var(--space-16);background:var(--theme-surface)}.acc-page .container{max-width:800px;margin:0 auto}.acc-intro{font-size:var(--font-size-base);line-height:1.8;color:var(--theme-text);margin-bottom:var(--space-8)}.acc-list{display:flex;flex-direction:column;gap:var(--space-3)}.acc-item{display:flex;align-items:center;gap:var(--space-4);padding:var(--space-4) var(--space-5);border:1px solid var(--theme-border-light);border-radius:var(--radius-lg);text-decoration:none;transition:all var(--transition-base)}.acc-item:hover{box-shadow:var(--shadow-md);transform:translateX(4px)}.acc--pdf>i:first-child{color:var(--file-pdf)}.acc--pdf:hover{border-color:rgba(220,53,69,0.3)}.acc--xlsx>i:first-child{color:var(--file-excel)}.acc--xlsx:hover{border-color:rgba(25,135,84,0.3)}.acc-item span{flex:1;font-size:var(--font-size-sm);font-weight:600;color:var(--theme-heading)}.acc-item:hover span{color:var(--itrc-gold)}.acc-item>i:last-child{color:var(--theme-text-muted);opacity:0.4}.back-link{margin-top:var(--space-8);text-align:center}.back-link a{display:inline-flex;align-items:center;gap:var(--space-2);color:var(--theme-text-muted);text-decoration:none;font-size:var(--font-size-sm);font-weight:600}.back-link a:hover{color:var(--itrc-gold)}</style>
