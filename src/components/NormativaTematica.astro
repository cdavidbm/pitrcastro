---
import HeroPage from './HeroPage.astro';

interface NormaRelacionada {
  titulo: string;
  url: string;
  tipo?: string;
}

interface PageData {
  title: string;
  description?: string;
  icon?: string;
  intro?: string;
  contenido?: string;
  normasRelacionadas?: NormaRelacionada[];
}

const { pageData } = Astro.props as { pageData: PageData };
const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Normativa', href: `${base}normativa` },
  { label: pageData.title }
];
---

<HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

<section class="nt-section">
  <div class="container">
    {pageData.intro && <p class="nt-intro">{pageData.intro}</p>}

    {pageData.contenido && (
      <article class="nt-contenido" set:html={pageData.contenido}></article>
    )}

    {pageData.normasRelacionadas && pageData.normasRelacionadas.length > 0 && (
      <>
        <h2 class="nt-heading"><i class="fa-solid fa-book" aria-hidden="true"></i> Normas relacionadas</h2>
        <ul class="nt-normas">
          {pageData.normasRelacionadas.map((n) => {
            const external = n.tipo !== 'internal';
            return (
              <li class="nt-norma">
                <a href={n.url} target={external ? '_blank' : '_self'} rel={external ? 'noopener noreferrer' : ''} class="nt-norma__link">
                  <i class={`fa-solid ${n.tipo === 'pdf' ? 'fa-file-pdf' : 'fa-file-lines'} nt-norma__icon`} aria-hidden="true"></i>
                  <span class="nt-norma__titulo">{n.titulo}</span>
                  {external && <i class="fa-solid fa-arrow-up-right-from-square nt-norma__ext" aria-hidden="true"></i>}
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}

    <div class="back-link">
      <a href={`${base}normativa`}><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Normativa</a>
    </div>
  </div>
</section>

<style>
  .nt-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .nt-section .container { max-width: 900px; margin: 0 auto; }

  .nt-intro { font-size: var(--font-size-base); line-height: 1.8; color: var(--theme-text-secondary); margin-bottom: var(--space-8); text-align: justify; font-style: italic; padding-left: var(--space-4); border-left: 3px solid var(--itrc-gold); }

  .nt-contenido { font-size: var(--font-size-sm); line-height: 1.75; color: var(--theme-text); margin-bottom: var(--space-10); }
  .nt-contenido :global(p) { margin: 0 0 var(--space-4); text-align: justify; }
  .nt-contenido :global(strong) { color: var(--theme-heading); font-weight: 700; }
  .nt-contenido :global(h2), .nt-contenido :global(h3), .nt-contenido :global(h4) { color: var(--theme-heading); margin: var(--space-5) 0 var(--space-3); }
  .nt-contenido :global(h2) { font-size: var(--font-size-xl); padding-bottom: var(--space-2); border-bottom: 2px solid var(--itrc-gold); }
  .nt-contenido :global(h3) { font-size: var(--font-size-lg); }
  .nt-contenido :global(ul), .nt-contenido :global(ol) { padding-left: var(--space-6); margin: 0 0 var(--space-4); }
  .nt-contenido :global(li) { margin-bottom: var(--space-2); }
  .nt-contenido :global(blockquote) { padding: var(--space-3) var(--space-4); background: var(--theme-surface-alt); border-left: 3px solid var(--itrc-gold); border-radius: var(--radius-sm); font-size: var(--font-size-sm); margin: var(--space-4) 0; }
  .nt-contenido :global(a) { color: var(--itrc-gold); text-decoration: underline; }
  .nt-contenido :global(a:hover) { color: var(--itrc-navy); }

  .nt-heading { display: flex; align-items: center; gap: var(--space-3); font-size: var(--font-size-lg); color: var(--theme-heading); margin: 0 0 var(--space-5); padding-bottom: var(--space-3); border-bottom: 2px solid var(--itrc-gold); }
  .nt-heading i { color: var(--itrc-gold); }

  .nt-normas { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .nt-norma__link { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-3) var(--space-4); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .nt-norma__link:hover { border-color: var(--itrc-gold); box-shadow: var(--shadow-sm); transform: translateX(3px); }
  .nt-norma__icon { color: var(--itrc-gold); font-size: var(--font-size-base); }
  .nt-norma__titulo { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); }
  .nt-norma__ext { color: var(--theme-text-muted); font-size: var(--font-size-xs); opacity: 0.5; }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }
</style>
