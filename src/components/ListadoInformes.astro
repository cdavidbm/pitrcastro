---
import HeroPage from './HeroPage.astro';

interface InformeItem {
  titulo: string;
  url: string;
}

interface PageData {
  title: string;
  description?: string;
  icon?: string;
  intro?: string;
  informes: InformeItem[];
}

const { pageData } = Astro.props as { pageData: PageData };
const base = import.meta.env.BASE_URL;

const breadcrumb = [
  { label: 'Inicio', href: base },
  { label: 'Transparencia', href: `${base}transparencia` },
  { label: pageData.title }
];

const total = pageData.informes.length;
---

<HeroPage title={pageData.title} subtitle={pageData.description} icon={pageData.icon} breadcrumb={breadcrumb} />

<section class="li-section">
  <div class="container">
    {pageData.intro && <p class="li-intro">{pageData.intro}</p>}

    <div class="li-count">
      <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
      <span>{total} informe{total === 1 ? '' : 's'} publicado{total === 1 ? '' : 's'}</span>
    </div>

    <ul class="li-list">
      {pageData.informes.map((inf, i) => (
        <li class="li-item">
          <a href={inf.url} target="_blank" rel="noopener noreferrer" class="li-item__link">
            <span class="li-item__num">{(i + 1).toString().padStart(2, '0')}</span>
            <i class="fa-solid fa-file-pdf li-item__icon" aria-hidden="true"></i>
            <span class="li-item__title">{inf.titulo}</span>
            <i class="fa-solid fa-download li-item__dl" aria-hidden="true"></i>
          </a>
        </li>
      ))}
    </ul>

    <div class="back-link">
      <a href={`${base}transparencia`}>
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Volver a Transparencia
      </a>
    </div>
  </div>
</section>

<style>
  .li-section { padding: var(--space-8) var(--space-6) var(--space-16); background: var(--theme-surface); }
  .li-section .container { max-width: 960px; margin: 0 auto; }

  .li-intro { font-size: var(--font-size-base); line-height: 1.7; color: var(--theme-text-secondary); margin-bottom: var(--space-8); text-align: center; max-width: 720px; margin-left: auto; margin-right: auto; }

  .li-count { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-5); background: var(--theme-surface-alt); border-radius: var(--radius-full); margin-bottom: var(--space-8); font-weight: 700; color: var(--itrc-gold); font-size: var(--font-size-sm); }

  .li-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }

  .li-item__link { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-4) var(--space-5); background: var(--theme-surface); border: 1px solid var(--theme-border-light); border-radius: var(--radius-lg); text-decoration: none; transition: all var(--transition-base); }
  .li-item__link:hover { border-color: var(--file-pdf); box-shadow: var(--shadow-md); transform: translateX(4px); }

  .li-item__num { display: inline-flex; align-items: center; justify-content: center; min-width: 36px; height: 36px; padding: 0 8px; background: var(--itrc-gold); color: var(--itrc-navy); border-radius: var(--radius-md); font-size: var(--font-size-xs); font-weight: 800; font-variant-numeric: tabular-nums; flex-shrink: 0; }
  .li-item__icon { color: var(--file-pdf); font-size: var(--font-size-lg); flex-shrink: 0; }
  .li-item__title { flex: 1; font-size: var(--font-size-sm); font-weight: 600; color: var(--theme-heading); line-height: 1.5; }
  .li-item__link:hover .li-item__title { color: var(--file-pdf); }
  .li-item__dl { color: var(--theme-text-muted); opacity: 0.4; font-size: var(--font-size-xs); }

  .back-link { margin-top: var(--space-10); text-align: center; }
  .back-link a { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--theme-text-muted); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
  .back-link a:hover { color: var(--itrc-gold); }

  @media (max-width: 640px) {
    .li-item__link { flex-wrap: wrap; padding: var(--space-3) var(--space-4); }
    .li-item__title { width: 100%; order: 3; }
  }
</style>
