---
/**
 * Card de noticia individual
 */
interface Props {
  title: string;
  date: string;
  image?: string;
  excerpt?: string;
  slug: string;
  categoria?: 'noticia' | 'boletin' | 'comunicado' | string;
}

const { title, date, image, excerpt, slug, categoria } = Astro.props;
const base = import.meta.env.BASE_URL;

const formattedDate = new Date(date).toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const catLabels: Record<string, string> = {
  noticia: 'Noticia',
  boletin: 'Boletín',
  comunicado: 'Comunicado',
  periodico: 'Periódico',
};
const catLabel = categoria ? (catLabels[categoria] || categoria) : '';
---

<article class="news-card" data-categoria={categoria || ''}>
  <a href={`${base}prensa/noticias/${slug}`} class="news-card__link">
    {image && (
      <div class="news-card__image">
        <img src={image} alt="" loading="lazy" />
        {catLabel && <span class={`news-card__badge news-card__badge--${categoria}`}>{catLabel}</span>}
      </div>
    )}
    <div class="news-card__content">
      <div class="news-card__meta">
        <time datetime={date} class="news-card__date">
          <i class="fa-regular fa-calendar" aria-hidden="true"></i>
          {formattedDate}
        </time>
        {catLabel && !image && <span class={`news-card__badge news-card__badge--${categoria} news-card__badge--inline`}>{catLabel}</span>}
      </div>
      <h3 class="news-card__title">{title}</h3>
      {excerpt && <p class="news-card__excerpt">{excerpt}</p>}
      <span class="news-card__read-more">
        Leer más
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </span>
    </div>
  </a>
</article>

<style is:global>
  .news-card__image { position: relative; }
  .news-card__badge {
    position: absolute; top: var(--space-3); left: var(--space-3);
    padding: 4px 12px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-full);
    color: #fff;
    background: var(--itrc-gold);
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  .news-card__badge--inline {
    position: static;
    box-shadow: none;
  }
  .news-card__badge--boletin { background: #0943b5; }
  .news-card__badge--comunicado { background: var(--itrc-gold); color: var(--itrc-navy); }
  .news-card__badge--noticia { background: #198754; }
  .news-card__badge--periodico { background: var(--itrc-navy); color: #fff; border: 2px solid var(--itrc-gold); }
  .news-card__meta { display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); margin-bottom: var(--space-3); flex-wrap: wrap; }
  .news-card__meta .news-card__date { margin-bottom: 0; }
</style>

<style>
  .news-card {
    background: var(--theme-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
  }

  .news-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .news-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .news-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .news-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .news-card:hover .news-card__image img {
    transform: scale(1.05);
  }

  .news-card__content {
    padding: var(--space-6);
  }

  .news-card__date {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--theme-text-muted);
    margin-bottom: var(--space-3);
  }

  .news-card__title {
    font-size: var(--font-size-lg);
    margin: 0 0 var(--space-3);
    color: var(--theme-heading);
    line-height: 1.4;
    transition: color var(--transition-fast);
  }

  .news-card:hover .news-card__title {
    color: var(--itrc-gold-dark);
  }

  .news-card__excerpt {
    font-size: var(--font-size-sm);
    color: var(--theme-text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--itrc-gold-dark);
    transition: all var(--transition-fast);
  }

  .news-card:hover .news-card__read-more {
    color: var(--itrc-gold);
    gap: var(--space-3);
  }
</style>
