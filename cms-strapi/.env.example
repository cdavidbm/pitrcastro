HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (Postgres por defecto, ver docker-compose.yml en raíz del repo)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi_dev_password
DATABASE_SSL=false

# GitHub dispatch (rebuild trigger). Dejarlas vacías deshabilita el dispatch.
# Configurar para activar el flujo: Strapi publish → GitHub Actions rebuild.
# El PAT requiere scope Actions:write sobre el repo.
GITHUB_REPO=cdavidbm/pitrcastro
GITHUB_DISPATCH_TOKEN=
