# Plantilla de configuración de despliegue.
# Copia este archivo a `.env.deploy` (que está gitignored) y completa con valores reales.
# Usado por `ops/deploy.sh` (ejecutado vía `npm run deploy`).

# ---- Build ----

# URL canónica del sitio (afecta sitemap, og:url, etc.).
# Pruebas: http://192.168.X.X
# Producción futura: https://portal.itrc.gov.co
SITE_URL=http://CAMBIAR-IP-SERVIDOR

# Base path. "/" para dominio raíz; "/subpath/" si se monta bajo subdirectorio.
BASE_PATH=/

# ---- Conexión SSH al servidor ----

DEPLOY_HOST=CAMBIAR-IP-SERVIDOR
DEPLOY_USER=admweb
DEPLOY_PATH=/var/www/itrc-web

# ---- SSH (opcional) ----
# Por defecto usa el `ssh` del PATH (Linux/macOS nativo, o WSL en
# networkingMode=mirrored que ve la VPN de Windows).
# Sólo descomentar si necesitas un binario específico (e.g. ssh.exe en
# WSL sin mirrored, o un wrapper personalizado).
# SSH_BIN=ssh
